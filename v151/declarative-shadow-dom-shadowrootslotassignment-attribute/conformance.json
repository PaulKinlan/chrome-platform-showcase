  "assertions": [
    {
      "id": "shadowroot-slotassignment-reflected",
      "description": "ShadowRoot exposes a slotAssignment mode.",
      "kind": "exists",
      "test": "ShadowRoot.prototype.slotAssignment",
      "specSection": "https://dom.spec.whatwg.org/#dom-shadowroot-slotassignment"
    },
    {
      "id": "declarative-slotassignment-manual-parsed",
      "description": "Parsing a declarative shadow root whose template carries shadowrootslotassignment=\"manual\" yields a shadow root in manual slot-assignment mode.",
      "kind": "script",
      "test": "(()=>{const d=Document.parseHTMLUnsafe('<div id=h><template shadowrootmode=\"open\" shadowrootslotassignment=\"manual\"></template></div>');const sr=d.getElementById('h').shadowRoot;return !!sr && sr.slotAssignment==='manual';})()",
      "specSection": "https://html.spec.whatwg.org/#attr-template-shadowrootslotassignment"
    },
    {
      "id": "declarative-slotassignment-default-named",
      "description": "Parsing a declarative shadow root without the attribute yields the default named slot assignment.",
      "kind": "script",
      "test": "(()=>{const d=Document.parseHTMLUnsafe('<div id=h><template shadowrootmode=\"open\"></template></div>');const sr=d.getElementById('h').shadowRoot;return !!sr && sr.slotAssignment==='named';})()",
      "specSection": "https://dom.spec.whatwg.org/#dom-shadowroot-slotassignment"
    }
  ]
