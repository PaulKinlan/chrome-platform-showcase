      "id": "ruby-overhang-auto-supported",
      "description": "CSS.supports recognises the ruby-overhang property with its initial 'auto' value.",
      "kind": "css-supports",
      "test": "ruby-overhang: auto",
      "specSection": "https://drafts.csswg.org/css-ruby/#ruby-overhang"
    },
    {
      "id": "ruby-overhang-spaces-supported",
      "description": "ruby-overhang accepts the 'spaces' keyword — annotations only overhang adjacent spaces / CJK punctuation.",
      "kind": "css-supports",
      "test": "ruby-overhang: spaces",
      "specSection": "https://drafts.csswg.org/css-ruby/#ruby-overhang"
    },
    {
      "id": "ruby-overhang-none-aliases-spaces",
      "description": "Per CSSWG, 'none' is aliased to 'spaces'; the parser must still accept 'none' as a value.",
      "kind": "css-supports",
      "test": "ruby-overhang: none",
      "specSection": "https://drafts.csswg.org/css-ruby/#ruby-overhang"
    },
    {
      "id": "ruby-overhang-rejects-bogus",
      "description": "An unrelated keyword like 'bananas' must not be reported as supported.",
      "kind": "script",
      "test": "!CSS.supports('ruby-overhang: bananas')",
      "specSection": "https://drafts.csswg.org/css-ruby/#ruby-overhang"
    },
    {
      "id": "ruby-overhang-roundtrips-through-cssom",
      "description": "Setting rubyOverhang via CSSOM and reading getComputedStyle returns one of the keyword values.",
      "kind": "script",
      "test": "(()=>{const r=document.createElement('ruby');r.style.rubyOverhang='spaces';document.body.appendChild(r);const v=getComputedStyle(r).rubyOverhang||getComputedStyle(r).getPropertyValue('ruby-overhang');r.remove();return /^(auto|spaces|none)$/.test((v||'').trim());})()",
      "specSection": "https://drafts.csswg.org/css-ruby/#ruby-overhang"
    },
    {
      "id": "ruby-overhang-is-inherited",
      "description": "The spec marks ruby-overhang as inherited. Setting it on a parent should propagate the computed value to a nested ruby annotation container.",
      "kind": "script",
      "test": "(()=>{const p=document.createElement('div');p.style.rubyOverhang='spaces';const c=document.createElement('ruby');p.appendChild(c);document.body.appendChild(p);const cv=(getComputedStyle(c).rubyOverhang||getComputedStyle(c).getPropertyValue('ruby-overhang')||'').trim();p.remove();return cv==='spaces';})()",
      "specSection": "https://drafts.csswg.org/css-ruby/#ruby-overhang"
    }
  ]
