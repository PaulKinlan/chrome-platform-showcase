      "id": "iframe-allow-attribute",
      "description": "HTMLIFrameElement exposes an `allow` attribute — the surface that carries permissions-policy directives like focus-without-user-activation.",
      "kind": "script",
      "test": "'allow' in document.createElement('iframe')",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "focus-method-on-htmlelement",
      "description": "HTMLElement.prototype.focus exists and is callable; the policy gates programmatic focus calls, so the API surface itself remains in place.",
      "kind": "typeof",
      "test": "HTMLElement.prototype.focus",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "window-focus-is-function",
      "description": "window.focus() is one of the surfaces this policy governs in subframes.",
      "kind": "typeof",
      "test": "window.focus",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "showmodal-is-function",
      "description": "HTMLDialogElement.prototype.showModal is gated by the policy (modal dialogs focus their default button). The method must be present.",
      "kind": "script",
      "test": "typeof HTMLDialogElement!=='undefined' && typeof HTMLDialogElement.prototype.showModal==='function'",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "autofocus-attribute-reflects",
      "description": "The autofocus content attribute is one of the surfaces this policy governs; it must reflect on freshly-created inputs.",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('input');i.autofocus=true;return i.hasAttribute('autofocus');})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "permissions-policy-known-feature",
      "description": "If document.permissionsPolicy / featurePolicy is present and exposes features(), 'focus-without-user-activation' should appear as a known feature name.",
      "kind": "script",
      "test": "(()=>{const p=document.permissionsPolicy||document.featurePolicy;if(!p||typeof p.features!=='function')return true;return p.features().includes('focus-without-user-activation');})()",
      "specSection": "https://html.spec.whatwg.org/#focus-without-user-activation-feature"
    }
