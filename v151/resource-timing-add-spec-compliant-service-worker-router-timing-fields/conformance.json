      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "workerMatchedRouterSource-on-prototype",
      "description": "PerformanceResourceTiming.prototype exposes a workerMatchedRouterSource accessor as defined in the W3C Resource Timing spec PR #415.",
      "kind": "script",
      "test": "'workerMatchedRouterSource' in PerformanceResourceTiming.prototype",
      "specSection": "https://github.com/w3c/resource-timing/pull/415"
    },
    {
      "id": "workerFinalRouterSource-on-prototype",
      "description": "PerformanceResourceTiming.prototype exposes a workerFinalRouterSource accessor.",
      "kind": "script",
      "test": "'workerFinalRouterSource' in PerformanceResourceTiming.prototype",
      "specSection": "https://github.com/w3c/resource-timing/pull/415"
    },
    {
      "id": "performance-observer-supports-resource",
      "description": "PerformanceObserver can subscribe to entries of type 'resource'; this is required to observe router-source values on real navigations.",
      "kind": "script",
      "test": "(()=>{const types=(PerformanceObserver && PerformanceObserver.supportedEntryTypes)||[];return Array.isArray(types) && types.includes('resource');})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "router-source-fields-are-string-typed",
      "description": "On a real resource entry, the new fields are typed as string (DOMString getters). On entries where the request didn't go through a SW router, they may be empty strings.",
      "kind": "script",
      "test": "(async()=>{const entries=performance.getEntriesByType('resource');if(!entries.length)return true;const e=entries[0];return (typeof e.workerMatchedRouterSource==='string'||typeof e.workerMatchedRouterSource==='undefined') && (typeof e.workerFinalRouterSource==='string'||typeof e.workerFinalRouterSource==='undefined');})()",
      "specSection": "https://github.com/w3c/resource-timing/pull/415"
    },
    {
      "id": "service-worker-api-available",
      "description": "navigator.serviceWorker is exposed — required for the static router that produces these timing values.",
      "kind": "exists",
      "test": "navigator.serviceWorker",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
