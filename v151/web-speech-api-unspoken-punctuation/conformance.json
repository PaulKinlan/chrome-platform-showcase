    },
    {
      "id": "unspokenPunctuation-on-prototype",
      "description": "SpeechRecognition.prototype exposes an unspokenPunctuation property.",
      "kind": "script",
      "test": "(()=>{const SR=window.SpeechRecognition||window.webkitSpeechRecognition;return !!SR && 'unspokenPunctuation' in SR.prototype;})()",
      "specSection": "https://github.com/WebAudio/web-speech-api/blob/main/explainers/unspoken-punctuation.md"
    },
    {
      "id": "unspokenPunctuation-default-false",
      "description": "Per the explainer, the attribute defaults to false on a freshly-constructed SpeechRecognition.",
      "kind": "script",
      "test": "(()=>{const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR)return false;const r=new SR();return r.unspokenPunctuation===false;})()",
      "specSection": "https://github.com/WebAudio/web-speech-api/blob/main/explainers/unspoken-punctuation.md"
    },
    {
      "id": "unspokenPunctuation-settable",
      "description": "Setting unspokenPunctuation=true must persist on the instance (it's a writable boolean attribute).",
      "kind": "script",
      "test": "(()=>{const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR)return false;const r=new SR();r.unspokenPunctuation=true;return r.unspokenPunctuation===true;})()",
      "specSection": "https://github.com/WebAudio/web-speech-api/blob/main/explainers/unspoken-punctuation.md"
    },
    {
      "id": "continuous-still-present",
      "description": "Existing SpeechRecognition attributes like 'continuous' remain in place — unspokenPunctuation is additive, not a replacement.",
      "kind": "script",
      "test": "(()=>{const SR=window.SpeechRecognition||window.webkitSpeechRecognition;return !!SR && 'continuous' in SR.prototype;})()",
      "specSection": "https://wicg.github.io/speech-api/#speechreco-section"
    },
