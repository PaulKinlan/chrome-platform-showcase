      "id": "domparser-parses-wellformed-xml",
      "description": "DOMParser parses a well-formed XML document into an XML DOM (the observable contract of the parser, now memory-safe in Rust).",
      "kind": "script",
      "test": "(()=>{const d=new DOMParser().parseFromString('<root><child>ok</child></root>','application/xml');return d.documentElement.tagName==='root' && d.querySelector('child').textContent==='ok';})()",
      "specSection": "https://www.w3.org/TR/xml/#sec-well-formed"
    },
    {
      "id": "domparser-reports-malformed-xml",
      "description": "DOMParser surfaces a parsererror element for malformed (non-well-formed) XML.",
      "kind": "script",
      "test": "(()=>{const d=new DOMParser().parseFromString('<root><unclosed></root>','application/xml');return !!d.querySelector('parsererror');})()",
      "specSection": "https://www.w3.org/TR/xml/#sec-well-formed"
    },
    {
      "id": "domparser-preserves-namespaces",
      "description": "Namespaced XML is parsed with namespace URIs intact.",
      "kind": "script",
      "test": "(()=>{const d=new DOMParser().parseFromString('<a:root xmlns:a=\"urn:x\"/>','application/xml');return d.documentElement.namespaceURI==='urn:x';})()",
      "specSection": "https://www.w3.org/TR/xml-names/"
