      "id": "slotted-flat-tree-cq-applies",
      "description": "An unnamed inline-size container inside shadow DOM is queryable from slotted light-DOM descendants (the flat-tree change).",
      "kind": "script",
      "test": "(()=>{try{const style=document.createElement('style');style.textContent='.t{display:inline-block;width:10px}@container (min-width: 200px){.t{width:42px}}';document.head.appendChild(style);const host=document.createElement('div');host.style.cssText='display:block;width:600px;container-type:inline-size';const root=host.attachShadow({mode:'open'});root.innerHTML='<slot></slot>';const target=document.createElement('span');target.className='t';host.appendChild(target);document.body.appendChild(host);const ok=getComputedStyle(target).width==='42px';host.remove();style.remove();return ok;}catch(err){return false;}})()",
      "specSection": "https://drafts.csswg.org/css-conditional-5/#container-queries"
    },
    {
      "id": "container-queries-conditional-supported",
      "description": "@container conditional rules parse via CSSOM (sheet.cssRules contains the rule).",
      "kind": "script",
