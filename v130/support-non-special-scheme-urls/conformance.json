      "expect": "function",
      "specSection": "https://url.spec.whatwg.org/#url-class"
    },
    {
      "id": "opaque-non-special-url-parses",
      "description": "An opaque non-special URL parses without requiring a host.",
      "kind": "script",
      "test": "(()=>{const url=new URL('foo:bar');return url.protocol==='foo:'&&url.host===''&&url.pathname==='bar'&&url.origin==='null';})()",
      "specSection": "https://url.spec.whatwg.org/#non-special-scheme"
    },
    {
      "id": "hierarchical-non-special-url-parses-host",
      "description": "A non-special hierarchical URL preserves its host and path.",
      "kind": "script",
      "test": "(()=>{const url=new URL('web+demo://host.example/path?x=1#frag');return url.protocol==='web+demo:'&&url.host==='host.example'&&url.pathname==='/path'&&url.search==='?x=1'&&url.hash==='#frag'&&url.origin==='null';})()",
      "specSection": "https://url.spec.whatwg.org/#non-special-scheme"
    },
    {
      "id": "non-special-path-normalization",
      "description": "A non-special URL with authority normalizes dot segments in the path.",
      "kind": "script",
      "test": "(()=>{const url=new URL('git://example.com/a/../b');return url.host==='example.com'&&url.pathname==='/b'&&url.origin==='null';})()",
      "specSection": "https://url.spec.whatwg.org/#path-state"
    },
    {
      "id": "mailto-opaque-path",
      "description": "mailto remains an opaque-path non-special URL with null origin.",
      "kind": "script",
      "test": "(()=>{const url=new URL('mailto:user@example.com');return url.protocol==='mailto:'&&url.pathname==='user@example.com'&&url.origin==='null';})()",
      "specSection": "https://url.spec.whatwg.org/#cannot-be-a-base-url-path-state"
    },
