  "assertions": [
    {
      "id": "canvas-2d-context-float16-supported",
      "description": "HTMLCanvasElement.getContext('2d') accepts a colorType:'float16' option per the proposal.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas');const ctx=c.getContext('2d',{colorType:'float16'});if(!ctx)return false;const s=ctx.getContextAttributes&&ctx.getContextAttributes();return !!s&&(s.colorType==='float16'||s.colorType==='unorm8');})()",
      "specSection": "https://github.com/w3c/ColorWeb-CG/blob/master/canvas_float.md"
    },
    {
      "id": "canvas-2d-default-colorType-unorm8",
      "description": "When colorType is unspecified, getContextAttributes() reports the default 'unorm8'.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas');const ctx=c.getContext('2d');const s=ctx&&ctx.getContextAttributes&&ctx.getContextAttributes();return !!s&&(s.colorType===undefined||s.colorType==='unorm8');})()",
      "specSection": "https://github.com/w3c/ColorWeb-CG/blob/master/canvas_float.md"
    },
    {
      "id": "imagedata-pixelformat-float16-accepted",
      "description": "ImageData supports a pixelFormat option that accepts 'rgba-float16' for high-precision pixel buffers.",
      "kind": "script",
      "test": "(()=>{try{const d=new ImageData(1,1,{pixelFormat:'rgba-float16'});return d.data instanceof Float16Array||d.data instanceof Float32Array||d.data instanceof Uint8ClampedArray;}catch(e){return false;}})()",
      "specSection": "https://github.com/w3c/ColorWeb-CG/blob/master/canvas_float.md"
    },
    {
      "id": "canvasrenderingcontext2d-exists",
      "description": "CanvasRenderingContext2D is the interface receiving the new colorType setting.",
      "kind": "exists",
      "test": "CanvasRenderingContext2D",
      "specSection": "https://html.spec.whatwg.org/multipage/canvas.html#canvasrenderingcontext2d"
    },
    {
      "id": "getcontextattributes-is-function",
      "description": "CanvasRenderingContext2D.prototype.getContextAttributes() is a function exposing the resolved colorType.",
      "kind": "script",
      "test": "typeof CanvasRenderingContext2D.prototype.getContextAttributes==='function'",
      "specSection": "https://html.spec.whatwg.org/multipage/canvas.html#dom-canvasrenderingcontext2d-getcontextattributes"
    },
    {
      "id": "offscreencanvas-2d-accepts-colorType",
      "description": "OffscreenCanvas also accepts a colorType:'float16' settings dictionary for its 2D context.",
      "kind": "script",
      "test": "(()=>{if(typeof OffscreenCanvas==='undefined')return false;const c=new OffscreenCanvas(1,1);const ctx=c.getContext('2d',{colorType:'float16'});return !!ctx;})()",
      "specSection": "https://github.com/w3c/ColorWeb-CG/blob/master/canvas_float.md"
    }
