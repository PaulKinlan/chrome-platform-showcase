{
  "release": "v137",
  "featureSlug": "ed25519-in-web-cryptography",
  "chromestatusId": 4913922408710144,
  "specUrl": "https://w3c.github.io/webcrypto/#ed25519",
  "generatedAt": "2026-06-01T08:50:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "subtle-crypto-exists",
      "description": "crypto.subtle is the entry point for the Web Cryptography algorithms.",
      "kind": "exists",
      "test": "crypto.subtle",
      "specSection": "https://w3c.github.io/webcrypto/#subtlecrypto-interface"
    },
    {
      "id": "subtle-generatekey-is-function",
      "description": "crypto.subtle.generateKey is a function used to mint Ed25519 key pairs.",
      "kind": "typeof",
      "test": "crypto.subtle.generateKey",
      "expect": "function",
      "specSection": "https://w3c.github.io/webcrypto/#SubtleCrypto-method-generateKey"
    },
    {
      "id": "generatekey-ed25519-resolves",
      "description": "generateKey({name:'Ed25519'}, true, ['sign','verify']) resolves to a CryptoKeyPair.",
      "kind": "script",
      "test": "(async()=>{const k=await crypto.subtle.generateKey({name:'Ed25519'},true,['sign','verify']);return !!(k&&k.privateKey&&k.publicKey&&k.publicKey.algorithm.name==='Ed25519');})().then(b=>b).catch(()=>false)",
      "specSection": "https://w3c.github.io/webcrypto/#ed25519"
    },
    {
      "id": "ed25519-sign-verify-roundtrip",
      "description": "sign/verify with the produced Ed25519 keypair round-trips for arbitrary data.",
      "kind": "script",
      "test": "(async()=>{const k=await crypto.subtle.generateKey({name:'Ed25519'},true,['sign','verify']);const data=new TextEncoder().encode('hi');const sig=await crypto.subtle.sign({name:'Ed25519'},k.privateKey,data);return await crypto.subtle.verify({name:'Ed25519'},k.publicKey,sig,data);})().then(b=>b).catch(()=>false)",
      "specSection": "https://w3c.github.io/webcrypto/#ed25519-operations"
    },
    {
      "id": "ed25519-export-raw-public-32-bytes",
      "description": "Exporting an Ed25519 public key as 'raw' yields the 32-byte encoded point.",
      "kind": "script",
      "test": "(async()=>{const k=await crypto.subtle.generateKey({name:'Ed25519'},true,['sign','verify']);const raw=await crypto.subtle.exportKey('raw',k.publicKey);return raw.byteLength===32;})().then(b=>b).catch(()=>false)",
      "specSection": "https://w3c.github.io/webcrypto/#ed25519-operations"
    },
    {
      "id": "ed25519-jwk-export-has-okp-kty",
      "description": "Exporting an Ed25519 public key as 'jwk' yields a JWK with kty:'OKP' and crv:'Ed25519'.",
      "kind": "script",
      "test": "(async()=>{const k=await crypto.subtle.generateKey({name:'Ed25519'},true,['sign','verify']);const jwk=await crypto.subtle.exportKey('jwk',k.publicKey);return jwk.kty==='OKP'&&jwk.crv==='Ed25519';})().then(b=>b).catch(()=>false)",
      "specSection": "https://w3c.github.io/webcrypto/#ed25519-operations"
    }
  ]
}
