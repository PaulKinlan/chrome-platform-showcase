      "description": "HTMLMediaElement.prototype.pause runs the internal pause steps; the spec triggers these when the iframe is hidden.",
      "kind": "script",
      "test": "typeof HTMLMediaElement.prototype.pause==='function'",
      "specSection": "https://wicg.github.io/iframe-media-pausing/#pause-on-not-rendered"
