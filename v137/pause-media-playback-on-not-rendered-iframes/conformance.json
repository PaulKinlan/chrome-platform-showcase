      "kind": "script",
      "test": "(()=>{try{const f=document.featurePolicy||document.permissionsPolicy;return !!f&&typeof f.allowsFeature==='function';}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/iframe-media-pausing/#permission-policy"
