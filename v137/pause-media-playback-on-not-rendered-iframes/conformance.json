      "description": "HTMLMediaElement.prototype.play returns a Promise that rejects with NotAllowedError when the iframe is not rendered.",
      "kind": "script",
      "test": "(()=>{const v=document.createElement('video');const p=v.play();const ok=p&&typeof p.then==='function';if(p&&p.catch)p.catch(()=>{});return ok;})()",
      "specSection": "https://wicg.github.io/iframe-media-pausing/#pause-on-not-rendered"
    },
    {
      "id": "audiocontext-has-interrupted-state",
      "description": "AudioContext.state can take the value 'interrupted' when the iframe is not rendered.",
      "kind": "script",
      "test": "(()=>{try{const ctx=new (window.AudioContext||window.webkitAudioContext)();const ok=['suspended','running','closed','interrupted'].includes(ctx.state);ctx.close();return ok;}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/iframe-media-pausing/#audiocontext-interrupted"
    },
