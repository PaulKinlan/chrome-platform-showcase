  "assertions": [
    {
      "id": "svg-use-element-constructable",
      "description": "Documents can create an SVG <use> element via createElementNS.",
      "kind": "script",
      "test": "document.createElementNS('http://www.w3.org/2000/svg','use') instanceof SVGUseElement",
      "specSection": "https://svgwg.org/svg2-draft/struct.html#UseElement"
    },
    {
      "id": "svguseelement-prototype-href",
      "description": "SVGUseElement exposes the href IDL attribute as an SVGAnimatedString.",
      "kind": "script",
      "test": "'href' in SVGUseElement.prototype",
      "specSection": "https://svgwg.org/svg2-draft/struct.html#UseElementHrefAttribute"
    },
    {
      "id": "svguseelement-href-accepts-no-fragment",
      "description": "Setting href to a URL without a fragment reflects through to the baseVal unchanged.",
      "kind": "script",
      "test": "(()=>{const u=document.createElementNS('http://www.w3.org/2000/svg','use');u.setAttribute('href','./shape.svg');return u.href.baseVal==='./shape.svg';})()",
      "specSection": "https://svgwg.org/svg2-draft/struct.html#UseElementHrefAttribute"
    },
    {
      "id": "svguseelement-href-animval-readable",
      "description": "SVGAnimatedString.animVal reflects the resolved href on the <use> element.",
      "kind": "script",
      "test": "(()=>{const u=document.createElementNS('http://www.w3.org/2000/svg','use');u.setAttribute('href','./shape.svg');return typeof u.href.animVal==='string';})()",
      "specSection": "https://svgwg.org/svg2-draft/struct.html#UseElementHrefAttribute"
    },
    {
      "id": "svg-use-prototype-on-svguseelement",
      "description": "SVGUseElement.prototype identifies use elements distinctly from other SVG elements.",
      "kind": "script",
      "test": "SVGUseElement.prototype instanceof SVGGraphicsElement",
      "specSection": "https://svgwg.org/svg2-draft/struct.html#UseElement"
    },
    {
      "id": "svguseelement-legacy-xlink-href",
      "description": "Legacy xlink:href attribute is still accepted for backwards compatibility.",
      "kind": "script",
      "test": "(()=>{const u=document.createElementNS('http://www.w3.org/2000/svg','use');u.setAttributeNS('http://www.w3.org/1999/xlink','xlink:href','./shape.svg');return u.getAttributeNS('http://www.w3.org/1999/xlink','href')==='./shape.svg';})()",
      "specSection": "https://svgwg.org/svg2-draft/struct.html#UseElementHrefAttribute"
    }
