    {
      "id": "svg-root-transform-attribute-accepted",
      "description": "Setting the transform attribute on the <svg> root element via setAttribute is round-trippable.",
      "kind": "script",
      "test": "(()=>{const s=document.createElementNS('http://www.w3.org/2000/svg','svg');s.setAttribute('transform','rotate(45)');return s.getAttribute('transform')==='rotate(45)';})()",
      "specSection": "https://www.w3.org/TR/SVG2/struct.html#SVGElement"
    },
    {
      "id": "svg-root-transform-idl-reflects",
      "description": "SVGSVGElement reflects 'transform' via the SVGAnimatedTransformList IDL attribute (inherited from SVGGraphicsElement).",
      "kind": "script",
      "test": "(()=>{const s=document.createElementNS('http://www.w3.org/2000/svg','svg');s.setAttribute('transform','translate(10 20)');return !!(s.transform&&s.transform.baseVal&&typeof s.transform.baseVal.numberOfItems==='number');})()",
      "specSection": "https://svgwg.org/svg2-draft/coords.html#TransformAttribute"
    },
    {
      "id": "nested-svg-transform-also-supported",
      "description": "Inner (nested) <svg> elements likewise accept transform.",
      "kind": "script",
      "test": "(()=>{const s=document.createElementNS('http://www.w3.org/2000/svg','svg');s.setAttribute('transform','scale(2)');document.body.appendChild(s);const ok=getComputedStyle(s).transform!==undefined;s.remove();return ok;})()",
      "specSection": "https://www.w3.org/TR/SVG2/struct.html#SVGElement"
    },
