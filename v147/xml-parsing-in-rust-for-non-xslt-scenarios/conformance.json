      "test": "window.XMLSerializer",
      "specSection": "https://html.spec.whatwg.org/multipage/dynamic-markup-insertion.html#xmlserializer"
    },
    {
      "id": "xml-parse-wellformed-xml",
      "description": "DOMParser correctly parses a well-formed XML string with application/xml MIME type.",
      "kind": "script",
      "test": "new DOMParser().parseFromString('<root><item id=\"1\">Hello</item></root>', 'application/xml').documentElement.tagName === 'root'",
      "specSection": "https://html.spec.whatwg.org/multipage/dynamic-markup-insertion.html#domparser"
    },
    {
      "id": "xml-parse-wellformed-svg",
      "description": "DOMParser correctly parses an SVG string with image/svg+xml MIME type.",
      "kind": "script",
      "test": "new DOMParser().parseFromString('<svg xmlns=\"http://www.w3.org/2000/svg\"/>', 'image/svg+xml').documentElement instanceof SVGElement",
      "specSection": "https://html.spec.whatwg.org/multipage/dynamic-markup-insertion.html#domparser"
    },
    {
      "id": "xml-parse-malformed-xml-error",
      "description": "DOMParser returns a document containing a parsererror element when parsing malformed XML.",
      "kind": "script",
      "test": "new DOMParser().parseFromString('<root><unclosed>text</root>', 'application/xml').querySelector('parsererror') !== null",
      "specSection": "https://html.spec.whatwg.org/multipage/dynamic-markup-insertion.html#domparser"
    },
    {
      "id": "xml-serializer-roundtrip",
      "description": "XMLSerializer correctly serializes an XML Document back to a string.",
      "kind": "script",
      "test": "new XMLSerializer().serializeToString(new DOMParser().parseFromString('<root/>', 'application/xml')).includes('<root/>') || new XMLSerializer().serializeToString(new DOMParser().parseFromString('<root/>', 'application/xml')).includes('<root></root>')",
      "specSection": "https://html.spec.whatwg.org/multipage/dynamic-markup-insertion.html#xmlserializer"
    }
  ]
