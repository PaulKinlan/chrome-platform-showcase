      "description": "element.pseudo('::before') returns a CSSPseudoElement instance.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');document.body.appendChild(e);const p=e.pseudo('::before');e.remove();return p instanceof CSSPseudoElement;})()",
      "specSection": "https://www.w3.org/TR/css-pseudo-4/#dom-element-pseudo"
    },
    {
      "id": "csspseudoelement-type-attr",
      "description": "A returned CSSPseudoElement exposes a type attribute reflecting the pseudo-element kind.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');document.body.appendChild(e);const p=e.pseudo('::before');const ok=p && p.type==='::before';e.remove();return ok;})()",
      "specSection": "https://www.w3.org/TR/css-pseudo-4/#dom-csspseudoelement-type"
    },
    {
      "id": "csspseudoelement-element-attr",
      "description": "CSSPseudoElement.element points back at the originating element.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');document.body.appendChild(e);const p=e.pseudo('::before');const ok=p && p.element===e;e.remove();return ok;})()",
      "specSection": "https://www.w3.org/TR/css-pseudo-4/#dom-csspseudoelement-element"
