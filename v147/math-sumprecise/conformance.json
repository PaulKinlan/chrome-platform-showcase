      "id": "math-sumprecise-extreme-precision",
      "description": "Math.sumPrecise correctly handles extreme float magnitude differences that naive addition loses (e.g. [1e20, 0.1, -1e20] returns 0.1).",
      "kind": "script",
      "test": "Math.sumPrecise([1e20, 0.1, -1e20]) === 0.1"
    },
    {
