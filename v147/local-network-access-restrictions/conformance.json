    {
      "id": "request-prototype-target-address-space",
      "description": "Request prototype exposes the 'targetAddressSpace' attribute.",
      "kind": "exists",
      "test": "Request.prototype.targetAddressSpace",
      "specSection": "https://wicg.github.io/private-network-access/#request-target-address-space"
    },
    {
      "id": "request-target-address-space-init",
      "description": "Request constructor accepts and reflects the targetAddressSpace option.",
      "kind": "script",
      "test": "(()=>{try{const r=new Request(location.href,{targetAddressSpace:'local'});return !('targetAddressSpace' in r)||r.targetAddressSpace==='local';}catch(e){return true;}})()",
      "specSection": "https://wicg.github.io/private-network-access/#request-target-address-space"
    },
    {
      "id": "request-target-address-space-default",
      "description": "A Request without a specified targetAddressSpace reflects null or undefined.",
      "kind": "script",
      "test": "(()=>{try{const r=new Request(location.href);return !('targetAddressSpace' in r)||typeof r.targetAddressSpace==='string';}catch(e){return true;}})()",
      "specSection": "https://wicg.github.io/private-network-access/#request-target-address-space"
    },
    {
      "id": "request-target-address-space-invalid",
      "description": "Setting an invalid targetAddressSpace in RequestInit throws a TypeError.",
      "kind": "script",
      "test": "(() => { try { new Request('http://localhost', { targetAddressSpace: 'invalid-space' }); return false; } catch (e) { return e.name === 'TypeError'; } })()",
      "specSection": "https://wicg.github.io/private-network-access/#request-target-address-space"
    },
    {
      "id": "permissions-api-query-local-network",
      "description": "navigator.permissions.query({name:'local-network'}) is queryable to probe LNA permissions.",
      "kind": "script",
      "test": "(async () => { try { const r = await navigator.permissions.query({ name: 'local-network' }); return r && ['granted', 'denied', 'prompt'].includes(r.state); } catch (e) { return false; } })()",
      "specSection": "https://wicg.github.io/private-network-access/#permissions"
    },
    {
      "id": "secure-context-required",
      "description": "Local Network Access restrictions require secure contexts.",
      "kind": "script",
      "test": "self.isSecureContext === true",
      "specSection": "https://wicg.github.io/private-network-access/#secure-contexts"
    }
