      "description": "navigator.permissions is exposed so userland can probe local-network permissions.",
      "kind": "script",
      "test": "(()=>{return !!(navigator.permissions && typeof navigator.permissions.query==='function');})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
