    {
      "id": "permissions-query-local-network",
      "description": "navigator.permissions.query({name:'local-network'}) resolves to a PermissionStatus rather than rejecting.",
      "kind": "script",
      "test": "(async()=>{try{const r=await navigator.permissions.query({name:'local-network'});return r&&['granted','denied','prompt'].includes(r.state);}catch(e){return false;}})()"
    },
