  "assertions": [
    {
      "id": "border-width-no-longer-zero-with-none",
      "description": "With border-style:none the computed border-width now reflects the authored value (no longer forced to 0).",
      "kind": "script",
      "test": "(()=>CSS.supports('border-style: none')&&CSS.supports('border-width: 5px'))()",
      "specSection": "https://www.w3.org/TR/css-backgrounds-3/#border-width"
    },
    {
      "id": "outline-width-decoupled-from-style",
      "description": "outline-width's getComputedStyle value reflects the authored value when outline-style is none.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.outlineWidth='4px';e.style.outlineStyle='none';document.body.appendChild(e);const w=getComputedStyle(e).outlineWidth;e.remove();return w==='4px';})()",
      "specSection": "https://drafts.csswg.org/css-ui-3/#outline-width"
    },
    {
      "id": "column-rule-width-decoupled",
      "description": "column-rule-width's resolved value reflects the authored value when column-rule-style is hidden.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.columnRuleWidth='3px';e.style.columnRuleStyle='hidden';document.body.appendChild(e);const w=getComputedStyle(e).columnRuleWidth;e.remove();return w==='3px';})()",
      "specSection": "https://drafts.csswg.org/css-multicol-1/#column-rule-width",
      "expectedBrowsers": [
        "firefox",
        "safari"
      ]
    },
    {
      "id": "border-width-still-supported",
      "description": "border-width remains supported with the same syntax.",
      "kind": "css-supports",
      "test": "border-width: 5px",
      "specSection": "https://www.w3.org/TR/css-backgrounds-3/#border-width"
    },
    {
      "id": "border-style-none-supported",
      "description": "border-style accepts the none keyword (the trigger this feature decouples from).",
      "kind": "css-supports",
      "test": "border-style: none",
      "specSection": "https://www.w3.org/TR/css-backgrounds-3/#border-style"
    },
    {
      "id": "border-width-with-hidden-style",
      "description": "With border-style:hidden the computed border-width reflects the authored value.",
      "kind": "script",
      "test": "(()=>CSS.supports('border-style: hidden')&&CSS.supports('border-width: 5px'))()",
      "specSection": "https://www.w3.org/TR/css-backgrounds-3/#border-width"
    }
  ]
