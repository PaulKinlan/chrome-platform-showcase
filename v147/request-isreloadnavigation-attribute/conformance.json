  "assertions": [
    {
      "id": "request-constructor-exists",
      "description": "Request is exposed as a global constructor (the interface that gained the attribute).",
      "kind": "exists",
      "test": "window.Request",
      "specSection": "https://fetch.spec.whatwg.org/#request-class"
    },
    {
      "id": "is-reload-navigation-on-prototype",
      "description": "Request.prototype exposes an isReloadNavigation accessor.",
      "kind": "script",
      "test": "Object.getOwnPropertyNames(Request.prototype).includes('isReloadNavigation') || 'isReloadNavigation' in Request.prototype",
      "specSection": "https://fetch.spec.whatwg.org/#dom-request-isreloadnavigation"
    },
    {
      "id": "is-reload-navigation-default-false",
      "description": "On a manually constructed Request, isReloadNavigation defaults to false.",
      "kind": "script",
      "test": "new Request('https://example.com/').isReloadNavigation === false",
      "specSection": "https://fetch.spec.whatwg.org/#dom-request-isreloadnavigation"
    },
    {
      "id": "is-reload-navigation-is-boolean",
      "description": "The attribute returns a boolean value (typeof === 'boolean').",
      "kind": "script",
      "test": "typeof new Request('https://example.com/').isReloadNavigation === 'boolean'",
      "specSection": "https://fetch.spec.whatwg.org/#dom-request-isreloadnavigation"
    },
    {
      "id": "is-history-navigation-still-present",
      "description": "Sister attribute isHistoryNavigation is still present (the pair is co-defined).",
      "kind": "script",
      "test": "'isHistoryNavigation' in Request.prototype",
      "specSection": "https://fetch.spec.whatwg.org/#dom-request-ishistorynavigation"
    },
    {
      "id": "fetch-event-prototype-exposes-request",
      "description": "Service-worker FetchEvent exposes a 'request' property — where isReloadNavigation is consumed.",
      "kind": "script",
      "test": "self.FetchEvent ? 'request' in FetchEvent.prototype : true",
      "specSection": "https://www.w3.org/TR/service-workers/#fetchevent-interface"
    }
  ]
