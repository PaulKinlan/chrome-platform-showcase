    {
      "id": "option-rich-markup-is-retained-in-dom",
      "description": "Rich child markup inside option remains in the DOM for customizable select listbox rendering.",
      "kind": "script",
      "test": "(()=>{const o=document.createElement('option');const span=document.createElement('span');span.textContent='swatch';o.append('Emerald ',span);return !!o.querySelector('span')&&o.textContent.includes('Emerald');})()",
