      "id": "select-element-exists",
      "description": "HTMLSelectElement is exposed — the foundation customizable listbox extends.",
      "kind": "exists",
      "test": "HTMLSelectElement",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "select-multiple-supported",
      "description": "The HTML multiple attribute on <select> is reflected as a property, the opt-in for multi-select listbox rendering.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('select');e.multiple=true;return e.multiple===true;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "select-size-supported",
      "description": "The HTML size attribute on <select> is reflected as a number property, the other opt-in to listbox rendering.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('select');e.size=4;return e.size===4;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "appearance-base-select-supported",
      "description": "appearance: base-select is supported in CSS — the toggle that activates the customizable listbox UI.",
      "kind": "css-supports",
      "test": "appearance: base-select",
      "specSection": "https://open-ui.org/components/customizableselect/"
    },
    {
      "id": "option-element-exists",
      "description": "HTMLOptionElement is exposed — listbox renders its options through this interface.",
      "kind": "exists",
      "test": "HTMLOptionElement",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "option-selected-roundtrip",
      "description": "Setting selected on an option round-trips — the basic state mechanic listbox depends on for selection rendering.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');s.multiple=true;const o=document.createElement('option');o.value='a';o.selected=true;s.appendChild(o);return s.selectedOptions.length===1;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
