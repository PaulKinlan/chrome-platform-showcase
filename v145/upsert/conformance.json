      "kind": "typeof",
      "test": "Map.prototype.getOrInsertComputed",
      "expect": "function",
      "specSection": "https://github.com/tc39/proposal-upsert"
    },
    {
      "id": "map-get-or-insert-inserts-on-miss",
      "description": "getOrInsert on a missing key returns the inserted value and writes it to the Map.",
      "kind": "script",
      "test": "(()=>{const m=new Map();const v=m.getOrInsert('a',1);return v===1&&m.get('a')===1&&m.size===1;})()",
      "specSection": "https://github.com/tc39/proposal-upsert"
    },
    {
      "id": "map-get-or-insert-preserves-on-hit",
      "description": "getOrInsert on an existing key returns the existing value, not the supplied one.",
      "kind": "script",
      "test": "(()=>{const m=new Map([['a',7]]);const v=m.getOrInsert('a',99);return v===7&&m.get('a')===7;})()",
      "specSection": "https://github.com/tc39/proposal-upsert"
    },
    {
      "id": "map-get-or-insert-computed-only-on-miss",
      "description": "getOrInsertComputed only invokes its callback for missing keys.",
      "kind": "script",
      "test": "(()=>{let n=0;const m=new Map([['a',7]]);const v1=m.getOrInsertComputed('a',()=>{n++;return 99;});const v2=m.getOrInsertComputed('b',()=>{n++;return 42;});return v1===7&&v2===42&&n===1;})()",
      "specSection": "https://github.com/tc39/proposal-upsert"
    },
