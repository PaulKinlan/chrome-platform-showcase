  "assertions": [
    {
      "id": "focus-options-dictionary-accepted",
      "description": "HTMLElement.prototype.focus accepts a FocusOptions dictionary — the surface that gains focusVisible.",
      "kind": "script",
      "test": "(()=>{try{const b=document.createElement('button');document.body.appendChild(b);b.focus({});b.remove();return true;}catch(e){return false;}})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "focus-visible-true-roundtrip",
      "description": "After focus({focusVisible:true}), the focused element matches :focus-visible.",
      "kind": "script",
      "test": "(()=>{try{const b=document.createElement('button');document.body.appendChild(b);b.focus({focusVisible:true});const ok=b.matches(':focus-visible');b.blur();b.remove();return ok;}catch(e){return false;}})()",
      "specSection": "https://html.spec.whatwg.org/#dom-focusoptions-focusvisible"
    },
    {
      "id": "focus-visible-false-roundtrip",
      "description": "After focus({focusVisible:false}), the focused element does not match :focus-visible.",
      "kind": "script",
      "test": "(()=>{try{const b=document.createElement('button');document.body.appendChild(b);b.focus({focusVisible:false});const fv=b.matches(':focus-visible');b.blur();b.remove();return fv===false;}catch(e){return false;}})()",
      "specSection": "https://html.spec.whatwg.org/#dom-focusoptions-focusvisible"
    },
    {
      "id": "svg-element-focus-is-function",
      "description": "SVGElement.prototype.focus is a function — the focusVisible option is added at the HTML/SVG element level.",
      "kind": "typeof",
      "test": "SVGElement.prototype.focus",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "focus-visible-pseudo-supported",
      "description": "CSS supports the :focus-visible pseudo-class via the selector() function, the target state focusVisible toggles.",
      "kind": "css-supports",
      "test": "selector(:focus-visible)",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
