    {
      "id": "focus-accepts-focus-visible-true",
      "description": "Calling focus({ focusVisible: true }) on a focusable element does not throw — the option is recognised.",
      "kind": "script",
      "test": "(()=>{try{const b=document.createElement('button');document.body.appendChild(b);b.focus({focusVisible:true});const ok=document.activeElement===b;b.blur();b.remove();return ok;}catch(e){return false;}})()",
      "specSection": "https://html.spec.whatwg.org/#dom-focusoptions-focusvisible"
    },
    {
      "id": "focus-accepts-focus-visible-false",
      "description": "Calling focus({ focusVisible: false }) does not throw, and the focus ring should not be painted.",
      "kind": "script",
      "test": "(()=>{try{const b=document.createElement('button');document.body.appendChild(b);b.focus({focusVisible:false});const ok=document.activeElement===b;b.blur();b.remove();return ok;}catch(e){return false;}})()",
      "specSection": "https://html.spec.whatwg.org/#dom-focusoptions-focusvisible"
    },
    {
      "id": "focus-options-prevent-scroll-still-supported",
      "description": "The pre-existing preventScroll FocusOptions member still works — focusVisible is an additive option.",
      "kind": "script",
      "test": "(()=>{try{const b=document.createElement('button');document.body.appendChild(b);b.focus({preventScroll:true});const ok=document.activeElement===b;b.remove();return ok;}catch(e){return false;}})()",
