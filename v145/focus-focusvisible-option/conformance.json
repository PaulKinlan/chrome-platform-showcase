    {
      "id": "focus-visible-pseudo-class-supported",
      "description": "The :focus-visible pseudo-class is supported in CSS selectors — focusVisible:true makes the focused element match this.",
      "kind": "script",
      "test": "(()=>{try{document.querySelector(':focus-visible');return true;}catch(e){return false;}})()",
      "specSection": "https://drafts.csswg.org/selectors-4/#the-focus-visible-pseudo",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
