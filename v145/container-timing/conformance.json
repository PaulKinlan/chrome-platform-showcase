      "kind": "exists",
      "test": "PerformanceObserver",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "container-entry-type-supported",
      "description": "PerformanceObserver.supportedEntryTypes is the feature-detection list that will contain 'container' when Container Timing is exposed.",
      "kind": "script",
      "test": "Array.isArray(PerformanceObserver.supportedEntryTypes)",
      "specSection": "https://wicg.github.io/container-timing/#sec-performance-container-timing"
    },
    {
      "id": "performance-container-timing-interface",
      "description": "PerformanceContainerTiming is exposed when the 'container' entry type is advertised.",
      "kind": "script",
      "test": "PerformanceObserver.supportedEntryTypes.includes('container')?typeof PerformanceContainerTiming==='function':typeof PerformanceContainerTiming==='undefined'",
      "specSection": "https://wicg.github.io/container-timing/#sec-performance-container-timing"
    },
    {
      "id": "container-timing-name-attribute",
      "description": "PerformanceContainerTiming.prototype exposes the name attribute when the interface is present.",
      "kind": "script",
      "test": "(()=>{if(typeof PerformanceContainerTiming==='undefined')return !PerformanceObserver.supportedEntryTypes.includes('container');return 'name' in PerformanceContainerTiming.prototype;})()",
      "specSection": "https://wicg.github.io/container-timing/"
    },
    {
      "id": "container-timing-identifier-attribute",
      "description": "PerformanceContainerTiming.prototype exposes the identifier attribute when the interface is present.",
      "kind": "script",
      "test": "(()=>{if(typeof PerformanceContainerTiming==='undefined')return !PerformanceObserver.supportedEntryTypes.includes('container');return 'identifier' in PerformanceContainerTiming.prototype;})()",
      "specSection": "https://wicg.github.io/container-timing/"
    },
    {
      "id": "observer-can-subscribe-container",
      "description": "PerformanceObserver.observe accepts type: 'container' without throwing — Chrome 145 ships the observer registration path.",
      "kind": "script",
      "test": "(()=>{try{const o=new PerformanceObserver(()=>{});o.observe({type:'container',buffered:true});o.disconnect();return true;}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/container-timing/"
    }
  ]
