{
  "release": "v146",
  "featureSlug": "data-url-mime-type-parameter-preservation",
  "chromestatusId": 4874471565557760,
  "specUrl": "https://fetch.spec.whatwg.org/#data-url-processor",
  "generatedAt": "2026-06-06T15:28:01Z",
  "author": "codex-devtools-mcp",
  "assertions": [
    {
      "id": "fetch-data-url-preserves-charset-param",
      "description": "Fetching a data: URL with a charset parameter exposes that parameter on the response's Content-Type header.",
      "kind": "script",
      "test": "(async()=>{const r=await fetch('data:text/plain;charset=utf-8,hello');return /charset=utf-?8/i.test(r.headers.get('Content-Type')||'');})()"
    },
    {
      "id": "fetch-data-url-preserves-custom-param",
      "description": "Non-charset MIME parameters (e.g. boundary, profile) on a data: URL are preserved on the response Content-Type rather than dropped.",
      "kind": "script",
      "test": "(async()=>{const r=await fetch('data:text/plain;boundary=xyz,hi');return /boundary=xyz/i.test(r.headers.get('Content-Type')||'');})()"
    },
    {
      "id": "fetch-data-url-preserves-multiple-params",
      "description": "Multiple MIME parameters on a single data: URL are all preserved after MIME serialization.",
      "kind": "script",
      "test": "(async()=>{const r=await fetch('data:text/plain;charset=utf-8;foo=bar,hi');const ct=r.headers.get('Content-Type')||'';const params=Object.fromEntries(ct.split(';').slice(1).map(p=>p.split('=').map(s=>s.trim().toLowerCase())));return params.charset==='utf-8'&&params.foo==='bar';})()"
    },
    {
      "id": "fetch-data-url-default-mime-still-text-plain",
      "description": "A data: URL without an explicit MIME type still defaults to text/plain;charset=US-ASCII per the Fetch spec.",
      "kind": "script",
      "test": "(async()=>{const r=await fetch('data:,hi');const ct=r.headers.get('Content-Type')||'';return /^text\\/plain/i.test(ct);})()",
      "specSection": "https://fetch.spec.whatwg.org/#data-url-processor"
    },
    {
      "id": "fetch-data-url-base64-payload-decoded",
      "description": "A base64-encoded data: URL with a MIME parameter still decodes its payload correctly while preserving the parameter.",
      "kind": "script",
      "test": "(async()=>{const r=await fetch('data:text/plain;charset=utf-8;base64,aGVsbG8=');const t=await r.text();const ct=r.headers.get('Content-Type')||'';return t==='hello'&&/charset=utf-?8/i.test(ct);})()"
    },
    {
      "id": "fetch-data-url-preserves-profile-param",
      "description": "A profile parameter on an application/calendar+xml data: URL is preserved, not reduced to a bare MIME essence.",
      "kind": "script",
      "test": "(async()=>{const r=await fetch('data:application/calendar+xml;profile=urn:ietf:params:xml:ns:icalendar-2.0;charset=utf-8,BEGIN:VCALENDAR');const ct=r.headers.get('Content-Type')||'';return /^application\\/calendar\\+xml/i.test(ct)&&/profile=urn:ietf:params:xml:ns:icalendar-2.0/i.test(ct)&&/charset=utf-?8/i.test(ct);})()"
    },
    {
      "id": "fetch-data-url-preserves-encoded-param-value",
      "description": "Percent-encoded delimiter characters inside parameter values remain part of the serialized MIME parameter value.",
      "kind": "script",
      "test": "(async()=>{const r=await fetch('data:text/plain;name=alpha%3Bbeta;charset=utf-8,hello');const ct=r.headers.get('Content-Type')||'';return /name=alpha%3Bbeta/i.test(ct)&&/charset=utf-?8/i.test(ct);})()"
    },
    {
      "id": "fetch-data-url-preserves-iso-8859-1-charset",
      "description": "An ISO-8859-1 charset parameter on a text/csv data: URL is preserved alongside other MIME parameters.",
      "kind": "script",
      "test": "(async()=>{const r=await fetch('data:text/csv;charset=iso-8859-1;header=present;base64,bmFtZSxjaXR5Ckpvc+ksTeFsYWdh');const ct=r.headers.get('Content-Type')||'';return /^text\\/csv/i.test(ct)&&/charset=iso-8859-1/i.test(ct)&&/header=present/i.test(ct);})()"
    }
  ]
}
