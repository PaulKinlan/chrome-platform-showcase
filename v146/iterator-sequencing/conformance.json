  "release": "v146",
  "featureSlug": "iterator-sequencing",
  "chromestatusId": 5193275975794688,
  "specUrl": "https://tc39.es/proposal-iterator-sequencing/",
  "generatedAt": "2026-06-01T08:00:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "iterator-concat-exists",
      "description": "Iterator.concat is exposed as a static method on the global Iterator constructor.",
      "kind": "typeof",
      "test": "Iterator.concat",
      "expect": "function"
    },
    {
      "id": "iterator-concat-empty-arglist",
      "description": "Iterator.concat() with no arguments returns an iterator that yields nothing.",
      "kind": "script",
      "test": "(()=>{const it=Iterator.concat();return it.next().done===true;})()"
    },
    {
      "id": "iterator-concat-two-arrays-in-order",
      "description": "Iterator.concat([1,2],[3]) yields 1,2,3 in order.",
      "kind": "script",
      "test": "(()=>{const arr=[...Iterator.concat([1,2],[3])];return arr.length===3&&arr[0]===1&&arr[1]===2&&arr[2]===3;})()"
    },
    {
      "id": "iterator-concat-mixes-iterators",
      "description": "Iterator.concat accepts iterator helpers and arrays interchangeably.",
      "kind": "script",
      "test": "(()=>{function* g(){yield 'a';yield 'b';}const arr=[...Iterator.concat(g(),['c'])];return arr.join('')==='abc';})()"
    },
    {
      "id": "iterator-concat-rejects-non-iterables",
      "description": "Iterator.concat throws a TypeError when an argument is not iterable.",
      "kind": "throws",
      "test": "[...Iterator.concat(42)]"
    },
    {
      "id": "iterator-concat-returns-iterator-helper",
      "description": "The value returned from Iterator.concat has Iterator.prototype on its chain (so chaining .map/.filter works).",
      "kind": "script",
      "test": "(()=>{const it=Iterator.concat([1],[2]);return typeof it.map==='function' && typeof it.next==='function';})()"
    }
  ]
}
