      "description": "Setting trigger-scope through CSSOM is reflected in getComputedStyle.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.setProperty('trigger-scope','none');document.body.appendChild(e);const v=getComputedStyle(e).getPropertyValue('trigger-scope');e.remove();return /none/.test(v);})()"
