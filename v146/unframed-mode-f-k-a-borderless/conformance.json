{
  "release": "v146",
  "featureSlug": "unframed-mode-f-k-a-borderless",
  "chromestatusId": 5551475195904000,
  "specUrl": "https://wicg.github.io/manifest-incubations/index.html#dfn-unframed",
  "generatedAt": "2026-06-01T08:00:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "display-mode-media-query-parseable",
      "description": "The (display-mode: unframed) media query parses without error in CSS.",
      "kind": "script",
      "test": "(()=>{try{matchMedia('(display-mode: unframed)');return true;}catch(e){return false;}})()"
    },
    {
      "id": "display-mode-unframed-matches-or-not",
      "description": "matchMedia('(display-mode: unframed)') returns a MediaQueryList whose 'matches' is boolean (true only inside an unframed PWA window).",
      "kind": "script",
      "test": "typeof matchMedia('(display-mode: unframed)').matches === 'boolean'"
    },
    {
      "id": "display-mode-standalone-still-supported",
      "description": "Existing display modes (standalone) keep working — unframed supplements rather than replaces them.",
      "kind": "script",
      "test": "typeof matchMedia('(display-mode: standalone)').matches === 'boolean'",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "display-mode-fullscreen-still-supported",
      "description": "(display-mode: fullscreen) still resolves to a MediaQueryList.",
      "kind": "script",
      "test": "matchMedia('(display-mode: fullscreen)') instanceof MediaQueryList",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "no-globally-exposed-borderless-flag",
      "description": "There is no script-exposed window.borderless / navigator.unframed boolean — pages must use the display-mode media query.",
      "kind": "script",
      "test": "typeof window.unframed === 'undefined' && typeof navigator.unframed === 'undefined'"
    }
  ]
}
