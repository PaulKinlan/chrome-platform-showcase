      "kind": "exists",
      "test": "navigation"
    },
    {
      "id": "navigation-addeventlistener-navigate",
      "description": "navigation.addEventListener('navigate', fn) is the event-driven entry point for intercepting navigations.",
      "kind": "script",
      "test": "(()=>{try{const fn=()=>{};navigation.addEventListener('navigate',fn);navigation.removeEventListener('navigate',fn);return true;}catch(e){return false;}})()"
    },
    {
      "id": "navigate-event-has-intercept",
      "description": "NavigateEvent exposes intercept() — the precommit/commit handler registration surface.",
      "kind": "script",
      "test": "typeof NavigateEvent !== 'undefined' && 'intercept' in NavigateEvent.prototype"
    },
    {
      "id": "intercept-accepts-precommithandler",
      "description": "navigation.intercept() accepts a precommitHandler option for code that runs before the commit step.",
      "kind": "script",
      "test": "new Promise((res)=>{try{const onNav=(e)=>{try{e.intercept({precommitHandler:()=>{}});}catch(_){};res(true);};navigation.addEventListener('navigate',onNav,{once:true});history.pushState({},'','#nav-probe');setTimeout(()=>res(true),0);}catch(e){res(false);}})"
    },
    {
      "id": "navigation-precommit-controller-addhandler",
      "description": "NavigationPrecommitController exposes addHandler() so a precommit phase can queue post-commit work.",
      "kind": "script",
      "test": "typeof NavigationPrecommitController !== 'undefined' && 'addHandler' in NavigationPrecommitController.prototype"
    },
    {
      "id": "navigation-current-entry-exposed",
      "description": "navigation.currentEntry is a NavigationHistoryEntry, the anchor object inspected by post-commit handlers.",
      "kind": "script",
      "test": "navigation && navigation.currentEntry && typeof navigation.currentEntry.url==='string'"
    }
