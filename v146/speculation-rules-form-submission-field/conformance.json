  "generatedAt": "2026-06-01T08:00:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "speculationrules-script-type-recognised",
      "description": "<script type=\"speculationrules\"> elements parse without throwing — the host of the new form_submission field.",
      "kind": "script",
      "test": "(()=>{try{const s=document.createElement('script');s.type='speculationrules';s.textContent=JSON.stringify({prefetch:[{urls:['/']}]});document.head.appendChild(s);const ok=s.type==='speculationrules';s.remove();return ok;}catch(e){return false;}})()"
    },
    {
      "id": "speculationrules-form-submission-true-parses",
      "description": "A speculation rule that sets form_submission:true is accepted by the parser (no exception thrown when inserting the script).",
      "kind": "script",
      "test": "(()=>{try{const s=document.createElement('script');s.type='speculationrules';s.textContent=JSON.stringify({prerender:[{urls:['/_fs_target'],form_submission:true}]});document.head.appendChild(s);s.remove();return true;}catch(e){return false;}})()"
    },
    {
      "id": "speculationrules-form-submission-false-parses",
      "description": "form_submission:false is also accepted — the field is boolean.",
      "kind": "script",
      "test": "(()=>{try{const s=document.createElement('script');s.type='speculationrules';s.textContent=JSON.stringify({prerender:[{urls:['/_fs_target'],form_submission:false}]});document.head.appendChild(s);s.remove();return true;}catch(e){return false;}})()"
    },
    {
      "id": "speculationrules-form-submission-non-boolean-warned-not-thrown",
      "description": "A non-boolean form_submission value does not throw — the spec says the UA may warn but must still parse the surrounding rules.",
      "kind": "script",
      "test": "(()=>{try{const s=document.createElement('script');s.type='speculationrules';s.textContent=JSON.stringify({prerender:[{urls:['/_fs_target'],form_submission:'maybe'}]});document.head.appendChild(s);s.remove();return true;}catch(e){return false;}})()"
    },
    {
      "id": "document-prerendering-reflects-prerender-state",
      "description": "document.prerendering remains the readable signal for documents activated by a speculation rule.",
      "kind": "script",
      "test": "typeof document.prerendering === 'boolean'"
    }
  ]
}
