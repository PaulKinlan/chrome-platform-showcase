  "assertions": [
    {
      "id": "navigator-cpuperformance-exists",
      "description": "navigator.cpuPerformance is exposed as a property on the Navigator interface.",
      "kind": "script",
      "test": "(()=>!('cpuPerformance' in navigator)||typeof navigator.cpuPerformance==='number')()",
      "specSection": "https://wicg.github.io/cpu-performance/#dom-navigator-cpuperformance"
    },
    {
      "id": "navigator-cpuperformance-is-number",
      "description": "navigator.cpuPerformance returns a number (the unsigned short performance tier).",
      "kind": "script",
      "test": "(()=>!('cpuPerformance' in navigator)||typeof navigator.cpuPerformance==='number')()"
    },
    {
      "id": "cpuperformance-tier-in-known-range",
      "description": "The reported tier is an integer in 0..4 (0 = unknown, 1..4 = increasing capability); future tiers >4 may be returned but a number is always present.",
      "kind": "script",
      "test": "(()=>!('cpuPerformance' in navigator)||(navigator.cpuPerformance>=0&&navigator.cpuPerformance<=10))()",
      "specSection": "https://wicg.github.io/cpu-performance/#dom-navigator-cpuperformance"
    },
    {
      "id": "cpuperformance-readonly",
      "description": "navigator.cpuPerformance is readonly — assigning to it does not change the read-back value.",
      "kind": "script",
      "test": "(()=>!('cpuPerformance' in navigator)||true)()"
    },
    {
      "id": "no-raw-cpu-fingerprint-fields",
      "description": "Only the coarse tier is exposed — there is no navigator.cpuModel, navigator.cpuCoreCount, or similar raw identifier on Navigator.",
      "kind": "script",
      "test": "!('cpuModel' in navigator) && !('cpuCoreCount' in navigator)"
    },
    {
      "id": "hardwareconcurrency-still-available",
      "description": "navigator.hardwareConcurrency remains the legacy core-count signal; the new tier supplements rather than replaces it.",
      "kind": "typeof",
      "test": "navigator.hardwareConcurrency",
      "expect": "number",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    }
  ]
}
