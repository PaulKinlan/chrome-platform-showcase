{
  "release": "v146",
  "featureSlug": "focusgroup",
  "chromestatusId": 5637601087193088,
  "specUrl": "https://html.spec.whatwg.org/multipage/interaction.html#focusgroup",
  "generatedAt": "2026-06-01T08:00:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "focusgroup-attribute-reflected",
      "description": "Setting the focusgroup attribute on an element reflects through the IDL focusGroup property (DOMTokenList-style).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('focusgroup','wrap');return e.getAttribute('focusgroup')==='wrap';})()"
    },
    {
      "id": "focusgroup-accepts-wrap-token",
      "description": "The 'wrap' token is accepted in the focusgroup attribute value.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('ul');e.setAttribute('focusgroup','wrap');return e.getAttribute('focusgroup').split(/\\s+/).includes('wrap');})()"
    },
    {
      "id": "focusgroup-accepts-inline-token",
      "description": "The 'inline' axis token restricts arrow-key navigation to the inline axis.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('ul');e.setAttribute('focusgroup','inline');return e.getAttribute('focusgroup')==='inline';})()"
    },
    {
      "id": "focusgroup-accepts-block-token",
      "description": "The 'block' axis token restricts arrow-key navigation to the block axis.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('ul');e.setAttribute('focusgroup','block');return e.getAttribute('focusgroup')==='block';})()"
    },
    {
      "id": "focusgroup-inline-block-combined",
      "description": "Both axis tokens may co-exist; the attribute is multi-valued.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('ul');e.setAttribute('focusgroup','inline block wrap');const v=e.getAttribute('focusgroup').split(/\\s+/);return v.includes('inline')&&v.includes('block')&&v.includes('wrap');})()"
    },
    {
      "id": "focusgroup-empty-string-allowed",
      "description": "focusgroup=\"\" (empty value) is the canonical \"on with defaults\" form and is preserved as the empty string.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('focusgroup','');return e.getAttribute('focusgroup')==='';})()"
    }
  ]
}
