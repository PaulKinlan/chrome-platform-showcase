{
  "release": "v146",
  "featureSlug": "focusgroup",
  "chromestatusId": 5637601087193088,
  "specUrl": "https://html.spec.whatwg.org/multipage/interaction.html#focusgroup",
  "generatedAt": "2026-06-06T15:48:54Z",
  "author": "codex-focusgroup-goal-setting",
  "assertions": [
    {
      "id": "focusgroup-idl-object",
      "description": "Elements expose the current focusGroup IDL object when native focusgroup is implemented.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');return 'focusGroup' in e && typeof e.focusGroup==='object';})()"
    },
    {
      "id": "focusgroup-toolbar-behavior-token",
      "description": "The toolbar behavior token can be used as the required focusgroup behavior.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('focusgroup','toolbar');return e.getAttribute('focusgroup')==='toolbar';})()"
    },
    {
      "id": "focusgroup-radiogroup-block-wrap",
      "description": "A radiogroup can declare block-axis focus movement with wrapping using behavior plus modifier tokens.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('focusgroup','radiogroup block wrap');const v=e.getAttribute('focusgroup').split(/\\s+/);return v.includes('radiogroup')&&v.includes('block')&&v.includes('wrap');})()"
    },
    {
      "id": "focusgroup-inline-block-modifiers",
      "description": "Inline and block axis modifiers are expressed alongside a behavior token in the current syntax.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('focusgroup','listbox block inline wrap');const v=e.getAttribute('focusgroup').split(/\\s+/);return v.includes('listbox')&&v.includes('inline')&&v.includes('block')&&v.includes('wrap');})()"
    },
    {
      "id": "focusgroup-nomemory-token",
      "description": "The current no-memory modifier spelling is the single token nomemory.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('focusgroup','toolbar nomemory');return e.getAttribute('focusgroup').split(/\\s+/).includes('nomemory');})()"
    },
    {
      "id": "focusgroup-nowrap-token",
      "description": "The nowrap modifier can be combined with a behavior token to disable wrapping.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('focusgroup','menu nowrap');return e.getAttribute('focusgroup').split(/\\s+/).includes('nowrap');})()"
    }
  ]
}
