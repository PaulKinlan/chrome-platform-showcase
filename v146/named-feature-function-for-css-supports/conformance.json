      "description": "A @supports rule using named-feature() applies styles only when the condition is true, matching standard @supports semantics.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('style');s.textContent='@supports named-feature(definitely-not-real){body{--nf-probe:1}}';document.head.appendChild(s);const v=getComputedStyle(document.body).getPropertyValue('--nf-probe');s.remove();return v.trim()==='';})()"
