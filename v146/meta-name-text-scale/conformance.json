{
  "release": "v146",
  "featureSlug": "meta-name-text-scale",
  "chromestatusId": 5112244702674944,
  "specUrl": "https://drafts.csswg.org/css-fonts-5/#text-scale-meta",
  "generatedAt": "2026-06-01T08:00:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "meta-text-scale-element-creatable",
      "description": "A meta element with name=\"text-scale\" can be created and inserted into the head.",
      "kind": "script",
      "test": "(()=>{const m=document.createElement('meta');m.name='text-scale';m.content='scale';document.head.appendChild(m);const ok=m.name==='text-scale'&&m.content==='scale';m.remove();return ok;})()"
    },
    {
      "id": "env-preferred-text-scale-supported",
      "description": "The preferred-text-scale environment variable is parseable by CSS — `env(preferred-text-scale)` is accepted.",
      "kind": "css-supports",
      "test": "font-size: calc(1rem * env(preferred-text-scale, 1))",
      "specSection": "https://drafts.csswg.org/css-fonts-5/#preferred-text-scale-env"
    },
    {
      "id": "rem-still-defined-relative-to-root",
      "description": "1rem still resolves to the root element's computed font-size — the meta tag changes how the user agent picks `medium`, not how rem is defined.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.fontSize='1rem';document.body.appendChild(e);const a=parseFloat(getComputedStyle(e).fontSize);const b=parseFloat(getComputedStyle(document.documentElement).fontSize);e.remove();return Math.abs(a-b)<0.01;})()"
    },
    {
      "id": "no-css-property-named-text-scale",
      "description": "There is no CSS property named text-scale — the feature is exposed via meta and env() only.",
      "kind": "script",
      "test": "!CSS.supports('text-scale: 1.5')",
      "specSection": "https://drafts.csswg.org/css-fonts-5/#text-scale-meta"
    },
    {
      "id": "meta-name-attribute-case-insensitive",
      "description": "The meta name attribute is case-insensitive — Text-Scale and text-scale identify the same directive.",
      "kind": "script",
      "test": "(()=>{const m=document.createElement('meta');m.setAttribute('name','Text-Scale');return m.name.toLowerCase()==='text-scale';})()"
    }
  ]
}
