  "generatedAt": "2026-06-01T08:00:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "document-modelcontext-exposed",
      "description": "document.modelContext is the entry point — the spec places WebMCP on Document, not Navigator.",
      "kind": "script",
      "test": "(()=>!('modelContext' in document)||!!document.modelContext)()"
    },
    {
      "id": "no-navigator-mcp-shim",
      "description": "navigator.mcp must NOT be exposed — implementations should not ship a parallel surface.",
      "kind": "script",
      "test": "typeof navigator.mcp === 'undefined'"
    },
    {
      "id": "modelcontext-registertool-function",
      "description": "modelContext.registerTool is a function — the primary registration entry point.",
      "kind": "script",
      "test": "(()=>!document.modelContext||typeof document.modelContext.registerTool==='function')()"
    },
    {
      "id": "modelcontext-ontoolchange-event-attribute",
      "description": "ModelContext exposes an ontoolchange event handler attribute.",
      "kind": "script",
      "test": "(()=>!document.modelContext||'ontoolchange' in document.modelContext)()"
    },
    {
      "id": "registertool-rejects-tool-without-name",
      "description": "registerTool throws (or rejects) when the tool definition lacks a required 'name' property.",
      "kind": "throws",
      "test": "document.modelContext.registerTool({description:'no-name',execute:()=>{}})"
    },
    {
      "id": "registertool-returns-or-resolves",
      "description": "Calling registerTool with a minimal valid tool descriptor does not throw synchronously.",
      "kind": "script",
      "test": "(()=>!document.modelContext||typeof document.modelContext.registerTool==='function')()"
    }
  ]
}
