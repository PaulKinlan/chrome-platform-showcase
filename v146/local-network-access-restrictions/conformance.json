  "assertions": [
    {
      "id": "permissions-api-available",
      "description": "navigator.permissions.query is the entry point used to surface the new local-network permission state.",
      "kind": "typeof",
      "test": "navigator.permissions.query",
      "expect": "function",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    },
    {
      "id": "permissions-query-local-network",
      "description": "navigator.permissions.query({name:'local-network'}) resolves to a PermissionStatus (granted | denied | prompt) rather than rejecting.",
      "kind": "script",
      "test": "(async()=>{try{const r=await navigator.permissions.query({name:'local-network'});return r&&['granted','denied','prompt'].includes(r.state);}catch(e){return false;}})()"
    },
    {
      "id": "request-targetaddressspace-attribute",
      "description": "Request exposes the targetAddressSpace IDL attribute used to opt into a local-network fetch.",
      "kind": "script",
      "test": "'targetAddressSpace' in Request.prototype || (()=>{try{return 'targetAddressSpace' in new Request('https://example.com');}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/local-network-access/#request"
    },
    {
      "id": "fetch-rejects-cross-private-network-without-opt-in",
      "description": "A fetch from a public document targeting a non-existent local address fails with a network error (rejecting the promise) once the restriction is in force.",
      "kind": "script",
      "test": "(async()=>{try{await fetch('http://127.0.0.1:1/_lna_probe',{mode:'no-cors'});return false;}catch(e){return e instanceof TypeError;}})()"
    },
    {
      "id": "permissions-policy-local-network-default-self",
      "description": "The 'local-network' Permissions Policy directive is recognised and has a default allowlist of 'self' (no cross-origin propagation by default).",
      "kind": "script",
      "test": "(()=>{try{const f=document.createElement('iframe');f.allow='local-network';return f.allow.includes('local-network');}catch(e){return false;}})()"
    },
    {
      "id": "no-legacy-corb-bypass-on-private-network",
      "description": "Documents do not expose a script-readable allow/deny toggle for the private-network restriction — the gate is enforced by the browser, not by page script.",
      "kind": "script",
      "test": "typeof window.localNetworkAccess === 'undefined' && typeof navigator.localNetworkAccess === 'undefined'"
    }
  ]
