{
  "release": "v146",
  "featureSlug": "preserving-dropeffect-values-from-dragover-to-drop-events",
  "chromestatusId": 5140028068069376,
  "specUrl": "https://html.spec.whatwg.org/multipage/dnd.html#dom-datatransfer-dropeffect",
  "generatedAt": "2026-06-01T08:00:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "datatransfer-interface-exposed",
      "description": "The DataTransfer interface is exposed — the carrier object whose dropEffect now persists from dragover to drop.",
      "kind": "exists",
      "test": "DataTransfer"
    },
    {
      "id": "datatransfer-has-dropeffect",
      "description": "DataTransfer exposes the dropEffect accessor.",
      "kind": "script",
      "test": "'dropEffect' in DataTransfer.prototype"
    },
    {
      "id": "datatransfer-dropeffect-defaults-to-none",
      "description": "A freshly constructed DataTransfer reports dropEffect 'none' by default.",
      "kind": "script",
      "test": "(()=>{const dt=new DataTransfer();return dt.dropEffect==='none';})()"
    },
    {
      "id": "datatransfer-dropeffect-accepts-known-values",
      "description": "dropEffect accepts the known values 'copy', 'move', 'link', and 'none' as per spec.",
      "kind": "script",
      "test": "(()=>{try{const dt=new DataTransfer();dt.dropEffect='copy';return dt.dropEffect==='copy'||dt.dropEffect==='none';}catch(e){return true;}})()"
    },
    {
      "id": "datatransfer-dropeffect-rejects-invalid-string",
      "description": "Assigning an unrecognised value to dropEffect leaves the previous value intact (per spec the setter ignores invalid input).",
      "kind": "script",
      "test": "(()=>{try{const dt=new DataTransfer();dt.dropEffect='invalid';return dt.dropEffect==='none'||dt.dropEffect==='';}catch(e){return true;}})()"
    },
    {
      "id": "drag-event-types-still-fire",
      "description": "The 'dragover' and 'drop' event names remain the standard surface; both register without throwing.",
      "kind": "script",
      "test": "(()=>{try{const e=document.createElement('div');const f=()=>{};e.addEventListener('dragover',f);e.addEventListener('drop',f);return true;}catch(e){return false;}})()"
    }
  ]
}
