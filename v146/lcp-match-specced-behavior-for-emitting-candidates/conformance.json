  "assertions": [
    {
      "id": "performance-observer-supports-largest-contentful-paint",
      "description": "PerformanceObserver advertises 'largest-contentful-paint' as a supported entry type.",
      "kind": "script",
      "test": "PerformanceObserver.supportedEntryTypes && PerformanceObserver.supportedEntryTypes.includes('largest-contentful-paint')"
    },
    {
      "id": "lcp-entry-has-rendertime",
      "description": "LargestContentfulPaint entries expose renderTime — the spec-aligned timestamp used to emit candidates.",
      "kind": "script",
      "test": "(()=>{try{return 'renderTime' in (window.LargestContentfulPaint?.prototype||{});}catch(e){return false;}})()"
    },
    {
      "id": "lcp-entry-has-loadtime",
      "description": "LargestContentfulPaint entries expose loadTime alongside renderTime.",
      "kind": "script",
      "test": "(()=>{try{return 'loadTime' in (window.LargestContentfulPaint?.prototype||{});}catch(e){return false;}})()"
    },
    {
      "id": "lcp-entry-has-size",
      "description": "LargestContentfulPaint entries expose size — used to determine candidate ordering.",
      "kind": "script",
      "test": "(()=>{try{return 'size' in (window.LargestContentfulPaint?.prototype||{});}catch(e){return false;}})()"
    },
    {
      "id": "lcp-entry-has-element",
      "description": "LargestContentfulPaint entries expose element so observers can introspect the painted node.",
      "kind": "script",
      "test": "(()=>{try{return 'element' in (window.LargestContentfulPaint?.prototype||{});}catch(e){return false;}})()"
    },
    {
      "id": "lcp-emits-at-least-one-entry-on-paint",
      "description": "Observing 'largest-contentful-paint' delivers at least one entry once the document paints content.",
      "kind": "script",
      "test": "new Promise((res)=>{try{new PerformanceObserver((list)=>{if(list.getEntries().length>0)res(true);}).observe({type:'largest-contentful-paint',buffered:true});setTimeout(()=>res(false),1500);}catch(e){res(false);}})"
    }
  ]
