      "id": "font-language-override-string-trk",
      "description": "font-language-override accepts an OpenType language tag for Turkish: \"TRK\".",
      "kind": "css-supports",
      "test": "font-language-override: \"TRK\"",
      "specSection": "https://www.w3.org/TR/css-fonts-4/#font-language-override-prop"
    },
    {
      "id": "font-language-override-computed-roundtrip",
      "description": "font-language-override round-trips through getComputedStyle.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('span');e.style.fontLanguageOverride='\"ENG\"';document.body.appendChild(e);const v=getComputedStyle(e).fontLanguageOverride;e.remove();return v.includes('ENG');})()",
      "specSection": "https://www.w3.org/TR/css-fonts-4/#font-language-override-prop"
    },
    {
      "id": "font-language-override-rejects-number",
      "description": "font-language-override rejects a bare number (must be `normal` or <string>).",
      "kind": "script",
      "test": "CSS.supports('font-language-override: 123')===false",
      "specSection": "https://www.w3.org/TR/css-fonts-4/#font-language-override-prop"
    },
    {
      "id": "font-language-override-inherits",
      "description": "font-language-override is inherited, so child elements pick up the parent's override.",
      "kind": "script",
      "test": "(()=>{const p=document.createElement('div');p.style.fontLanguageOverride='\"ROM\"';const c=document.createElement('span');p.appendChild(c);document.body.appendChild(p);const v=getComputedStyle(c).fontLanguageOverride;p.remove();return v.includes('ROM');})()",
      "specSection": "https://www.w3.org/TR/css-fonts-4/#font-language-override-prop"
    }
