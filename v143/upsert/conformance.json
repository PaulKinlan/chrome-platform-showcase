      "description": "getOrInsert sets and returns the default when the key is absent.",
      "kind": "script",
      "test": "(()=>{const m=new Map();const v=m.getOrInsert('k',42);return v===42 && m.get('k')===42;})()",
      "specSection": "https://github.com/tc39/proposal-upsert"
    },
    {
      "id": "map-getorinsert-keeps-existing",
      "description": "getOrInsert returns the existing value and does not overwrite when the key is present.",
      "kind": "script",
      "test": "(()=>{const m=new Map([['k',1]]);const v=m.getOrInsert('k',999);return v===1 && m.get('k')===1;})()",
      "specSection": "https://github.com/tc39/proposal-upsert"
    },
    {
      "id": "map-getorinsertcomputed-lazy",
      "description": "getOrInsertComputed only invokes the callback when the key is absent.",
      "kind": "script",
      "test": "(()=>{let calls=0;const m=new Map([['k',1]]);m.getOrInsertComputed('k',()=>{calls++;return 9;});return calls===0;})()",
