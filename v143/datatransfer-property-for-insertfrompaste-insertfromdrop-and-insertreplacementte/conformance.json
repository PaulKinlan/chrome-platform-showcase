  "assertions": [
    {
      "id": "inputevent-datatransfer-attribute",
      "description": "InputEvent exposes a dataTransfer attribute on its prototype.",
      "kind": "script",
      "test": "'dataTransfer' in InputEvent.prototype",
      "specSection": "https://w3c.github.io/input-events/#dom-inputevent-datatransfer"
    },
    {
      "id": "inputevent-datatransfer-getter",
      "description": "InputEvent.prototype.dataTransfer is an accessor (getter), not a data property.",
      "kind": "script",
      "test": "!!Object.getOwnPropertyDescriptor(InputEvent.prototype,'dataTransfer').get",
      "specSection": "https://w3c.github.io/input-events/#dom-inputevent-datatransfer"
    },
    {
      "id": "inputevent-constructible-with-datatransfer",
      "description": "InputEvent can be constructed with a DataTransfer in its init dictionary.",
      "kind": "script",
      "test": "(()=>{try{const dt=new DataTransfer();const ev=new InputEvent('input',{dataTransfer:dt,inputType:'insertFromPaste'});return ev.dataTransfer instanceof DataTransfer;}catch(_){return false;}})()",
      "specSection": "https://w3c.github.io/input-events/#dom-inputevent-datatransfer"
    },
    {
      "id": "inputevent-default-datatransfer-null",
      "description": "InputEvent constructed without dataTransfer has dataTransfer === null.",
      "kind": "script",
      "test": "new InputEvent('input').dataTransfer===null",
      "specSection": "https://w3c.github.io/input-events/#dom-inputevent-datatransfer"
    },
    {
      "id": "inputevent-inputtype-attribute",
      "description": "InputEvent exposes an inputType string attribute used to discriminate insertFromPaste vs insertFromDrop vs insertReplacementText.",
      "kind": "script",
      "test": "typeof new InputEvent('input',{inputType:'insertFromPaste'}).inputType==='string'",
      "specSection": "https://w3c.github.io/input-events/#dom-inputevent-inputtype"
    },
    {
      "id": "datatransfer-types-list",
      "description": "DataTransfer.types is a DOMStringList-like sequence (length is defined).",
      "kind": "script",
      "test": "typeof (new DataTransfer().types.length)==='number'",
      "specSection": "https://w3c.github.io/input-events/#dom-inputevent-datatransfer"
    },
    {
      "id": "affected-inputtypes-carry-datatransfer",
      "description": "insertFromPaste, insertFromDrop, and insertReplacementText InputEvents can be initialized with a DataTransfer payload.",
      "kind": "script",
      "test": "(()=>{try{const types=['insertFromPaste','insertFromDrop','insertReplacementText'];return types.every((inputType)=>{const dt=new DataTransfer();dt.setData('text/plain',inputType);const ev=new InputEvent('input',{inputType,dataTransfer:dt});return ev.dataTransfer===dt&&ev.inputType===inputType;});}catch(_){return false;}})()",
      "specSection": "https://w3c.github.io/input-events/#dom-inputevent-datatransfer"
    },
    {
      "id": "form-control-default-remains-null",
      "description": "Without an explicit DataTransfer payload, input events keep dataTransfer null, matching the form-control behavior described by the spec.",
      "kind": "script",
      "test": "new InputEvent('input',{inputType:'insertFromPaste',data:'pasted text'}).dataTransfer===null",
      "specSection": "https://w3c.github.io/input-events/#dom-inputevent-datatransfer"
    }
  ]
