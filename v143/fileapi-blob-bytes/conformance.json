      "description": "Bytes returned by Blob.bytes() has the same length as the source bytes.",
      "kind": "script",
      "test": "(()=>{const b=new Blob([new Uint8Array([1,2,3])]);return b.bytes().then(v=>v.length===3);})() instanceof Promise",
      "specSection": "https://www.w3.org/TR/FileAPI/#dom-blob-bytes"
    },
