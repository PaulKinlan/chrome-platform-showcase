    },
    {
      "id": "blob-bytes-resolves-to-uint8array",
      "description": "Blob.prototype.bytes() resolves to a Uint8Array (not a raw ArrayBuffer).",
      "kind": "script",
      "test": "(()=>{const b=new Blob(['hi']);return b.bytes().then(v=>v instanceof Uint8Array);})() instanceof Promise",
