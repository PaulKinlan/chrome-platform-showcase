  "assertions": [
    {
      "id": "createelement-accepts-unicode-tag",
      "description": "document.createElement accepts a tag name starting with a non-ASCII letter (e.g. CJK).",
      "kind": "script",
      "test": "(()=>{try{const e=document.createElement('\\u4e2d');return e.tagName.length>0;}catch(_){return false;}})()",
      "specSection": "https://dom.spec.whatwg.org/#namespaces"
    },
    {
      "id": "createelement-accepts-underscore-start",
      "description": "document.createElement accepts a tag name starting with an underscore.",
      "kind": "script",
      "test": "(()=>{try{const e=document.createElement('_x');return e instanceof Element;}catch(_){return false;}})()",
      "specSection": "https://dom.spec.whatwg.org/#namespaces"
    },
    {
      "id": "createelement-rejects-whitespace",
      "description": "document.createElement still throws for names containing ASCII whitespace.",
      "kind": "throws",
      "test": "document.createElement('bad name')",
      "specSection": "https://dom.spec.whatwg.org/#namespaces"
    },
    {
      "id": "createelement-rejects-slash",
      "description": "document.createElement still throws for names containing a U+002F SOLIDUS.",
      "kind": "throws",
      "test": "document.createElement('a/b')",
      "specSection": "https://dom.spec.whatwg.org/#namespaces"
    },
    {
      "id": "setattribute-accepts-unicode-name",
      "description": "Element.setAttribute accepts attribute names with non-ASCII letters (e.g. data-名前).",
      "kind": "script",
      "test": "(()=>{try{const e=document.createElement('div');e.setAttribute('data-\\u540d\\u524d','x');return e.getAttribute('data-\\u540d\\u524d')==='x';}catch(_){return false;}})()",
      "specSection": "https://dom.spec.whatwg.org/#namespaces"
    },
    {
      "id": "setattribute-rejects-equals",
      "description": "Element.setAttribute throws when the attribute name contains an equals sign.",
      "kind": "throws",
      "test": "document.createElement('div').setAttribute('a=b','x')",
      "specSection": "https://dom.spec.whatwg.org/#namespaces"
    },
    {
      "id": "queryselector-roundtrips-unicode-tag",
      "description": "querySelector with CSS.escape can locate an element created with a Unicode tag name.",
      "kind": "script",
      "test": "(()=>{try{const tag='\\u00e9l';const e=document.createElement(tag);document.body.appendChild(e);const found=document.querySelector(CSS.escape(tag));e.remove();return !!found;}catch(_){return false;}})()",
      "specSection": "https://dom.spec.whatwg.org/#namespaces"
    }
  ]
