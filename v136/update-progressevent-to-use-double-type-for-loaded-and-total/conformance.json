      "description": "ProgressEvent.loaded is a JS number (per double IDL).",
      "kind": "script",
      "test": "(()=>{const e=new ProgressEvent('progress',{loaded:0,total:0});return typeof e.loaded==='number';})()",
      "specSection": "https://whatpr.org/xhr/394.html#interface-progressevent"
    },
    {
      "id": "progress-event-length-computable",
