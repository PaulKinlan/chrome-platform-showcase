  "assertions": [
    {
      "id": "canvas-context-lang",
      "description": "CanvasRenderingContext2D exposes a `lang` attribute on its CanvasTextDrawingStyles mixin.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas').getContext('2d');return 'lang' in c;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/canvas.html#dom-context-2d-lang"
    },
    {
      "id": "canvas-context-lang-roundtrip",
      "description": "Setting ctx.lang round-trips through the getter.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas').getContext('2d');c.lang='ja';return c.lang==='ja';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/canvas.html#dom-context-2d-lang"
    },
    {
      "id": "canvas-context-lang-inherit",
      "description": "The default `lang` value is the string \"inherit\" — the spec-defined sentinel meaning \"use the canvas element's lang attribute\".",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas').getContext('2d');return c.lang==='inherit';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/canvas.html#dom-context-2d-lang"
    },
    {
      "id": "offscreen-canvas-context-lang",
      "description": "OffscreenCanvasRenderingContext2D mirrors the lang attribute so workers can produce locale-correct text.",
      "kind": "script",
      "test": "(()=>{const c=new OffscreenCanvas(2,2).getContext('2d');return 'lang' in c;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/canvas.html#dom-context-2d-lang"
    },
    {
      "id": "fill-text-still-exists",
      "description": "fillText is still exposed — language tagging is additive, not breaking.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas').getContext('2d');return typeof c.fillText==='function';})()"
    }
  ]
