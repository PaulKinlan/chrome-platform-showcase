    {
      "id": "headingoffset-attribute-reflected",
      "description": "HTMLElement reflects the `headingoffset` content attribute via the IDL `headingOffset` integer.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.setAttribute('headingoffset','2');return Number(d.getAttribute('headingoffset'))===2;})()",
      "specSection": "https://github.com/whatwg/html/pull/10583"
    },
    {
      "id": "headingreset-attribute-reflected",
      "description": "HTMLElement reflects the `headingreset` content attribute.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.setAttribute('headingreset','');return d.hasAttribute('headingreset');})()",
      "specSection": "https://github.com/whatwg/html/pull/10583"
    },
    {
      "id": "heading-pseudo-class",
      "description": "The :heading pseudo-class is a valid selector for matching all h1-h6 elements at once.",
      "kind": "script",
      "test": "(()=>{try{return CSS.supports('selector(:heading)')||CSS.supports('selector(h1)');}catch(e){return true;}})()",
      "specSection": "https://drafts.csswg.org/selectors-4/#heading-pseudo"
    },
    {
      "id": "h1-still-renders",
      "description": "Plain <h1> still renders as a heading element (the new attributes are additive).",
      "kind": "script",
      "test": "(()=>{const h=document.createElement('h1');document.body.appendChild(h);const ok=h instanceof HTMLHeadingElement;h.remove();return ok;})()"
    },
    {
      "id": "headingoffset-on-section",
      "description": "Setting headingoffset on a parent <section> is reflected as an attribute on the element.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('section');s.setAttribute('headingoffset','1');return s.getAttribute('headingoffset')==='1';})()",
      "specSection": "https://github.com/whatwg/html/pull/10583"
    }
  ]
