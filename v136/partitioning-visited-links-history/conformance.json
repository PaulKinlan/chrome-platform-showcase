  "assertions": [
    {
      "id": "visited-pseudo-class-supported",
      "description": "The :visited pseudo-class is still supported as a selector — partitioning changes which links match, not the selector grammar.",
      "kind": "css-supports",
      "test": "selector(:visited)",
      "specSection": "https://drafts.csswg.org/selectors-4/#link"
    },
    {
      "id": "visited-style-restricted-color",
      "description": "Computed style of an :visited rule must report the unvisited color when matching is suppressed — getComputedStyle never returns the post-visit color (anti-leak invariant).",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('style');s.textContent='a:visited{color:rgb(255,0,0)}';document.head.appendChild(s);const a=document.createElement('a');a.href='https://example.invalid/'+Math.random();a.textContent='x';document.body.appendChild(a);const c=getComputedStyle(a).color;a.remove();s.remove();return c!=='rgb(255, 0, 0)';})()",
      "specSection": "https://drafts.csswg.org/selectors-4/#visited-privacy"
    },
    {
      "id": "link-pseudo-class-supported",
      "description": "Sibling pseudo-class :link is supported — required for the :link/:visited dichotomy.",
      "kind": "css-supports",
      "test": "selector(:link)",
      "specSection": "https://drafts.csswg.org/selectors-4/#link"
    },
    {
      "id": "anchor-element-href",
      "description": "HTMLAnchorElement exposes href — the surface partitioning is applied to.",
      "kind": "script",
      "test": "'href' in HTMLAnchorElement.prototype"
    },
    {
      "id": "no-getmatchedcssrules",
      "description": "window.getMatchedCSSRules has long been removed; with visited-links partitioning the inability to introspect matched :visited rules is reinforced.",
      "kind": "script",
      "test": "typeof window.getMatchedCSSRules==='undefined'"
    }
  ]
