      "id": "regexp-escape-handles-meta-chars",
      "description": "RegExp.escape returns a string that, when used as a pattern, matches the original literally — special characters are neutralised.",
      "kind": "script",
      "test": "(()=>{const s='a.b+c?(d|e)';const e=RegExp.escape(s);return new RegExp(e).test(s);})()",
      "specSection": "https://tc39.es/proposal-regex-escaping/#sec-regexp.escape"
    },
    {
      "id": "regexp-escape-throws-on-non-string",
      "description": "RegExp.escape throws a TypeError when the input is not a string.",
      "kind": "throws",
      "test": "RegExp.escape(42)",
      "specSection": "https://tc39.es/proposal-regex-escaping/#sec-regexp.escape"
    },
    {
      "id": "regexp-escape-empty-string",
      "description": "RegExp.escape('') returns the empty string.",
      "kind": "script",
      "test": "RegExp.escape('')===''",
      "specSection": "https://tc39.es/proposal-regex-escaping/#sec-regexp.escape"
    },
    {
      "id": "regexp-escape-preserves-unicode",
      "description": "RegExp.escape preserves non-meta Unicode characters unchanged.",
      "kind": "script",
      "test": "(()=>{const out=RegExp.escape('caf\\u00e9');return new RegExp(out).test('caf\\u00e9');})()",
      "specSection": "https://tc39.es/proposal-regex-escaping/#sec-regexp.escape"
    },
    {
      "id": "regexp-escape-escapes-leading-digit",
      "description": "Per the proposal, a leading decimal digit is escaped so the result cannot be confused with a back-reference when concatenated.",
      "kind": "script",
      "test": "(()=>{const out=RegExp.escape('1abc');return out.charAt(0)==='\\\\';})()",
      "specSection": "https://tc39.es/proposal-regex-escaping/#sec-encodeforregexpescape"
    }
