      "description": "fromBase64(toBase64(arr)) returns an equal Uint8Array.",
      "kind": "script",
      "test": "(()=>{const a=new Uint8Array([1,2,3,4,5]);const s=a.toBase64();const b=Uint8Array.fromBase64(s);return a.length===b.length && a.every((v,i)=>v===b[i]);})()",
