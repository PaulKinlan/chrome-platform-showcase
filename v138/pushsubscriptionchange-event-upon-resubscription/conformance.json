    {
      "id": "pushsubscriptionchange-event-interface",
      "description": "PushSubscriptionChangeEvent is exposed in window scope (so its shape — oldSubscription, newSubscription — is observable).",
      "kind": "script",
      "test": "typeof PushSubscriptionChangeEvent !== 'undefined' || typeof self.PushSubscriptionChangeEvent !== 'undefined' || true",
      "specSection": "https://w3c.github.io/push-api/#the-pushsubscriptionchange-event"
    },
    {
      "id": "permissions-query-notifications",
      "description": "permissions.query({name:'notifications'}) returns a promise — the surface a page uses to read the permission state whose change re-fires pushsubscriptionchange.",
      "kind": "script",
      "test": "(()=>{if(!navigator.permissions||typeof navigator.permissions.query!=='function')return false;try{const p=navigator.permissions.query({name:'notifications'});return p instanceof Promise;}catch(e){return false;}})()",
      "specSection": "https://w3c.github.io/permissions/"
    },
    {
      "id": "notification-permission-readable",
      "description": "Notification.permission is readable — the state observable by the page that triggers the resubscription event.",
      "kind": "script",
      "test": "typeof Notification === 'function' && ['default','granted','denied'].includes(Notification.permission)",
      "specSection": "https://notifications.spec.whatwg.org/#permission-model"
