      "description": "abs() is accepted in property values; returns the same type as its argument.",
      "kind": "css-supports",
      "test": "width: abs(-10px)",
      "specSection": "https://www.w3.org/TR/css-values-4/#sign-funcs"
    },
    {
      "id": "sign-supported",
      "description": "sign() is accepted in property values; returns a unitless number.",
      "kind": "css-supports",
      "test": "opacity: sign(-5)",
      "specSection": "https://www.w3.org/TR/css-values-4/#sign-funcs"
    },
    {
      "id": "abs-of-negative-length",
      "description": "abs(-20px) computes to 20px.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.width='abs(-20px)';document.body.appendChild(e);const v=getComputedStyle(e).width;e.remove();return v==='20px';})()",
      "specSection": "https://www.w3.org/TR/css-values-4/#sign-funcs"
    },
    {
      "id": "sign-of-positive-is-1",
      "description": "sign(5) computes to 1 (unitless).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.opacity='sign(5)';document.body.appendChild(e);const v=parseFloat(getComputedStyle(e).opacity);e.remove();return Math.abs(v-1)<0.001;})()",
      "specSection": "https://www.w3.org/TR/css-values-4/#sign-funcs"
    },
    {
      "id": "sign-of-negative-is-minus-1",
      "description": "sign(-5) computes to -1 (observable via a custom property to avoid opacity clamping).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.setProperty('--s','sign(-5)');document.body.appendChild(e);const v=getComputedStyle(e).getPropertyValue('--s').trim();e.remove();return v==='-1'||v.startsWith('-1');})()",
      "specSection": "https://www.w3.org/TR/css-values-4/#sign-funcs"
    },
    {
      "id": "abs-inside-calc",
      "description": "abs() composes inside calc() expressions.",
      "kind": "css-supports",
      "test": "width: calc(abs(-15px) + 5px)",
      "specSection": "https://www.w3.org/TR/css-values-4/#sign-funcs"
    }
  ]
