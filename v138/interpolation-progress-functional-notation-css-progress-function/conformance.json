    {
      "id": "progress-half-is-0.5",
      "description": "progress(50, 0, 100) computes to 0.5.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.opacity='progress(50, 0, 100)';document.body.appendChild(e);const v=parseFloat(getComputedStyle(e).opacity);e.remove();return Math.abs(v-0.5)<0.01;})()",
      "specSection": "https://drafts.csswg.org/css-values-5/#progress"
    },
    {
      "id": "progress-zero-at-start",
      "description": "progress(0, 0, 100) computes to 0.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.opacity='progress(0, 0, 100)';document.body.appendChild(e);const v=parseFloat(getComputedStyle(e).opacity);e.remove();return Math.abs(v-0)<0.01;})()",
      "specSection": "https://drafts.csswg.org/css-values-5/#progress"
    },
    {
      "id": "progress-one-at-end",
      "description": "progress(100, 0, 100) computes to 1.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.opacity='progress(100, 0, 100)';document.body.appendChild(e);const v=parseFloat(getComputedStyle(e).opacity);e.remove();return Math.abs(v-1)<0.01;})()",
      "specSection": "https://drafts.csswg.org/css-values-5/#progress"
    },
    {
      "id": "progress-extrapolates-beyond-end",
      "description": "progress(150, 0, 100) extrapolates to 1.5 — values outside [start,end] are not clamped.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.cssText='position:absolute;visibility:hidden;width:calc(progress(150, 0, 100) * 10px);';document.body.appendChild(e);const v=parseFloat(getComputedStyle(e).width);e.remove();return Math.abs(v-15)<0.5;})()",
      "specSection": "https://drafts.csswg.org/css-values-5/#progress"
