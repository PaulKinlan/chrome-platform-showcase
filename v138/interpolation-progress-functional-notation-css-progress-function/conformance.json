    },
    {
      "id": "progress-with-length-args",
      "description": "progress() accepts typed <length> arguments where all three share the same type.",
      "kind": "css-supports",
      "test": "opacity: progress(50px, 0px, 100px)",
      "specSection": "https://drafts.csswg.org/css-values-5/#progress"
