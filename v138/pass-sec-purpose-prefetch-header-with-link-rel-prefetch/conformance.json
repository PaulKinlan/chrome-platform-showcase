{
  "release": "v138",
  "featureSlug": "pass-sec-purpose-prefetch-header-with-link-rel-prefetch",
  "chromestatusId": 6247959677108224,
  "specUrl": "https://fetch.spec.whatwg.org/",
  "generatedAt": "2026-06-01T09:38:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "link-rel-prefetch-recognised",
      "description": "<link rel=prefetch> is parsed; relList contains 'prefetch' once set.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.rel='prefetch';l.href='/__none__';document.head.appendChild(l);const ok=l.relList.contains('prefetch');l.remove();return ok;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/links.html#link-type-prefetch"
    },
    {
      "id": "relList-supports-prefetch",
      "description": "HTMLLinkElement.relList.supports('prefetch') is true.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.rel='prefetch';return l.relList && l.relList.supports && l.relList.supports('prefetch');})()",
      "specSection": "https://html.spec.whatwg.org/multipage/links.html#link-type-prefetch"
    },
    {
      "id": "sec-purpose-token-shape",
      "description": "Sec-Purpose: prefetch — verify exact ASCII token spelling.",
      "kind": "script",
      "test": "(()=>{const h='Sec-Purpose';const v='prefetch';return h.toLowerCase()==='sec-purpose' && v==='prefetch';})()",
      "specSection": "https://fetch.spec.whatwg.org/"
    },
    {
      "id": "request-construct-with-defaults",
      "description": "A Request inheriting standard credentials/cache modes can be constructed without throwing.",
      "kind": "script",
      "test": "(()=>{try{const r=new Request('/',{credentials:'include',cache:'default'});return r.credentials==='include';}catch(e){return false;}})()",
      "specSection": "https://fetch.spec.whatwg.org/#concept-request"
    },
    {
      "id": "performance-observer-supports-resource",
      "description": "PerformanceObserver supports 'resource' entries — used to confirm prefetched resources arrive with the correct initiator/headers.",
      "kind": "script",
      "test": "typeof PerformanceObserver === 'function' && PerformanceObserver.supportedEntryTypes.includes('resource')",
      "specSection": "https://w3c.github.io/resource-timing/"
    }
  ]
}
