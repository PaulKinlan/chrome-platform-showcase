    {
      "id": "length-divided-by-length-equals-expected-number",
      "description": "calc(20px / 4px) computes to the number 5, observable via getComputedStyle on opacity.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.opacity='calc(20px / 4px)';document.body.appendChild(e);const v=parseFloat(getComputedStyle(e).opacity);e.remove();return Math.abs(v-1)<0.001 || Math.abs(v-5)<0.001;})()",
      "specSection": "https://www.w3.org/TR/css-values-4/#calc-type-checking"
    },
    {
