      "kind": "script",
      "test": "(()=>{const a=document.createElement('span');a.textContent='Hello';a.style.font='16px monospace';const b=document.createElement('span');b.textContent='Hello';b.style.font='16px monospace';b.style.letterSpacing='10px';document.body.append(a,b);const wa=a.getBoundingClientRect().width;const wb=b.getBoundingClientRect().width;a.remove();b.remove();return wb>wa+30;})()",
      "specSection": "https://www.w3.org/TR/css-text-3/#letter-spacing-property"
    },
    {
      "id": "letter-spacing-ignored-for-arabic",
      "description": "letter-spacing applied to Arabic cursive script does not noticeably increase rendered width (v138 behavior).",
      "kind": "script",
      "test": "(()=>{const txt='العربية';const a=document.createElement('span');a.textContent=txt;a.style.font='16px sans-serif';const b=document.createElement('span');b.textContent=txt;b.style.font='16px sans-serif';b.style.letterSpacing='20px';document.body.append(a,b);const wa=a.getBoundingClientRect().width;const wb=b.getBoundingClientRect().width;a.remove();b.remove();return Math.abs(wb-wa)<wa*0.5;})()",
      "specSection": "https://www.w3.org/TR/css-text-3/#cursive-tracking"
    },
    {
      "id": "computed-letter-spacing-still-reflects-author-value",
      "description": "Even though the visual effect is suppressed for cursive scripts, getComputedStyle still reports the author-declared letter-spacing.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('span');e.textContent='اب';e.style.letterSpacing='5px';document.body.appendChild(e);const v=getComputedStyle(e).letterSpacing;e.remove();return v==='5px';})()",
