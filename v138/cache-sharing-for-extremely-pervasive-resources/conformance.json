      "description": "fetch() exists — the HTTP cache layer this feature modifies is reachable from script via fetch.",
      "kind": "exists",
      "test": "fetch",
      "specSection": "https://fetch.spec.whatwg.org/"
    },
    {
      "id": "fetch-is-function",
      "description": "fetch is callable; cache sharing is transparent to the API.",
      "kind": "typeof",
      "test": "fetch",
      "expect": "function"
    },
    {
      "id": "request-cache-modes-still-honored",
      "description": "Request.cache reflects the chosen cache mode; shared cache cannot override an explicit no-store.",
      "kind": "script",
      "test": "(()=>{try{const r=new Request('/',{cache:'no-store'});return r.cache==='no-store';}catch(e){return false;}})()",
      "specSection": "https://fetch.spec.whatwg.org/#concept-request-cache-mode"
    },
    {
      "id": "performance-resource-timing",
      "description": "PerformanceResourceTiming is available so a page can still observe cached-resource timings (transferSize, etc.) when shared cache is used.",
      "kind": "exists",
      "test": "PerformanceResourceTiming",
      "specSection": "https://w3c.github.io/resource-timing/"
    },
    {
      "id": "transfer-size-readable",
      "description": "A PerformanceResourceTiming entry exposes transferSize as a number — the primary observable for whether a fetch hit a shared cache.",
      "kind": "script",
      "test": "(()=>{const ents=performance.getEntriesByType('resource');return ents.length===0||typeof ents[0].transferSize==='number';})()",
      "specSection": "https://w3c.github.io/resource-timing/#dom-performanceresourcetiming-transfersize"
    }
