      "id": "lt-in-attribute-serialised-as-entity",
      "description": "Setting an attribute to a value containing '<' yields '&lt;' in outerHTML.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('data-x','<script>');return /&lt;/.test(e.outerHTML);})()",
      "specSection": "https://html.spec.whatwg.org/multipage/parsing.html#serialising-html-fragments"
    },
    {
      "id": "gt-in-attribute-serialised-as-entity",
      "description": "Setting an attribute to a value containing '>' yields '&gt;' in outerHTML.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('data-x','a>b');return /&gt;/.test(e.outerHTML);})()",
      "specSection": "https://html.spec.whatwg.org/multipage/parsing.html#serialising-html-fragments"
    },
    {
      "id": "ampersand-still-escaped",
      "description": "Existing attribute escaping for '&' is preserved (regression check).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('data-x','a&b');return /&amp;/.test(e.outerHTML);})()",
      "specSection": "https://html.spec.whatwg.org/multipage/parsing.html#serialising-html-fragments"
    },
    {
      "id": "quote-still-escaped",
      "description": "Existing attribute escaping for double-quote is preserved.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('data-x','a\"b');return /&quot;/.test(e.outerHTML);})()",
      "specSection": "https://html.spec.whatwg.org/multipage/parsing.html#serialising-html-fragments"
    },
    {
      "id": "outerhtml-roundtrip-safe",
      "description": "Round-tripping outerHTML for an element with '<' in an attribute yields the same getAttribute value.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('data-x','<x>');const html=e.outerHTML;const w=document.createElement('div');w.innerHTML=html;return w.firstElementChild.getAttribute('data-x')==='<x>';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/parsing.html#serialising-html-fragments"
