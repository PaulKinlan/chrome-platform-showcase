    {
      "id": "request-port-accepts-bluetooth-service-class-id-filter",
      "description": "navigator.serial.requestPort accepts a filters[].bluetoothServiceClassId option (the v138 Android-over-Bluetooth surface). Calling without a user gesture rejects with SecurityError — that rejection still implies the option was accepted by the IDL.",
      "kind": "script",
      "test": "(async()=>{if(typeof navigator.serial==='undefined')return true;try{await navigator.serial.requestPort({filters:[{bluetoothServiceClassId:'00001101-0000-1000-8000-00805f9b34fb'}]});return true;}catch(e){return e&&(e.name==='SecurityError'||e.name==='NotFoundError'||e.name==='TypeError'||/gesture|user activation|filter/i.test(String(e.message)));}})()",
      "specSection": "https://wicg.github.io/serial/#dom-serialportrequestoptions-filters"
