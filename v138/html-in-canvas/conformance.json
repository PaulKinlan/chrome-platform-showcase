    {
      "id": "layoutsubtree-attribute-reflects",
      "description": "The new layoutsubtree content attribute on <canvas> reflects through the DOM.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas');c.setAttribute('layoutsubtree','');return c.hasAttribute('layoutsubtree');})()",
      "specSection": "https://github.com/whatwg/html/pull/11588"
    },
    {
      "id": "2d-drawelement-method",
      "description": "CanvasRenderingContext2D exposes drawElement (a.k.a. drawElementImage) for rendering an HTML subtree to canvas.",
      "kind": "script",
      "test": "(()=>!('drawElement' in CanvasRenderingContext2D.prototype)||typeof CanvasRenderingContext2D.prototype.drawElement==='function')()",
      "specSection": "https://github.com/whatwg/html/pull/11588"
    },
    {
      "id": "webgl-texelementimage2d",
      "description": "WebGL2 context exposes texElementImage2D for sourcing textures from HTML elements when present.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas');const ctx=c.getContext('webgl2')||c.getContext('webgl');if(!ctx)return true;return typeof ctx.texElementImage2D==='function'||typeof ctx.texElementImage2D==='undefined';})()",
      "specSection": "https://github.com/whatwg/html/pull/11588"
    },
    {
      "id": "webgpu-copyelementimagetotexture",
      "description": "GPUQueue.prototype.copyElementImageToTexture is exposed when WebGPU is available.",
      "kind": "script",
      "test": "(()=>typeof GPUQueue==='undefined'||!('copyElementToTexture' in GPUQueue.prototype)||typeof GPUQueue.prototype.copyElementToTexture==='function')()",
      "specSection": "https://github.com/whatwg/html/pull/11588"
    }
  ]
