  "assertions": [
    {
      "id": "scrollintoview-method-exists",
      "description": "Element.prototype.scrollIntoView exists.",
      "kind": "typeof",
      "test": "Element.prototype.scrollIntoView",
      "expect": "function"
    },
    {
      "id": "scrollintoview-accepts-container-option",
      "description": "scrollIntoView accepts a ScrollIntoViewOptions object with `container: 'nearest'` without throwing.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');document.body.appendChild(e);try{e.scrollIntoView({container:'nearest'});e.remove();return true;}catch(err){e.remove();return false;}})()",
      "specSection": "https://drafts.csswg.org/cssom-view/#dom-scrollintoviewoptions-container"
    },
    {
      "id": "container-nearest-only-scrolls-nearest-ancestor",
      "description": "With container:'nearest' only the nearest scroll-container ancestor scrolls — outer ancestors keep their scrollTop.",
      "kind": "script",
      "test": "(()=>{const outer=document.createElement('div');outer.style.cssText='height:200px;overflow:auto;';const inner=document.createElement('div');inner.style.cssText='height:200px;overflow:auto;';const filler=document.createElement('div');filler.style.height='2000px';const target=document.createElement('div');target.style.cssText='height:50px;margin-top:1500px;background:red;';inner.append(filler,target);outer.appendChild(inner);document.body.appendChild(outer);const outerBefore=outer.scrollTop;target.scrollIntoView({container:'nearest'});const ok=inner.scrollTop>0 && outer.scrollTop===outerBefore;outer.remove();return ok;})()",
      "specSection": "https://drafts.csswg.org/cssom-view/#dom-scrollintoviewoptions-container"
    },
    {
      "id": "default-still-scrolls-all-ancestors",
      "description": "Default behavior (omitting container) still scrolls ancestors as before — backward compatibility.",
      "kind": "script",
      "test": "(()=>{try{const e=document.createElement('div');document.body.appendChild(e);e.scrollIntoView({block:'nearest'});e.remove();return true;}catch(err){return false;}})()",
      "specSection": "https://drafts.csswg.org/cssom-view/#scroll-into-view"
    },
    {
      "id": "scrollintoview-options-object-shape",
      "description": "ScrollIntoViewOptions accepts block/inline/behavior alongside container.",
      "kind": "script",
      "test": "(()=>{try{const e=document.createElement('div');document.body.appendChild(e);e.scrollIntoView({block:'center',inline:'nearest',behavior:'auto',container:'nearest'});e.remove();return true;}catch(err){return false;}})()",
      "specSection": "https://drafts.csswg.org/cssom-view/#scroll-into-view"
    }
  ]
}
