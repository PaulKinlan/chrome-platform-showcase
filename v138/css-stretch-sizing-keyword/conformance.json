    {
      "id": "stretch-fills-margin-box",
      "description": "width: stretch with horizontal margins yields a margin box equal to the container's width.",
      "kind": "script",
      "test": "(()=>{const p=document.createElement('div');p.style.width='200px';const c=document.createElement('div');c.style.width='stretch';c.style.marginLeft='10px';c.style.marginRight='30px';p.appendChild(c);document.body.appendChild(p);const w=c.getBoundingClientRect().width;p.remove();return Math.abs(w-160)<2;})()",
      "specSection": "https://drafts.csswg.org/css-sizing-4/#sizing-values"
    },
    {
      "id": "stretch-differs-from-100percent",
      "description": "Unlike width: 100% (which ignores margins), width: stretch accounts for margins.",
      "kind": "script",
      "test": "(()=>{const p=document.createElement('div');p.style.width='200px';const a=document.createElement('div');a.style.width='100%';a.style.marginLeft='20px';const b=document.createElement('div');b.style.width='stretch';b.style.marginLeft='20px';p.append(a,b);document.body.appendChild(p);const wa=a.getBoundingClientRect().width;const wb=b.getBoundingClientRect().width;p.remove();return wa!==wb&&Math.abs(wb-180)<2;})()",
      "specSection": "https://drafts.csswg.org/css-sizing-4/#sizing-values"
    }
  ]
