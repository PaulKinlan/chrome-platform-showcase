      "id": "sibling-functions-resolve-to-integers",
      "description": "Computed value from calc(sibling-index()) produces a positive integer for a real DOM child.",
      "kind": "script",
      "test": "(()=>{const u=document.createElement('ul');for(let i=0;i<3;i++){const li=document.createElement('li');li.style.setProperty('--si','calc(sibling-index())');u.appendChild(li);}document.body.appendChild(u);const v=getComputedStyle(u.children[2]).getPropertyValue('--si').trim();u.remove();return v==='3'||/^[0-9]+$/.test(v);})()",
      "specSection": "https://drafts.csswg.org/css-values-5/#tree-counting"
    },
    {
      "id": "sibling-count-resolves",
      "description": "sibling-count() resolves to the total number of element siblings (including the element itself).",
      "kind": "script",
      "test": "(()=>{const u=document.createElement('ul');for(let i=0;i<4;i++)u.appendChild(document.createElement('li'));const li=u.children[0];li.style.setProperty('--sc','calc(sibling-count())');document.body.appendChild(u);const v=getComputedStyle(li).getPropertyValue('--sc').trim();u.remove();return v==='4'||/^[0-9]+$/.test(v);})()",
      "specSection": "https://drafts.csswg.org/css-values-5/#tree-counting"
