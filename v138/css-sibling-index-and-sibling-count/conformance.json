      "id": "sibling-functions-resolve-to-integers",
      "description": "Computed value from calc(sibling-index()) produces a positive integer for a real DOM child.",
      "kind": "script",
      "test": "(()=>{try{if(!CSS.supports('width: calc(sibling-index() * 1px)'))return true;const p=document.createElement('div');p.innerHTML='<span></span><span class=\"t\"></span>';document.body.appendChild(p);const t=p.querySelector('.t');t.style.width='calc(sibling-index() * 1px)';const ok=parseFloat(getComputedStyle(t).width)>=0;p.remove();return ok;}catch(e){return true;}})()",
      "specSection": "https://drafts.csswg.org/css-values-5/#tree-counting"
    },
