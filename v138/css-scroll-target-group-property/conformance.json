      "description": "Setting scroll-target-group: auto round-trips through getComputedStyle.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.setProperty('scroll-target-group','auto');document.body.appendChild(e);const v=getComputedStyle(e).getPropertyValue('scroll-target-group').trim();e.remove();return v==='auto';})()",
