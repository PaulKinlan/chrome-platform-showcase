      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');document.body.appendChild(e);const v=getComputedStyle(e).scrollTargetGroup||getComputedStyle(e).getPropertyValue('scroll-target-group');e.remove();return v==='none'||v==='';})()",
