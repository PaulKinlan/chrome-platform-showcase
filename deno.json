{
  "license": "Apache-2.0",
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-env server.ts",
    "start": "deno run --allow-net --allow-read --allow-env server.ts",
    "check": "deno check server.ts && python3 .claude/audit-demos.py --strict",
    "audit": "python3 .claude/audit-demos.py",
    "auto-research": "deno run --allow-run --allow-read --allow-write --allow-net --allow-env tools/auto-research.ts",
    "fmt": "deno fmt"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "semiColons": true,
    "exclude": ["**/*.html", "**/*.css", "v[0-9]*/**/*.js", "v[0-9]*/**/*.json"]
  },
  "compilerOptions": {
    "lib": ["deno.window", "dom"],
    "strict": true
  }
}
