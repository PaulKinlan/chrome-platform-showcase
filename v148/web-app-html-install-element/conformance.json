  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "html-element-install-defined",
      "description": "<install> is registered as a known HTML element (not HTMLUnknownElement).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('install');return e.toString()!=='[object HTMLUnknownElement]';})()",
      "specSection": "https://github.com/WICG/web-app-install-element"
    },
    {
      "id": "install-src-attribute-reflects",
      "description": "The src attribute reflects on the install element (cross-origin install source).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('install');e.setAttribute('src','/manifest.webmanifest');return e.getAttribute('src')==='/manifest.webmanifest';})()"
    },
    {
      "id": "install-manifest-id-attribute",
      "description": "The manifest-id attribute reflects on the install element.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('install');e.setAttribute('manifest-id','foo');return e.getAttribute('manifest-id')==='foo';})()"
    },
    {
      "id": "before-install-prompt-event",
      "description": "beforeinstallprompt remains a registrable event used by the install flow.",
      "kind": "script",
      "test": "(()=>{let ok=true;try{window.addEventListener('beforeinstallprompt',()=>{});}catch(e){ok=false;}return ok;})()"
    },
    {
      "id": "install-click-event-default",
      "description": "Click on the install element doesn't throw and remains a dispatchable event.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('install');document.body.appendChild(e);e.click();e.remove();return true;})()"
    }
  ]
}
