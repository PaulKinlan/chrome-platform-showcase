    {
      "id": "name-only-at-container-parses",
      "description": "@container --foo { } parses without requiring a parenthesised query.",
      "kind": "script",
      "test": "(()=>{const s=new CSSStyleSheet();s.replaceSync('@container --foo { .x { --parsed-name-only: yes } }');return s.cssRules[0].cssText.includes('@container')})()",
      "specSection": "https://drafts.csswg.org/css-conditional-5/#container-rule"
    },
    {
      "id": "name-only-matches-without-type",
      "description": "An element with container-name set but no container-type can satisfy a name-only @container.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('div');c.style.containerName='--foo';const x=document.createElement('span');x.className='name-only-child';c.appendChild(x);document.body.appendChild(c);const s=document.createElement('style');s.textContent='@container --foo { .name-only-child { --matched-name-only: yes; } }';document.head.appendChild(s);const cs=getComputedStyle(x);const ok=cs.getPropertyValue('--matched-name-only').trim()==='yes'&&getComputedStyle(c).containerType==='normal';c.remove();s.remove();return ok;})()",
      "specSection": "https://drafts.csswg.org/css-conditional-5/#container-rule"
    },
    {
      "id": "named-with-query-still-works",
      "description": "Legacy named query with size still parses (backward compatibility).",
      "kind": "script",
      "test": "(()=>{const s=new CSSStyleSheet();s.replaceSync('@container --foo (min-width: 100px) { .x { --parsed-sized-name: yes } }');return s.cssRules.length===1;})()",
      "specSection": "https://drafts.csswg.org/css-conditional-5/#container-rule"
    },
