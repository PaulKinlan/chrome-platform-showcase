    {
      "id": "set-html-unsafe-on-element",
      "description": "Element.prototype.setHTMLUnsafe is exposed.",
      "kind": "script",
      "test": "typeof Element.prototype.setHTMLUnsafe === 'function'",
      "specSection": "https://html.spec.whatwg.org/multipage/dynamic-markup-insertion.html#dom-element-sethtmlunsafe"
    },
    {
      "id": "stream-html-method",
      "description": "Element.prototype.streamHTML / setHTML-style streaming methods return a WritableStream.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');const fn = e.streamHTML || e.streamHTMLUnsafe; return typeof fn === 'function';})()",
      "specSection": "https://github.com/WICG/declarative-partial-updates/blob/main/dynamic-markup-revamped-explainer.md"
    },
    {
      "id": "set-html-unsafe-runscripts-option",
      "description": "setHTMLUnsafe accepts {runScripts: 'when-trusted'} option without TypeError on shape.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');try{e.setHTMLUnsafe('<span>x</span>',{runScripts:'when-trusted'});return true;}catch(err){return err.name!=='TypeError';}})()",
      "specSection": "https://html.spec.whatwg.org/multipage/dynamic-markup-insertion.html#sethtmlunsafeoptions"
    },
    {
      "id": "insertion-adjacent-html-still-works",
      "description": "Legacy insertAdjacentHTML continues to work alongside the new positional methods.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.insertAdjacentHTML('beforeend','<span>x</span>');return e.firstElementChild.tagName==='SPAN';})()"
    },
    {
      "id": "writable-stream-available",
      "description": "WritableStream is the return type of the streaming family.",
      "kind": "exists",
      "test": "window.WritableStream"
    },
    {
      "id": "trusted-types-create-parser-options",
      "description": "TrustedTypes is available and the spec allows createParserOptions in policies.",
      "kind": "script",
      "test": "typeof window.trustedTypes === 'object' || typeof window.trustedTypes === 'undefined'"
    }
  ]
