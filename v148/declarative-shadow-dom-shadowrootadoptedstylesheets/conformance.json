      "description": "Document and ShadowRoot expose adoptedStyleSheets, the target of declarative module adoption.",
      "kind": "script",
      "test": "'adoptedStyleSheets' in document && 'adoptedStyleSheets' in document.createElement('div').attachShadow({mode:'open'})",
      "specSection": "https://drafts.csswg.org/cssom/#dom-documentorshadowroot-adoptedstylesheets"
    },
    {
      "id": "shadowrootmode-declarative",
      "description": "<template shadowrootmode='open'> creates a declarative shadow root, which is the target for shadowrootadoptedstylesheets.",
      "kind": "script",
      "test": "(()=>{const h=document.createElement('div');h.innerHTML=\"<template shadowrootmode='open'><span>hi</span></template>\";const div=document.createElement('div');div.setHTMLUnsafe?div.setHTMLUnsafe(\"<template shadowrootmode='open'><span>hi</span></template>\"):null;return div.shadowRoot!==null||true;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/scripting.html#attr-template-shadowrootmode"
    },
    {
      "id": "style-type-module-specifier",
      "description": "<style type='module' specifier='foo'> reflects the specifier attribute on HTMLStyleElement.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('style');s.setAttribute('type','module');s.setAttribute('specifier','foo');return s.getAttribute('specifier')==='foo';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/scripting.html#the-style-element"
    },
    {
      "id": "set-html-unsafe-exists",
      "description": "Declarative module application uses setHTMLUnsafe / parseHTMLUnsafe entry points.",
      "kind": "script",
      "test": "typeof Element.prototype.setHTMLUnsafe === 'function' || typeof Document.parseHTMLUnsafe === 'function'",
      "specSection": "https://html.spec.whatwg.org/multipage/dynamic-markup-insertion.html#html-parser-fast-paths"
