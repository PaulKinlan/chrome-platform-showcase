    {
      "id": "supported-entry-types-container",
      "description": "PerformanceObserver.supportedEntryTypes lists 'container' once the feature is enabled.",
      "kind": "script",
      "test": "(()=>!PerformanceObserver.supportedEntryTypes||PerformanceObserver.supportedEntryTypes.includes('container')||typeof PerformanceContainerTiming==='undefined')()",
      "specSection": "https://wicg.github.io/container-timing/#sec-PerformanceContainerTiming"
    },
    {
      "id": "containertiming-attribute-reflects",
      "description": "The containertiming HTML attribute is reflected on HTMLElement instances.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('containertiming','hero');return e.getAttribute('containertiming')==='hero';})()",
      "specSection": "https://wicg.github.io/container-timing/#dom-htmlelement-containertiming"
    },
    {
      "id": "performance-container-timing-class",
      "description": "PerformanceContainerTiming is exposed as a PerformanceEntry subtype.",
      "kind": "script",
      "test": "(()=>typeof PerformanceContainerTiming==='undefined'||typeof PerformanceContainerTiming==='function')()",
      "specSection": "https://wicg.github.io/container-timing/#performancecontainertiming"
    },
    {
      "id": "observe-buffered-supported",
      "description": "PerformanceObserver.observe accepts the {type, buffered} pattern needed to catch early container entries.",
      "kind": "script",
      "test": "(()=>{try{const po=new PerformanceObserver(()=>{});po.observe({type:'container',buffered:true});po.disconnect();return true;}catch(e){return /TypeError|not supported/i.test(e.message)===false?false:false;}})()",
      "specSection": "https://w3c.github.io/performance-timeline/#dom-performanceobserver-observe"
    }
