      "id": "containertiming-attribute-reflects",
      "description": "The containertiming content attribute stores the identifier that becomes PerformanceContainerTiming.identifier.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('containertiming','hero-section');return e.getAttribute('containertiming')==='hero-section';})()",
      "specSection": "https://wicg.github.io/container-timing/#dfn-containertiming"
    },
    {
      "id": "containertiming-ignore-attribute-reflects",
      "description": "The containertiming-ignore content attribute can mark an ignored subtree for ancestor container timing.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('aside');e.setAttribute('containertiming-ignore','');return e.hasAttribute('containertiming-ignore');})()",
      "specSection": "https://wicg.github.io/container-timing/#dfn-containertiming-ignore"
    },
    {
      "id": "performance-container-timing-constructor-gates-native-support",
      "description": "Origin-trial native support is detected through the PerformanceContainerTiming constructor recommended by Chrome.",
      "kind": "script",
      "test": "(()=>typeof PerformanceContainerTiming==='undefined'||typeof PerformanceContainerTiming==='function')()",
      "specSection": "https://wicg.github.io/container-timing/#performancecontainertiming"
    },
    {
      "id": "performance-container-timing-prototype-fields",
      "description": "When native support is enabled, PerformanceContainerTiming exposes the identifier, first-render, size, root, last-painted, and paint timestamp fields.",
      "kind": "script",
      "test": "(()=>typeof PerformanceContainerTiming==='undefined'||['identifier','firstRenderTime','size','rootElement','lastPaintedElement'].every(name=>name in PerformanceContainerTiming.prototype)&&('renderTime'in PerformanceContainerTiming.prototype||'paintTime'in PerformanceContainerTiming.prototype||'startTime'in PerformanceContainerTiming.prototype))()",
      "specSection": "https://wicg.github.io/container-timing/#performancecontainertiming"
    },
    {
      "id": "native-observer-registration-or-clean-unsupported",
      "description": "When native support is enabled, PerformanceObserver can register type: 'container'; otherwise the unsupported browser path remains clean.",
      "kind": "script",
      "test": "(()=>{if(typeof PerformanceContainerTiming==='undefined')return true;try{const po=new PerformanceObserver(()=>{});po.observe({type:'container',buffered:true});po.disconnect();return true;}catch{return false;}})()",
      "specSection": "https://wicg.github.io/container-timing/#sec-processing-model"
