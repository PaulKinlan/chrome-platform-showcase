  "assertions": [
    {
      "id": "table-element-exists",
      "description": "HTMLTableElement is exposed; the change affects its UA stylesheet.",
      "kind": "exists",
      "test": "window.HTMLTableElement"
    },
    {
      "id": "border-color-property-supported",
      "description": "border-color remains an author-settable CSS property.",
      "kind": "css-supports",
      "test": "border-color: red"
    },
    {
      "id": "table-default-border-color-uses-current",
      "description": "After UA rule removal, a table's effective border-color uses currentColor (i.e. inherits from color).",
      "kind": "script",
      "test": "(()=>{const t=document.createElement('table');t.setAttribute('border','1');t.style.color='red';document.body.appendChild(t);const cs=getComputedStyle(t).borderTopColor;t.remove();return /rgb\\(\\s*255\\s*,\\s*0\\s*,\\s*0\\s*\\)/.test(cs);})()",
      "specSection": "https://html.spec.whatwg.org/multipage/rendering.html#tables-2"
    },
    {
      "id": "table-currentcolor-keyword-supported",
      "description": "currentColor is parseable for border-color (the new UA default).",
      "kind": "css-supports",
      "test": "border-color: currentColor"
    },
    {
      "id": "table-border-attribute-still-works",
      "description": "The border content attribute on <table> is still parsed and reflected.",
      "kind": "script",
      "test": "(()=>{const t=document.createElement('table');t.setAttribute('border','2');return t.getAttribute('border')==='2';})()"
    }
  ]
