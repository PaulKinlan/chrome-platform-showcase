      "kind": "css-supports",
      "test": "selector(:active)"
    },
    {
      "id": "dialog-show-modal",
      "description": "<dialog>.showModal places the dialog in the top layer (the layer this rule scopes against).",
      "kind": "script",
      "test": "typeof HTMLDialogElement.prototype.showModal === 'function'",
      "specSection": "https://html.spec.whatwg.org/multipage/interactive-elements.html#dom-dialog-showmodal"
    },
    {
      "id": "popover-attribute-reflects",
      "description": "popover attribute (another way to enter the top layer) is reflected on HTMLElement.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('popover','');return e.hasAttribute('popover');})()"
