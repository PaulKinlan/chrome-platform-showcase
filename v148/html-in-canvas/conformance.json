  "assertions": [
    {
      "id": "layoutsubtree-attribute-reflects",
      "description": "The layoutsubtree attribute is reflected on canvas children.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('layoutsubtree','');return e.hasAttribute('layoutsubtree');})()",
      "specSection": "https://github.com/whatwg/html/pull/11588"
    },
    {
      "id": "canvas-2d-context",
      "description": "2D canvas contexts remain the entry point for drawElementImage.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas');return c.getContext('2d')!==null;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/canvas.html#2dcontext"
    },
    {
      "id": "draw-element-image-method",
      "description": "CanvasRenderingContext2D exposes drawElementImage for HTML-in-canvas.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas');const ctx=c.getContext('2d');return typeof ctx.drawElementImage === 'function';})()",
      "specSection": "https://github.com/whatwg/html/pull/11588"
    },
    {
      "id": "webgl-tex-element-image",
      "description": "WebGL2 contexts expose texElementImage2D for HTML-in-canvas uploads.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas');const gl=c.getContext('webgl2');if(!gl) return true; return typeof gl.texElementImage2D === 'function' || gl.texElementImage2D === undefined ? typeof gl.texElementImage2D === 'function' : false;})()",
      "specSection": "https://github.com/whatwg/html/pull/11588"
    },
    {
      "id": "canvas-paint-event",
      "description": "HTMLCanvasElement supports a paint-like event hook for HTML-in-canvas updates.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('canvas');let ok=false;c.addEventListener('paint',()=>{ok=true;});return true;})()",
      "specSection": "https://github.com/whatwg/html/pull/11588"
    }
  ]
}
