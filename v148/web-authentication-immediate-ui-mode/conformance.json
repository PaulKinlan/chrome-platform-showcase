  "assertions": [
    {
      "id": "public-key-credential-exists",
      "description": "PublicKeyCredential remains the WebAuthn entry point.",
      "kind": "exists",
      "test": "window.PublicKeyCredential"
    },
    {
      "id": "credentials-get-is-function",
      "description": "navigator.credentials.get is the entry the immediate UI mode is added to.",
      "kind": "typeof",
      "test": "navigator.credentials?.get",
      "expect": "function"
    },
    {
      "id": "credentials-get-mediation-options",
      "description": "navigator.credentials.get accepts a mediation option (the dictionary the new 'immediate' value lives on).",
      "kind": "script",
      "test": "(()=>{try{navigator.credentials.get({mediation:'immediate',signal:AbortSignal.abort()});return true;}catch(e){return /AbortError|NotAllowedError|TypeError/.test(e.name);}})()",
      "specSection": "https://w3c.github.io/webauthn/#dom-credentialrequestoptions-mediation"
    },
    {
      "id": "immediate-rejects-not-allowed",
      "description": "An immediate-mode get() must reject with NotAllowedError when no eligible credential is known.",
      "kind": "script",
      "test": "(async()=>{try{await navigator.credentials.get({mediation:'immediate',publicKey:{challenge:new Uint8Array(32)}});return false;}catch(e){return e.name==='NotAllowedError'||e.name==='SecurityError'||e.name==='AbortError';}})()"
    },
    {
      "id": "credentials-conditional-mediation-still-works",
      "description": "Existing 'conditional' mediation continues to work alongside the new 'immediate'.",
      "kind": "script",
      "test": "typeof PublicKeyCredential.isConditionalMediationAvailable === 'function'"
    }
  ]
}
