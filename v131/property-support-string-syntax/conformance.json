      "id": "string-syntax-registers",
      "description": "CSS.registerProperty accepts syntax: '<string>'.",
      "kind": "script",
      "test": "(()=>{try{CSS.registerProperty({name:'--string-conf-'+Math.random().toString(36).slice(2),syntax:'<string>',inherits:false,initialValue:'\"initial\"'});return true;}catch(_){return false;}})()",
      "specSection": "https://drafts.css-houdini.org/css-properties-values-api-1/#supported-names"
    },
    {
      "id": "string-value-computes",
      "description": "A registered <string> custom property computes a quoted string value.",
      "kind": "script",
      "test": "(()=>{const name='--string-conf-'+Math.random().toString(36).slice(2);CSS.registerProperty({name,syntax:'<string>',inherits:false,initialValue:'\"initial\"'});const e=document.createElement('div');e.style.setProperty(name,'\"custom\"');document.body.append(e);const ok=getComputedStyle(e).getPropertyValue(name).trim()==='\"custom\"';e.remove();return ok;})()",
      "specSection": "https://drafts.css-houdini.org/css-properties-values-api-1/#supported-names"
    },
    {
      "id": "unquoted-string-rejected",
      "description": "An unquoted token does not satisfy a registered <string> custom property.",
      "kind": "script",
      "test": "(()=>{const name='--string-conf-'+Math.random().toString(36).slice(2);CSS.registerProperty({name,syntax:'<string>',inherits:false,initialValue:'\"initial\"'});const e=document.createElement('div');e.style.setProperty(name,'not-a-string');document.body.append(e);const ok=getComputedStyle(e).getPropertyValue(name).trim()==='\"initial\"';e.remove();return ok;})()",
      "specSection": "https://drafts.css-houdini.org/css-properties-values-api-1/#supported-names"
    },
