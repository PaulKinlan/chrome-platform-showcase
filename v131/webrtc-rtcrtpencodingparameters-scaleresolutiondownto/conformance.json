      "id": "scale-resolution-down-to-reflected",
      "description": "getParameters reflects the maxWidth and maxHeight values set through scaleResolutionDownTo.",
      "kind": "script",
      "test": "(async()=>{try{const pc=new RTCPeerConnection();const canvas=document.createElement('canvas');canvas.width=32;canvas.height=24;const track=canvas.captureStream().getVideoTracks()[0];const sender=pc.addTrack(track);const params=sender.getParameters();params.encodings=params.encodings&&params.encodings.length?params.encodings:[{}];params.encodings[0].scaleResolutionDownTo={maxWidth:16,maxHeight:12};await sender.setParameters(params);const after=sender.getParameters().encodings[0].scaleResolutionDownTo;track.stop();pc.close();return after&&after.maxWidth===16&&after.maxHeight===12;}catch(_){return false;}})()",
