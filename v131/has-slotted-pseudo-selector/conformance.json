    {
      "id": "slotted-selector-parses",
      "description": "The established ::slotted() selector parses for styling distributed slot content.",
      "kind": "css-supports",
      "test": "selector(::slotted(*))",
      "specSection": "https://drafts.csswg.org/css-scoping/#slotted-pseudo"
    },
    {
      "id": "assignednodes-detects-slotted-text",
      "description": "assignedNodes reports a text node distributed into a default slot.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');const root=host.attachShadow({mode:'open'});root.innerHTML='<slot></slot>';host.textContent='slotted text';document.body.append(host);const slot=root.querySelector('slot');const ok=slot.assignedNodes().length===1&&slot.assignedNodes()[0].nodeType===Node.TEXT_NODE;host.remove();return ok;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/scripting.html#dom-slot-assignednodes"
    },
    {
      "id": "assignednodes-empty-slot",
      "description": "assignedNodes returns an empty list when the slot uses fallback content.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');const root=host.attachShadow({mode:'open'});root.innerHTML='<slot>fallback</slot>';document.body.append(host);const slot=root.querySelector('slot');const ok=slot.assignedNodes().length===0;host.remove();return ok;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/scripting.html#dom-slot-assignednodes"
    },
    {
      "id": "assignedelements-flatten-option",
      "description": "assignedElements accepts the flatten option used by slot-distribution checks.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');const root=host.attachShadow({mode:'open'});root.innerHTML='<slot></slot>';const child=document.createElement('span');host.append(child);document.body.append(host);const slot=root.querySelector('slot');const ok=slot.assignedElements({flatten:true})[0]===child;host.remove();return ok;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/scripting.html#dom-slot-assignedelements"
    }
  ]
