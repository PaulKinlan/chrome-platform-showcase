  "assertions": [
    {
      "id": "speculation-rules-script-type-supported",
      "description": "Browsers that ship speculation rules accept <script type=speculationrules> as a valid script type.",
      "kind": "script",
      "test": "HTMLScriptElement.supports && HTMLScriptElement.supports('speculationrules')",
      "specSection": "https://wicg.github.io/nav-speculation/speculation-rules.html"
    },
    {
      "id": "speculation-rules-prerender-mode",
      "description": "The prerender action is recognised inside a speculation rules script.",
      "kind": "script",
      "test": "(()=>{try{const s=document.createElement('script');s.type='speculationrules';s.textContent=JSON.stringify({prerender:[{urls:['/__sr_probe']}]});document.head.appendChild(s);const ok=s.parentNode===document.head;s.remove();return ok;}catch(e){return false;}})()"
    },
    {
      "id": "header-driven-rules-bypass-script-src",
      "description": "A Speculation-Rules HTTP header should apply even when CSP script-src is restrictive; this assertion documents the spec contract.",
      "kind": "script",
      "test": "'SecurityPolicyViolationEvent' in window"
    },
    {
      "id": "no-csp-violation-on-header-rules",
      "description": "No SecurityPolicyViolationEvent is dispatched purely for the presence of a Speculation-Rules header in this page load.",
      "kind": "script",
      "test": "(()=>{let fired=false;const h=()=>fired=true;document.addEventListener('securitypolicyviolation',h);setTimeout(()=>document.removeEventListener('securitypolicyviolation',h),0);return !fired;})()"
    },
    {
      "id": "speculation-rules-prefetch-mode",
      "description": "The prefetch action is recognised inside a speculation rules script.",
      "kind": "script",
      "test": "(()=>{try{const s=document.createElement('script');s.type='speculationrules';s.textContent=JSON.stringify({prefetch:[{urls:['/__pf_probe']}]});document.head.appendChild(s);const ok=s.parentNode===document.head;s.remove();return ok;}catch(e){return false;}})()"
    }
  ]
