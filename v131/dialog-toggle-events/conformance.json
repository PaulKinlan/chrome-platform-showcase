    {
      "id": "ontoggle-on-dialog",
      "description": "HTMLDialogElement exposes an ontoggle IDL attribute, mirroring popovers.",
      "kind": "script",
      "test": "'ontoggle' in HTMLDialogElement.prototype",
      "specSection": "https://html.spec.whatwg.org/multipage/interactive-elements.html#the-dialog-element"
    },
    {
      "id": "onbeforetoggle-on-dialog",
      "description": "HTMLDialogElement exposes an onbeforetoggle IDL attribute for cancelable pre-state-change notification.",
      "kind": "script",
      "test": "'onbeforetoggle' in HTMLDialogElement.prototype"
    },
    {
      "id": "toggleevent-constructor",
      "description": "ToggleEvent constructor is exposed (the dialog reuses the popover event interface).",
      "kind": "typeof",
      "test": "ToggleEvent",
      "expect": "function"
    },
    {
      "id": "toggleevent-has-newstate-oldstate",
      "description": "ToggleEvent instances expose newState and oldState string properties.",
      "kind": "script",
      "test": "(()=>{try{const e=new ToggleEvent('toggle',{oldState:'closed',newState:'open'});return e.newState==='open'&&e.oldState==='closed';}catch(e){return false;}})()"
    },
    {
      "id": "dialog-fires-toggle-on-show",
      "description": "Calling show() on a <dialog> fires a 'toggle' event with newState 'open'.",
      "kind": "script",
      "test": "(()=>{return new Promise(res=>{const d=document.createElement('dialog');document.body.appendChild(d);d.addEventListener('toggle',ev=>{const ok=ev.newState==='open';d.close();d.remove();res(ok);});try{d.show();}catch(e){d.remove();res(false);}setTimeout(()=>{try{d.remove()}catch(_){}res(false);},500);});})()"
    },
    {
      "id": "beforetoggle-reports-dialog-close-transition",
      "description": "The beforetoggle event for a closing dialog reports the open-to-closed transition and is not the cancellable close-request hook.",
      "kind": "script",
      "test": "(()=>new Promise(res=>{const d=document.createElement('dialog');document.body.appendChild(d);let seen=false;d.addEventListener('beforetoggle',ev=>{if(ev.newState==='closed'){seen=ev.oldState==='open'&&ev.cancelable===false;}});d.addEventListener('toggle',ev=>{if(ev.newState==='closed'){d.remove();res(seen);}});try{d.showModal();requestAnimationFrame(()=>d.close('test'));}catch(e){d.remove();res(false);}setTimeout(()=>{try{d.remove();}catch(_){}res(false);},500);}))()"
    },
    {
      "id": "requestclose-fires-cancel-before-beforetoggle",
      "description": "dialog.requestClose() fires a cancellable cancel event before the beforetoggle close-transition notification.",
      "kind": "script",
      "test": "(()=>new Promise(res=>{if(typeof HTMLDialogElement.prototype.requestClose!=='function'){res(false);return;}const d=document.createElement('dialog');document.body.appendChild(d);const events=[];d.addEventListener('cancel',ev=>events.push(`cancel:${ev.cancelable}`));d.addEventListener('beforetoggle',ev=>{if(ev.newState==='closed')events.push(`beforetoggle:${ev.cancelable}:${ev.oldState}->${ev.newState}`);});d.addEventListener('toggle',ev=>{if(ev.newState==='closed'){const ok=events[0]==='cancel:true'&&events[1]==='beforetoggle:false:open->closed';d.remove();res(ok);}});try{d.showModal();requestAnimationFrame(()=>d.requestClose('test'));}catch(e){d.remove();res(false);}setTimeout(()=>{try{d.remove();}catch(_){}res(false);},500);}))()",
      "specSection": "https://html.spec.whatwg.org/multipage/interactive-elements.html#dom-dialog-requestclose"
    },
    {
      "id": "cancel-preventdefault-keeps-dialog-open",
      "description": "Preventing the cancel event from a close request keeps the modal dialog open for guarded dirty-form flows.",
      "kind": "script",
      "test": "(()=>new Promise(res=>{if(typeof HTMLDialogElement.prototype.requestClose!=='function'){res(false);return;}const d=document.createElement('dialog');document.body.appendChild(d);d.addEventListener('cancel',ev=>ev.preventDefault());try{d.showModal();requestAnimationFrame(()=>{d.requestClose('blocked');setTimeout(()=>{const ok=d.open===true;d.close('cleanup');d.remove();res(ok);},80);});}catch(e){d.remove();res(false);}setTimeout(()=>{try{d.remove();}catch(_){}res(false);},500);}))()",
      "specSection": "https://html.spec.whatwg.org/multipage/interactive-elements.html#close-requests"
    }
  ]
}
