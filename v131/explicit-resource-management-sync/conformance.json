      "id": "using-syntax-disposes-on-block-exit",
      "description": "The using declaration syntax calls Symbol.dispose when control exits the block.",
      "kind": "script",
      "test": "(()=>{try{const fn=new Function('let disposed=false; { using resource = { [Symbol.dispose](){ disposed=true; } }; } return disposed;');return fn()===true;}catch(_){return false;}})()",
      "specSection": "https://tc39.es/proposal-explicit-resource-management/#sec-using-declarations"
    },
    {
      "id": "disposable-stack-defer-runs",
      "description": "DisposableStack.defer registers a callback that runs when dispose is called.",
      "kind": "script",
      "test": "(()=>{let called=false;const stack=new DisposableStack();stack.defer(()=>{called=true;});stack.dispose();return called;})()",
      "specSection": "https://tc39.es/proposal-explicit-resource-management/#sec-disposablestack.prototype.defer"
    },
    {
      "id": "disposable-stack-disposes-once",
      "description": "DisposableStack.dispose is idempotent and does not run deferred callbacks twice.",
      "kind": "script",
      "test": "(()=>{let count=0;const stack=new DisposableStack();stack.defer(()=>{count++;});stack.dispose();stack.dispose();return count===1;})()",
