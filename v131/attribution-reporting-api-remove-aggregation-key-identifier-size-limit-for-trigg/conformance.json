      "kind": "script",
      "test": "'attributionSrc' in HTMLAnchorElement.prototype"
    },
    {
      "id": "attribution-src-attribute-on-img",
      "description": "HTMLImageElement exposes the attributionSrc IDL attribute for trigger registration via pixels.",
      "kind": "script",
      "test": "'attributionSrc' in HTMLImageElement.prototype"
    },
    {
      "id": "attribution-src-attribute-on-script",
      "description": "HTMLScriptElement exposes the attributionSrc IDL attribute for script-driven attribution.",
      "kind": "script",
      "test": "'attributionSrc' in HTMLScriptElement.prototype"
    },
    {
      "id": "fetch-attributionreporting-option-accepted",
      "description": "Request() accepts an attributionReporting RequestInit option without throwing on the option name itself.",
      "kind": "script",
      "test": "(()=>{try{new Request('/',{attributionReporting:{eventSourceEligible:false,triggerEligible:false}});return true;}catch(e){return /attributionReporting/i.test(String(e))?false:true;}})()"
    },
    {
      "id": "no-explicit-key-length-limit-exposed",
      "description": "The API does not expose a numeric constant for aggregation key identifier length, consistent with the spec removing that limit.",
      "kind": "script",
      "test": "!('MAX_AGGREGATION_KEY_IDENTIFIER_LENGTH' in (window.AttributionReporting||{}))"
    }
