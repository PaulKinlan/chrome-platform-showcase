    {
      "id": "text-decoder-still-supports-iso-2022-jp",
      "description": "TextDecoder still decodes 'iso-2022-jp' explicitly — only auto-detection is removed.",
      "kind": "script",
      "test": "(()=>{try{const d=new TextDecoder('iso-2022-jp');return d.encoding==='iso-2022-jp';}catch(e){return false;}})()",
      "specSection": "https://encoding.spec.whatwg.org/"
    },
    {
      "id": "html-parser-defaults-not-iso-2022-jp-without-declaration",
      "description": "An HTML document parsed with no charset declaration is not auto-detected as iso-2022-jp.",
      "kind": "script",
      "test": "(()=>{try{const p=new DOMParser();const d=p.parseFromString('<html><body>x</body></html>','text/html');const cs=(d.characterSet||'').toLowerCase();return cs!=='iso-2022-jp';}catch(e){return false;}})()",
      "specSection": "https://html.spec.whatwg.org/multipage/parsing.html#determining-the-character-encoding"
    },
    {
      "id": "text-decoder-utf8-default",
      "description": "TextDecoder() with no args defaults to utf-8 — the encoding the parser falls back to without a declaration.",
      "kind": "script",
      "test": "(()=>{const d=new TextDecoder();return d.encoding==='utf-8';})()"
    },
    {
      "id": "explicit-meta-charset-still-honored",
      "description": "Explicit <meta charset=iso-2022-jp> remains honored via DOMParser — only auto-detection is removed.",
      "kind": "script",
      "test": "(()=>{try{const p=new DOMParser();const d=p.parseFromString('<html><head><meta charset=\"iso-2022-jp\"></head><body>x</body></html>','text/html');return typeof d.characterSet==='string';}catch(e){return false;}})()"
    }
