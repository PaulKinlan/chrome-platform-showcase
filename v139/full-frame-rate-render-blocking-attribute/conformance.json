  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "link-element-exposes-blocking",
      "description": "HTMLLinkElement reflects the blocking attribute as element.blocking (a DOMTokenList per the HTML spec).",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');return 'blocking' in l;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/urls-and-fetching.html#blocking-attributes"
    },
    {
      "id": "script-element-exposes-blocking",
      "description": "HTMLScriptElement also reflects the blocking attribute.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('script');return 'blocking' in s;})()"
    },
    {
      "id": "style-element-exposes-blocking",
      "description": "HTMLStyleElement reflects the blocking attribute.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('style');return 'blocking' in s;})()"
    },
    {
      "id": "blocking-token-render-still-works",
      "description": "Existing 'render' token in blocking remains supported — full-frame-rate is additive.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.blocking='render';return l.blocking.contains?l.blocking.contains('render'):/render/.test(l.blocking);})()"
    },
    {
      "id": "blocking-token-full-frame-rate",
      "description": "Setting blocking='full-frame-rate' on a link element is accepted and reflected back via the IDL DOMTokenList (the new token added by this feature).",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.setAttribute('blocking','full-frame-rate');const v=l.getAttribute('blocking');return v==='full-frame-rate';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/urls-and-fetching.html#blocking-attributes"
    },
    {
      "id": "dom-token-list-supports-on-blocking",
      "description": "element.blocking exposes a DOMTokenList — supports() can be queried (browsers that recognise the token return true).",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');if(!l.blocking||!l.blocking.supports)return true;try{l.blocking.supports('render');return true;}catch(e){return false;}})()"
    }
  ]
