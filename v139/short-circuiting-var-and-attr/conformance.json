  "specUrl": "https://drafts.csswg.org/css-variables-2/#using-variables",
  "generatedAt": "2026-06-01T08:13:31Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "var-with-fallback-supported",
      "description": "var() with a fallback parses — this is the core syntax the short-circuiting rule applies to.",
      "kind": "css-supports",
      "test": "color: var(--c, red)",
      "specSection": "https://drafts.csswg.org/css-variables-2/#using-variables"
    },
    {
      "id": "attr-with-fallback-supported",
      "description": "attr() with a fallback parses — short-circuiting also applies to attr().",
      "kind": "css-supports",
      "test": "content: attr(data-x, 'default')"
    },
    {
      "id": "defined-var-short-circuits-fallback-evaluation",
      "description": "When --c is defined, the fallback in var(--c, var(--c)) is not evaluated, so a self-referential fallback is allowed and the declaration is valid.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.style.setProperty('--c','green');d.style.color='var(--c, var(--c))';document.body.appendChild(d);const v=getComputedStyle(d).color;d.remove();return /rgb\\(\\s*0\\s*,\\s*128\\s*,\\s*0\\s*\\)/.test(v);})()",
      "specSection": "https://drafts.csswg.org/css-variables-2/#using-variables"
    },
    {
      "id": "var-still-resolves",
      "description": "var() still resolves the defined custom property to its value.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.style.setProperty('--c','rgb(1, 2, 3)');d.style.color='var(--c)';document.body.appendChild(d);const v=getComputedStyle(d).color;d.remove();return /rgb\\(\\s*1\\s*,\\s*2\\s*,\\s*3\\s*\\)/.test(v);})()"
    },
    {
      "id": "var-fallback-still-used-when-undefined",
      "description": "When the custom property is undefined, the fallback is used (this is unchanged by the short-circuiting rule).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.style.color='var(--undef, rgb(4, 5, 6))';document.body.appendChild(d);const v=getComputedStyle(d).color;d.remove();return /rgb\\(\\s*4\\s*,\\s*5\\s*,\\s*6\\s*\\)/.test(v);})()"
    },
    {
      "id": "css-supports-recognises-attr-fallback",
      "description": "CSS.supports recognises attr() with a fallback as parseable syntax.",
      "kind": "script",
      "test": "CSS.supports('content: attr(data-x, \"y\")')"
    }
  ]
}
