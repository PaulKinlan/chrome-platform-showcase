    {
      "id": "json-module-import-application-json",
      "description": "A JSON module import accepts the literal application/json MIME type.",
      "kind": "script",
      "test": "(async()=>{try{const m=await import('data:application/json,%7B%22kind%22%3A%22json%22%7D',{with:{type:'json'}});return m.default.kind==='json';}catch(e){return false;}})()",
      "specSection": "https://mimesniff.spec.whatwg.org/#json-mime-type"
    },
    {
      "id": "json-module-import-text-json",
      "description": "A JSON module import accepts the literal text/json MIME type.",
      "kind": "script",
      "test": "(async()=>{try{const m=await import('data:text/json,%7B%22kind%22%3A%22text-json%22%7D',{with:{type:'json'}});return m.default.kind==='text-json';}catch(e){return false;}})()",
      "specSection": "https://mimesniff.spec.whatwg.org/#json-mime-type"
    },
    {
      "id": "json-module-import-application-ld-json",
      "description": "A JSON module import accepts a structured-syntax suffix type such as application/ld+json.",
      "kind": "script",
      "test": "(async()=>{try{const m=await import('data:application/ld+json,%7B%22kind%22%3A%22ld%22%7D',{with:{type:'json'}});return m.default.kind==='ld';}catch(e){return false;}})()",
      "specSection": "https://mimesniff.spec.whatwg.org/#json-mime-type"
    },
    {
      "id": "json-module-import-image-svg-json",
      "description": "The JSON MIME algorithm is broad: any type whose subtype ends in +json, such as image/svg+json, is treated as JSON.",
      "kind": "script",
      "test": "(async()=>{try{const m=await import('data:image/svg+json,%7B%22kind%22%3A%22svg-json%22%7D',{with:{type:'json'}});return m.default.kind==='svg-json';}catch(e){return false;}})()",
      "specSection": "https://mimesniff.spec.whatwg.org/#json-mime-type"
    },
    {
      "id": "json-module-import-uppercase-parameterized-json",
      "description": "JSON MIME matching lowercases the essence and strips parameters, so Application/Problem+JSON; charset=UTF-8 imports as JSON.",
      "kind": "script",
      "test": "(async()=>{try{const m=await import('data:Application/Problem+JSON;charset=UTF-8,%7B%22kind%22%3A%22problem%22%7D',{with:{type:'json'}});return m.default.kind==='problem';}catch(e){return false;}})()",
      "specSection": "https://mimesniff.spec.whatwg.org/#mime-type-essence"
