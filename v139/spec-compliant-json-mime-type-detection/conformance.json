  "assertions": [
    {
      "id": "blob-with-application-json",
      "description": "Constructing a Blob with type 'application/json' is accepted; this is the traditional JSON MIME type.",
      "kind": "script",
      "test": "(()=>{const b=new Blob(['{}'],{type:'application/json'});return b.type==='application/json';})()"
    },
    {
      "id": "blob-with-suffix-json",
      "description": "Constructing a Blob with a +json structured-suffix type like 'application/ld+json' preserves the type — the v139 detector treats this as JSON per mimesniff.",
      "kind": "script",
      "test": "(()=>{const b=new Blob(['{}'],{type:'application/ld+json'});return b.type==='application/ld+json';})()",
      "specSection": "https://mimesniff.spec.whatwg.org/#json-mime-type"
    },
    {
      "id": "fetch-response-json-method",
      "description": "Response.prototype.json exists; the JSON MIME detector decides whether resources are decoded by this method.",
      "kind": "typeof",
      "test": "Response.prototype.json",
      "expect": "function"
    },
    {
      "id": "response-text-method",
      "description": "Response.prototype.text exists — the alternative decode path when MIME type is not JSON.",
      "kind": "typeof",
      "test": "Response.prototype.text",
      "expect": "function"
    },
    {
      "id": "response-with-suffix-json-body-parses",
      "description": "A Response constructed with body '{\"a\":1}' and type 'application/ld+json' resolves response.json() to the parsed object — proving +json subtypes are now treated as JSON.",
      "kind": "script",
      "test": "(async()=>{try{const r=new Response('{\"a\":1}',{headers:{'content-type':'application/ld+json'}});const j=await r.json();return j.a===1;}catch(e){return false;}})()",
      "specSection": "https://mimesniff.spec.whatwg.org/#json-mime-type"
    },
    {
      "id": "text-json-still-detected",
      "description": "'text/json' is also detected as JSON per the mimesniff algorithm.",
      "kind": "script",
      "test": "(async()=>{try{const r=new Response('1',{headers:{'content-type':'text/json'}});const j=await r.json();return j===1;}catch(e){return false;}})()"
    }
  ]
}
