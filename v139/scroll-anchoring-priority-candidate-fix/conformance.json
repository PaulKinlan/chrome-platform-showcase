      "kind": "script",
      "test": "(()=>new Promise(resolve=>{const host=document.createElement('div');host.style.cssText='position:fixed;left:0;top:0;width:260px;height:130px;overflow:auto;overflow-anchor:auto;opacity:0;pointer-events:none;z-index:-1;';const inner=document.createElement('div');const before=document.createElement('div');before.style.cssText='height:190px;overflow-anchor:none;';const edit=document.createElement('div');edit.contentEditable='true';edit.textContent='focused editable anchor';edit.style.cssText='height:36px;overflow-anchor:auto;';const after=document.createElement('div');after.style.height='430px';inner.append(before,edit,after);host.append(inner);document.body.append(host);host.scrollTop=edit.offsetTop-45;edit.focus();requestAnimationFrame(()=>{const baseTop=edit.getBoundingClientRect().top-host.getBoundingClientRect().top;const baseScroll=host.scrollTop;const block=document.createElement('div');block.style.cssText='height:72px;overflow-anchor:none;';inner.insertBefore(block,before);requestAnimationFrame(()=>requestAnimationFrame(()=>{const moved=Math.abs((edit.getBoundingClientRect().top-host.getBoundingClientRect().top)-baseTop);const adjusted=host.scrollTop-baseScroll;host.remove();resolve(moved<4&&adjusted>48);}));});}))()",
