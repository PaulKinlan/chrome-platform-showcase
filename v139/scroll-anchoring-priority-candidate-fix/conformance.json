      "description": "With overflow-anchor:auto, inserting content above a visible target preserves that target's position by adjusting scrollTop.",
      "kind": "script",
      "test": "(()=>new Promise(resolve=>{const host=document.createElement('div');host.style.cssText='position:fixed;left:0;top:0;width:240px;height:120px;overflow:auto;overflow-anchor:auto;opacity:0;pointer-events:none;z-index:-1;';const inner=document.createElement('div');const before=document.createElement('div');before.style.cssText='height:180px;overflow-anchor:none;';const target=document.createElement('div');target.textContent='anchor target';target.style.cssText='height:32px;overflow-anchor:auto;';const after=document.createElement('div');after.style.height='420px';inner.append(before,target,after);host.append(inner);document.body.append(host);host.scrollTop=target.offsetTop-40;requestAnimationFrame(()=>{const baseTop=target.getBoundingClientRect().top-host.getBoundingClientRect().top;const baseScroll=host.scrollTop;const block=document.createElement('div');block.style.cssText='height:64px;overflow-anchor:none;';inner.insertBefore(block,before);requestAnimationFrame(()=>requestAnimationFrame(()=>{const moved=Math.abs((target.getBoundingClientRect().top-host.getBoundingClientRect().top)-baseTop);const adjusted=host.scrollTop-baseScroll;host.remove();resolve(moved<4&&adjusted>40);}));});}))()",
      "specSection": "https://drafts.csswg.org/css-scroll-anchoring-1/#description"
    },
    {
      "id": "none-opt-out-allows-visible-target-to-move",
      "description": "With overflow-anchor:none, inserting content above a visible target does not compensate the scroll position.",
      "kind": "script",
      "test": "(()=>new Promise(resolve=>{const host=document.createElement('div');host.style.cssText='position:fixed;left:0;top:0;width:240px;height:120px;overflow:auto;overflow-anchor:none;opacity:0;pointer-events:none;z-index:-1;';const inner=document.createElement('div');const before=document.createElement('div');before.style.height='180px';const target=document.createElement('div');target.textContent='anchor target';target.style.height='32px';const after=document.createElement('div');after.style.height='420px';inner.append(before,target,after);host.append(inner);document.body.append(host);host.scrollTop=target.offsetTop-40;requestAnimationFrame(()=>{const baseTop=target.getBoundingClientRect().top-host.getBoundingClientRect().top;const baseScroll=host.scrollTop;const block=document.createElement('div');block.style.height='64px';inner.insertBefore(block,before);requestAnimationFrame(()=>requestAnimationFrame(()=>{const moved=(target.getBoundingClientRect().top-host.getBoundingClientRect().top)-baseTop;const adjusted=host.scrollTop-baseScroll;host.remove();resolve(moved>40&&Math.abs(adjusted)<4);}));});}))()",
