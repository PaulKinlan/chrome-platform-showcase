  "assertions": [
    {
      "id": "identitycredential-exposed",
      "description": "IdentityCredential is exposed globally; it is the credential type FedCM produces.",
      "kind": "exists",
      "test": "IdentityCredential"
    },
    {
      "id": "credentials-get-accepts-identity",
      "description": "navigator.credentials.get accepts an 'identity' member describing the FedCM request.",
      "kind": "script",
      "test": "(()=>{try{const p=navigator.credentials.get({identity:{providers:[]},signal:AbortSignal.abort()});p.catch(()=>{});return p instanceof Promise;}catch(e){return false;}})()"
    },
    {
      "id": "identityprovider-config-fields",
      "description": "The IdentityProviderRequestOptions dictionary accepts a 'fields' member listing account fields to disclose (name, email, picture, phone, username).",
      "kind": "script",
      "test": "(()=>{try{const p=navigator.credentials.get({identity:{providers:[{configURL:'https://example/config.json',clientId:'x',fields:['name','phone','username']}]},signal:AbortSignal.abort()});p.catch(()=>{});return p instanceof Promise;}catch(e){return false;}})()"
    },
    {
      "id": "credentials-store-exists",
      "description": "navigator.credentials.store remains the storage path for credential types; the surface persists alongside FedCM.",
      "kind": "script",
      "test": "!!navigator.credentials && typeof navigator.credentials.store==='function'",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "fedcm-requires-secure-context",
      "description": "isSecureContext is exposed; FedCM is restricted to secure contexts per spec.",
      "kind": "script",
      "test": "typeof isSecureContext==='boolean'",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "abort-signal-supported",
      "description": "AbortSignal exists so callers can abort an in-flight identity request, as the spec requires.",
      "kind": "exists",
      "test": "AbortSignal",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
}
