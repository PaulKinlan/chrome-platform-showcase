{
  "release": "v141",
  "featureSlug": "stop-sending-purpose-prefetch-header-from-prefetches-and-prerenders",
  "chromestatusId": 5088012836536320,
  "specUrl": "https://wicg.github.io/nav-speculation/prerendering.html#interaction-with-fetch",
  "generatedAt": "2026-06-01T08:13:08Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "sec-purpose-header-readable",
      "description": "Headers API can hold a Sec-Purpose value; Sec-Purpose is the replacement header that prefetches/prerenders continue to send.",
      "kind": "script",
      "test": "(()=>{const h=new Headers({'sec-purpose':'prefetch'});return h.get('sec-purpose')==='prefetch';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "link-rel-prefetch-supported",
      "description": "HTMLLinkElement.rel can be set to 'prefetch'; the removed header was previously attached to these fetches.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.rel='prefetch';return l.rel==='prefetch';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "speculation-rules-script-type",
      "description": "<script type=\"speculationrules\"> is recognised; the legacy Purpose header was also sent on speculation-rules fetches before the removal.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('script');s.type='speculationrules';return s.type==='speculationrules';})()"
    },
    {
      "id": "fetch-with-headers-init",
      "description": "fetch accepts a headers init; servers detect the new world by reading Sec-Purpose, not Purpose.",
      "kind": "script",
      "test": "(()=>{try{const r=new Request('https://example.com/',{headers:{'x-probe':'1'}});return r.headers.get('x-probe')==='1';}catch(e){return false;}})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "document-prerendering",
      "description": "document.prerendering is exposed; prerendered documents are the scope of the header change.",
      "kind": "script",
      "test": "'prerendering' in document"
    },
    {
      "id": "purpose-prefetch-string-is-not-special",
      "description": "Headers can still carry a custom 'purpose' value; the change is browser-side (not sending it automatically), not a Headers API change.",
      "kind": "script",
      "test": "(()=>{const h=new Headers({'purpose':'prefetch'});return h.get('purpose')==='prefetch';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
}
