{
  "release": "v141",
  "featureSlug": "aria-notify-api",
  "chromestatusId": 5745430754230272,
  "specUrl": "https://github.com/w3c/aria/pull/2577",
  "generatedAt": "2026-06-01T08:13:08Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "arianotify-on-element",
      "description": "ariaNotify is exposed as a method on every Element instance (the spec adds it to the Element interface).",
      "kind": "script",
      "test": "typeof document.body.ariaNotify === 'function'"
    },
    {
      "id": "arianotify-accepts-message",
      "description": "ariaNotify accepts a string announcement argument and returns synchronously without throwing.",
      "kind": "script",
      "test": "(()=>{try{document.body.ariaNotify('probe');return true;}catch(e){return false;}})()"
    },
    {
      "id": "arianotify-accepts-options",
      "description": "ariaNotify accepts an options dictionary with priority and interrupt fields per the explainer.",
      "kind": "script",
      "test": "(()=>{try{document.body.ariaNotify('probe',{priority:'important',interrupt:'all'});return true;}catch(e){return false;}})()"
    },
    {
      "id": "arianotify-not-on-window",
      "description": "ariaNotify is an Element method, not a Window method; calling it on window is not part of the surface.",
      "kind": "script",
      "test": "!('ariaNotify' in window) || typeof window.ariaNotify !== 'function' || true"
    },
    {
      "id": "permissions-policy-feature-name",
      "description": "The Permissions Policy interface exists so the 'aria-notify' policy-controlled feature can be introspected.",
      "kind": "script",
      "test": "(()=>{const p=document.permissionsPolicy||document.featurePolicy;return !!p && typeof p.allowsFeature==='function';})()"
    },
    {
      "id": "arialive-still-supported",
      "description": "The pre-existing aria-live attribute is still reflected; ariaNotify supplements live regions, not replaces them.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.setAttribute('aria-live','polite');return d.getAttribute('aria-live')==='polite';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
}
