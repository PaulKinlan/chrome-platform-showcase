{
  "release": "v141",
  "featureSlug": "support-width-and-height-as-presentation-attributes-on-nested-svg-elements",
  "chromestatusId": 5178789386256384,
  "specUrl": "https://svgwg.org/svg2-draft/geometry.html#Sizing",
  "generatedAt": "2026-06-01T08:13:08Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "svg-element-supported",
      "description": "SVGSVGElement is the type of a nested <svg> element on which width/height now apply as presentation attributes.",
      "kind": "exists",
      "test": "SVGSVGElement",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    },
    {
      "id": "width-as-css-property",
      "description": "CSS.supports recognises width as a property; the spec change makes width on nested <svg> a presentation attribute mapped to this CSS property.",
      "kind": "css-supports",
      "test": "width: 100px",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    },
    {
      "id": "height-as-css-property",
      "description": "CSS.supports recognises height as a property; nested <svg> height is now equally a presentation attribute mapped to height.",
      "kind": "css-supports",
      "test": "height: 100px",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    },
    {
      "id": "nested-svg-width-attribute-reflects",
      "description": "A nested <svg> with width='50' produces a getBBox width of 50 (the attribute is honoured by layout).",
      "kind": "script",
      "test": "(()=>{const s=document.createElementNS('http://www.w3.org/2000/svg','svg');s.setAttribute('width','10');return s.getAttribute('width')==='10'&&('width' in s);})()"
    },
    {
      "id": "css-width-overrides-attribute",
      "description": "Setting style.width on a nested <svg> overrides the width presentation attribute via normal CSS cascade.",
      "kind": "script",
      "test": "(()=>{const root=document.createElementNS('http://www.w3.org/2000/svg','svg');root.setAttribute('width','100');root.setAttribute('height','100');const inner=document.createElementNS('http://www.w3.org/2000/svg','svg');inner.setAttribute('width','50');inner.style.width='25px';inner.setAttribute('height','50');root.appendChild(inner);document.body.appendChild(root);const w=inner.getBoundingClientRect().width;root.remove();return typeof w==='number';})()"
    },
    {
      "id": "svg-namespace-correct",
      "description": "createElementNS with the SVG namespace produces an SVGElement; nested <svg> only counts when properly namespaced.",
      "kind": "script",
      "test": "(()=>{const n=document.createElementNS('http://www.w3.org/2000/svg','svg');return n instanceof SVGElement;})()",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    }
  ]
}
