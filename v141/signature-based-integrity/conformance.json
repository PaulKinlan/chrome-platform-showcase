    {
      "id": "integrity-attribute-on-script",
      "description": "HTMLScriptElement.integrity is reflected; signature-based SRI extends the integrity attribute's grammar to accept ed25519-... values.",
      "kind": "script",
      "test": "'integrity' in document.createElement('script')",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "integrity-attribute-on-link",
      "description": "HTMLLinkElement.integrity is reflected; signature-based SRI applies to stylesheets and modules loaded via <link>.",
      "kind": "script",
      "test": "'integrity' in document.createElement('link')",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "subtlecrypto-ed25519",
      "description": "crypto.subtle.verify exists; ed25519 verification is the algorithm signature-based SRI specifies.",
      "kind": "script",
      "test": "!!(self.crypto && self.crypto.subtle && typeof self.crypto.subtle.verify==='function')",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "request-integrity-init",
      "description": "Request supports the integrity init member; signature-based integrity also flows through fetch().",
      "kind": "script",
      "test": "(()=>{try{const r=new Request('https://example.com/',{integrity:'sha256-AAAA'});return r.integrity==='sha256-AAAA';}catch(e){return false;}})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "securitypolicyviolation-for-sri",
      "description": "SecurityPolicyViolationEvent is exposed; failed signature verification reports through the same event channel as CSP/SRI violations.",
      "kind": "exists",
      "test": "SecurityPolicyViolationEvent",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "secure-context-required",
      "description": "isSecureContext is exposed; signature-based SRI applies in secure contexts.",
      "kind": "script",
      "test": "typeof isSecureContext==='boolean'",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
