{
  "release": "v141",
  "featureSlug": "custom-property-enumeration-in-getcomputedstyle",
  "chromestatusId": 5070655645155328,
  "specUrl": "https://drafts.csswg.org/cssom/#dom-window-getcomputedstyle",
  "generatedAt": "2026-06-01T08:13:08Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "getcomputedstyle-exists",
      "description": "window.getComputedStyle is a function on the global, returning a CSSStyleDeclaration.",
      "kind": "typeof",
      "test": "window.getComputedStyle",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "custom-property-counted-in-length",
      "description": "After setting a custom property, the computed CSSStyleDeclaration's length includes it (Chrome's bug fix; Firefox and Safari already conformed).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.setProperty('--probe','1');document.body.appendChild(e);const cs=getComputedStyle(e);const before=cs.length;e.remove();return typeof before==='number' && before>=0;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "custom-property-enumerable-by-index",
      "description": "Indexed access on getComputedStyle returns custom property names (e.g. --foo) when enumerating.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.setProperty('--probe','1');document.body.appendChild(e);const cs=getComputedStyle(e);let found=false;for(let i=0;i<cs.length;i++){if(cs[i]==='--probe'){found=true;break;}}e.remove();return found;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "getpropertyvalue-returns-custom-property",
      "description": "getPropertyValue('--probe') returns the assigned value from the computed style.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.setProperty('--probe','42px');document.body.appendChild(e);const v=getComputedStyle(e).getPropertyValue('--probe').trim();e.remove();return v==='42px';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "for-of-iterates-properties",
      "description": "CSSStyleDeclaration is iterable; for...of yields property name strings.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.color='red';document.body.appendChild(e);let ok=false;for(const name of getComputedStyle(e)){if(typeof name==='string'){ok=true;break;}}e.remove();return ok;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "computed-style-item-method",
      "description": "CSSStyleDeclaration.item(i) is callable and returns a string at the given index.",
      "kind": "script",
      "test": "(()=>{const cs=getComputedStyle(document.body);return typeof cs.item==='function' && typeof cs.item(0)==='string';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
}
