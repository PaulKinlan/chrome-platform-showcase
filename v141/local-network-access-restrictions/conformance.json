  "assertions": [
    {
      "id": "fetch-available",
      "description": "fetch is the primary subject of LNA: requests from public sites to private/loopback IPs go through it.",
      "kind": "typeof",
      "test": "fetch",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "permissions-api-exists",
      "description": "navigator.permissions exists so the local-network-access permission can be queried by sites that need it.",
      "kind": "script",
      "test": "!!navigator.permissions && typeof navigator.permissions.query==='function'",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "request-target-address-space",
      "description": "Request supports the targetAddressSpace init member used by LNA to declare the request's intended address space.",
      "kind": "script",
      "test": "(()=>{try{const r=new Request('https://example.com/',{targetAddressSpace:'private'});return r instanceof Request;}catch(e){return false;}})()"
    },
    {
      "id": "secure-context-required",
      "description": "isSecureContext is exposed; LNA restricts loopback/private requests from secure top-level contexts.",
      "kind": "script",
      "test": "typeof isSecureContext==='boolean'",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "abortcontroller-supported",
      "description": "AbortController is available so a slow LNA preflight + permission grant can be aborted.",
      "kind": "exists",
      "test": "AbortController",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "fetch-mode-cors-supported",
      "description": "fetch accepts mode:'cors'; LNA layers on top of CORS preflight, not in place of it.",
      "kind": "script",
      "test": "(()=>{try{const r=new Request('https://example.com/',{mode:'cors'});return r.mode==='cors';}catch(e){return false;}})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
}
