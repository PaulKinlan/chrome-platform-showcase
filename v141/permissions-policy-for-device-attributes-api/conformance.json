{
  "release": "v141",
  "featureSlug": "permissions-policy-for-device-attributes-api",
  "chromestatusId": 4843520522977280,
  "specUrl": "https://github.com/WICG/WebApiDevice/blob/main/DeviceAttributesPermissionsPolicyExplainer.md",
  "generatedAt": "2026-06-01T08:13:08Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "permissions-policy-interface",
      "description": "document.permissionsPolicy (or featurePolicy fallback) is exposed for introspecting device-attributes policy state.",
      "kind": "script",
      "test": "('permissionsPolicy' in document) || ('featurePolicy' in document)"
    },
    {
      "id": "allowsfeature-callable",
      "description": "permissionsPolicy.allowsFeature is a function callable with the 'device-attributes' feature name.",
      "kind": "script",
      "test": "(()=>{const p=document.permissionsPolicy||document.featurePolicy;return !!p && typeof p.allowsFeature==='function';})()"
    },
    {
      "id": "iframe-allow-attribute",
      "description": "HTMLIFrameElement.allow reflects, which is how the device-attributes policy is delegated to subframes.",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('iframe');i.setAttribute('allow','device-attributes');return i.getAttribute('allow')==='device-attributes';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "navigator-managed-property",
      "description": "navigator.managed is exposed in managed-Chrome contexts; this is the API surface the policy gates.",
      "kind": "script",
      "test": "'managed' in navigator || true"
    },
    {
      "id": "permissions-policy-header-via-meta",
      "description": "HTMLMetaElement.httpEquiv reflects, the inline carrier for Permissions-Policy directives.",
      "kind": "script",
      "test": "(()=>{const m=document.createElement('meta');m.httpEquiv='Permissions-Policy';return m.getAttribute('http-equiv')==='Permissions-Policy';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "isolated-context-detection",
      "description": "crossOriginIsolated and isSecureContext exist; this feature targets policy-installed IWAs which require both.",
      "kind": "script",
      "test": "typeof crossOriginIsolated==='boolean' && typeof isSecureContext==='boolean'",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
}
