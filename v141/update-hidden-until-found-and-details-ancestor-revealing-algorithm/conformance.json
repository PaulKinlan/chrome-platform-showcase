{
  "release": "v141",
  "featureSlug": "update-hidden-until-found-and-details-ancestor-revealing-algorithm",
  "chromestatusId": 5179013869993984,
  "specUrl": "https://html.spec.whatwg.org/multipage/interaction.html#the-hidden-attribute",
  "generatedAt": "2026-06-01T08:13:08Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "hidden-attribute-reflects",
      "description": "HTMLElement.hidden reflects the hidden content attribute; 'until-found' is a value the revealing algorithm operates on.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.setAttribute('hidden','until-found');return e.getAttribute('hidden')==='until-found';})()"
    },
    {
      "id": "details-element-exists",
      "description": "HTMLDetailsElement is exposed; its open attribute is toggled by the revealing algorithm when content inside is targeted.",
      "kind": "exists",
      "test": "HTMLDetailsElement",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "details-open-reflects",
      "description": "HTMLDetailsElement.open reflects the open attribute; the revealing algorithm sets this on ancestors.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('details');d.open=true;return d.hasAttribute('open');})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "beforematch-event-supported",
      "description": "The 'beforematch' event is fired on elements when hidden=until-found content is about to be revealed by find-in-page.",
      "kind": "script",
      "test": "'onbeforematch' in document.createElement('div')"
    },
    {
      "id": "element-scrollintoview",
      "description": "Element.prototype.scrollIntoView exists; the revealing algorithm uses scroll-into-view as part of bringing content into the viewport.",
      "kind": "typeof",
      "test": "Element.prototype.scrollIntoView",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "scrollintoviewifneeded-no-infinite-loop",
      "description": "Calling scrollIntoView on a deeply nested hidden=until-found target returns synchronously without entering an infinite loop (the spec change's stated motivation).",
      "kind": "script",
      "test": "(()=>{const outer=document.createElement('details');const inner=document.createElement('div');inner.setAttribute('hidden','until-found');outer.appendChild(inner);document.body.appendChild(outer);try{inner.scrollIntoView();const ok=true;outer.remove();return ok;}catch(e){outer.remove();return false;}})()"
    }
  ]
}
