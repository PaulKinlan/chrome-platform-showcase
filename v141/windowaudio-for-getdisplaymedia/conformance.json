  "assertions": [
    {
      "id": "getdisplaymedia-exists",
      "description": "navigator.mediaDevices.getDisplayMedia is the entry point on which the windowAudio option is accepted.",
      "kind": "script",
      "test": "!!navigator.mediaDevices && typeof navigator.mediaDevices.getDisplayMedia==='function'"
    },
    {
      "id": "windowaudio-accepts-exclude",
      "description": "getDisplayMedia accepts { windowAudio: 'exclude' } in its DisplayMediaStreamOptions without TypeError at the dictionary layer.",
      "kind": "script",
      "test": "(()=>{try{const p=navigator.mediaDevices.getDisplayMedia({windowAudio:'exclude'});p.catch(()=>{});return p instanceof Promise;}catch(e){return e.name!=='TypeError';}})()"
    },
    {
      "id": "windowaudio-accepts-system",
      "description": "getDisplayMedia accepts windowAudio: 'system' (one of the three valid enum values per the spec).",
      "kind": "script",
      "test": "(()=>{try{const p=navigator.mediaDevices.getDisplayMedia({windowAudio:'system'});p.catch(()=>{});return p instanceof Promise;}catch(e){return e.name!=='TypeError';}})()"
    },
    {
      "id": "windowaudio-accepts-window",
      "description": "getDisplayMedia accepts windowAudio: 'window' (the third enum value).",
      "kind": "script",
      "test": "(()=>{try{const p=navigator.mediaDevices.getDisplayMedia({windowAudio:'window'});p.catch(()=>{});return p instanceof Promise;}catch(e){return e.name!=='TypeError';}})()"
    },
    {
      "id": "mediastream-getaudiotracks",
      "description": "MediaStream.prototype.getAudioTracks exists; the negotiated windowAudio behaviour surfaces as the presence or absence of an audio track.",
      "kind": "typeof",
      "test": "MediaStream.prototype.getAudioTracks",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "permissions-policy-display-capture",
      "description": "PermissionsPolicy / featurePolicy interface is available to introspect display-capture, the gate for getDisplayMedia.",
      "kind": "script",
      "test": "(()=>{const p=document.permissionsPolicy||document.featurePolicy;return !!p && typeof p.allowsFeature==='function';})()"
    }
  ]
