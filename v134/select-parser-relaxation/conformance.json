{
  "release": "v134",
  "featureSlug": "select-parser-relaxation",
  "chromestatusId": 5145948356083712,
  "specUrl": "https://github.com/whatwg/html/pull/10557",
  "generatedAt": "2026-06-01T08:30:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "select-allows-div-child",
      "description": "Parser allows a <div> inside <select> (relaxation: previously stripped to text).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.innerHTML='<select><option>x<div>nested</div></option></select>';return d.querySelector('select option div')!==null;})()"
    },
    {
      "id": "select-allows-span-child",
      "description": "<span> inside <select><option> is preserved.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.innerHTML='<select><option><span>x</span></option></select>';return d.querySelector('select option span')!==null;})()"
    },
    {
      "id": "select-allows-hr-child",
      "description": "<hr> inside <select> is preserved as a separator element.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.innerHTML='<select><option>a</option><hr><option>b</option></select>';return d.querySelector('select hr')!==null;})()"
    },
    {
      "id": "selectedcontent-allowed",
      "description": "<selectedcontent> is preserved inside <select> (relaxed parser keeps the new element).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.innerHTML='<select><selectedcontent></selectedcontent><option>x</option></select>';return d.querySelector('select selectedcontent')!==null;})()"
    },
    {
      "id": "select-options-still-populates",
      "description": "Despite the relaxed parser, select.options still enumerates only <option> elements.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.innerHTML='<select><option>a</option><hr><option>b</option></select>';return d.querySelector('select').options.length===2;})()"
    }
  ]
}
