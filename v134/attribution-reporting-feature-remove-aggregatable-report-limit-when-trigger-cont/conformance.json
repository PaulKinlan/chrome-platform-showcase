  "assertions": [
    {
      "id": "server-route-non-empty-context-uncaps",
      "description": "A trigger registration with a non-empty trigger_context_id is accepted without the 20-report cap.",
      "kind": "script",
      "test": "(async()=>{const registration={aggregatable_trigger_data:[{key_piece:'0x1',source_keys:['cart']}],aggregatable_values:{cart:1},trigger_data:1,trigger_context_id:'ctx-1'};const r=await fetch('../trigger-context-id-builder/register-trigger',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({registration,conversionCount:35})});const j=await r.json();return r.ok&&j.acceptedReports===35&&j.droppedReports===0&&j.triggerContextIdPresent===true&&r.headers.get('Attribution-Reporting-Register-Trigger')?.includes('trigger_context_id');})()",
      "specSection": "https://wicg.github.io/attribution-reporting-api/#trigger-context-id"
    },
    {
      "id": "server-route-empty-context-remains-capped",
      "description": "An empty trigger_context_id string does not lift the per-source report cap.",
      "kind": "script",
      "test": "(async()=>{const registration={aggregatable_trigger_data:[{key_piece:'0x1',source_keys:['cart']}],aggregatable_values:{cart:1},trigger_data:1,trigger_context_id:''};const r=await fetch('../trigger-context-id-builder/register-trigger',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({registration,conversionCount:35})});const j=await r.json();return r.ok&&j.acceptedReports===20&&j.droppedReports===15&&j.triggerContextIdPresent===false;})()",
      "specSection": "https://wicg.github.io/attribution-reporting-api/#trigger-context-id"
    },
    {
      "id": "server-route-omitted-context-remains-capped",
      "description": "Omitting trigger_context_id keeps the legacy 20-report cap in force.",
      "kind": "script",
      "test": "(async()=>{const registration={aggregatable_trigger_data:[{key_piece:'0x1',source_keys:['cart']}],aggregatable_values:{cart:1},trigger_data:1};const r=await fetch('../trigger-context-id-builder/register-trigger',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({registration,conversionCount:35})});const j=await r.json();return r.ok&&j.acceptedReports===20&&j.droppedReports===15&&j.triggerContextIdPresent===false;})()",
      "specSection": "https://wicg.github.io/attribution-reporting-api/#trigger-context-id"
    },
    {
      "id": "server-route-invalid-key-piece-rejected",
      "description": "A key_piece that is not 0x/0X plus ASCII hex digits is rejected before a response header is emitted.",
      "kind": "script",
      "test": "(async()=>{const registration={aggregatable_trigger_data:[{key_piece:'not-hex',source_keys:['cart']}],aggregatable_values:{cart:1},trigger_data:1,trigger_context_id:'ctx-1'};const r=await fetch('../trigger-context-id-builder/register-trigger',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({registration,conversionCount:35})});const j=await r.json();return r.status===400&&Array.isArray(j.validationErrors)&&j.validationErrors.some(e=>e.includes('key_piece'));})()",
      "specSection": "https://wicg.github.io/attribution-reporting-api/#trigger-context-id"
    },
    {
      "id": "server-route-header-unsafe-context-rejected",
      "description": "A trigger_context_id that cannot be emitted safely in the HTTP header is rejected with structured JSON rather than a 500.",
      "kind": "script",
      "test": "(async()=>{const registration={aggregatable_trigger_data:[{key_piece:'0x1',source_keys:['cart']}],aggregatable_values:{cart:1},trigger_data:1,trigger_context_id:'ctx-with-emoji-🎯'};const r=await fetch('../trigger-context-id-builder/register-trigger',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({registration,conversionCount:35})});const j=await r.json();return r.status===400&&Array.isArray(j.validationErrors)&&j.validationErrors.some(e=>e.includes('printable ASCII'));})()",
      "specSection": "https://wicg.github.io/attribution-reporting-api/#trigger-context-id"
    }
