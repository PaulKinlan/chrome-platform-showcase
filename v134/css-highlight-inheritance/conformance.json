    {
      "id": "highlight-pseudo-with-name",
      "description": "Named custom highlights ::highlight(name) parse — the feature includes them in the highlight inheritance tree.",
      "kind": "css-supports",
      "test": "selector(::highlight(foo))"
    },
    {
      "id": "selection-color-inherits",
      "description": "::selection color set on an ancestor is inherited into a descendant's ::selection (the core behaviour shipped).",
      "kind": "script",
      "test": "(()=>{const sheet=new CSSStyleSheet();sheet.replaceSync('#hl-parent::selection{color:rgb(1,2,3)} #hl-parent *::selection{color:inherit}');document.adoptedStyleSheets=[...document.adoptedStyleSheets,sheet];const a=document.createElement('div');a.id='hl-parent';const b=document.createElement('span');b.textContent='x';a.appendChild(b);document.body.appendChild(a);const ok=getComputedStyle(b,'::selection').color.includes('1, 2, 3');a.remove();document.adoptedStyleSheets=document.adoptedStyleSheets.filter(s=>s!==sheet);return ok;})()"
    },
    {
      "id": "target-text-pseudo",
      "description": "::target-text is also part of the highlight pseudo family covered by the cascade change.",
      "kind": "css-supports",
      "test": "selector(::target-text)"
