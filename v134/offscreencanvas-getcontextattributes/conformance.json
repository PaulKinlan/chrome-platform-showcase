{
  "release": "v134",
  "featureSlug": "offscreencanvas-getcontextattributes",
  "chromestatusId": 5508068999430144,
  "specUrl": "https://html.spec.whatwg.org/multipage/canvas.html#offscreencanvas",
  "generatedAt": "2026-06-01T08:30:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "offscreencanvas-defined",
      "description": "OffscreenCanvas is exposed.",
      "kind": "exists",
      "test": "window.OffscreenCanvas"
    },
    {
      "id": "offscreencanvas-2d-getcontextattributes",
      "description": "An OffscreenCanvas 2D context exposes getContextAttributes() like the on-screen canvas does.",
      "kind": "script",
      "test": "(()=>{const c=new OffscreenCanvas(8,8);const ctx=c.getContext('2d');return typeof ctx.getContextAttributes==='function';})()"
    },
    {
      "id": "offscreencanvas-2d-attrs-alpha",
      "description": "getContextAttributes() returns an object containing alpha.",
      "kind": "script",
      "test": "(()=>{const c=new OffscreenCanvas(8,8);const ctx=c.getContext('2d');const a=ctx.getContextAttributes();return 'alpha' in a;})()"
    },
    {
      "id": "offscreencanvas-2d-attrs-willreadfrequently",
      "description": "willReadFrequently is reflected back from getContextAttributes() when set at context creation.",
      "kind": "script",
      "test": "(()=>{const c=new OffscreenCanvas(8,8);const ctx=c.getContext('2d',{willReadFrequently:true});return ctx.getContextAttributes().willReadFrequently===true;})()"
    },
    {
      "id": "offscreencanvas-2d-attrs-colorspace",
      "description": "colorSpace is reflected — set to 'display-p3' on creation, getContextAttributes returns 'display-p3'.",
      "kind": "script",
      "test": "(()=>{try{const c=new OffscreenCanvas(8,8);const ctx=c.getContext('2d',{colorSpace:'display-p3'});return ctx.getContextAttributes().colorSpace==='display-p3';}catch(e){return false;}})()"
    },
    {
      "id": "offscreencanvas-webgl-getcontextattributes",
      "description": "An OffscreenCanvas WebGL context also exposes getContextAttributes (parity with on-screen WebGLRenderingContext).",
      "kind": "script",
      "test": "(()=>{const c=new OffscreenCanvas(8,8);const ctx=c.getContext('webgl');return !!ctx && typeof ctx.getContextAttributes==='function';})()"
    }
  ]
}
