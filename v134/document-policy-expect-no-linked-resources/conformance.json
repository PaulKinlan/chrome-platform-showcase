    {
      "id": "expect-no-linked-resources-in-features",
      "description": "expect-no-linked-resources is advertised in the supported document policy features list (or absent — both observable states).",
      "kind": "script",
      "test": "(()=>{try{const f=document.featurePolicy.features();return typeof (f.includes('expect-no-linked-resources'))==='boolean';}catch(e){return false;}})()"
    },
