{
  "release": "v134",
  "featureSlug": "dialog-light-dismiss",
  "chromestatusId": 5097714453577728,
  "specUrl": "https://html.spec.whatwg.org/#attr-dialog-closedby",
  "generatedAt": "2026-06-01T08:30:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "dialog-closedby-idl",
      "description": "HTMLDialogElement exposes a closedBy IDL attribute reflecting the closedby content attribute.",
      "kind": "exists",
      "test": "HTMLDialogElement.prototype.closedBy"
    },
    {
      "id": "dialog-closedby-any-roundtrip",
      "description": "Setting closedBy='any' reflects to the content attribute (light-dismiss enabled).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('dialog');d.closedBy='any';return d.getAttribute('closedby')==='any';})()"
    },
    {
      "id": "dialog-closedby-closerequest",
      "description": "closedBy accepts 'closerequest' (Esc / OS close request only).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('dialog');d.closedBy='closerequest';return d.closedBy==='closerequest';})()"
    },
    {
      "id": "dialog-closedby-none",
      "description": "closedBy accepts 'none' to disable Esc and light dismiss entirely (modal stays put).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('dialog');d.closedBy='none';return d.closedBy==='none';})()"
    },
    {
      "id": "dialog-closedby-invalid-defaults",
      "description": "Invalid values are reflected back through the IDL getter as one of the canonical states.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('dialog');d.setAttribute('closedby','garbage');return ['any','closerequest','none','auto',''].includes(d.closedBy);})()"
    },
    {
      "id": "close-watcher-exists",
      "description": "CloseWatcher is exposed — it is the close-request primitive that backs closedBy.",
      "kind": "exists",
      "test": "window.CloseWatcher"
    }
  ]
}
