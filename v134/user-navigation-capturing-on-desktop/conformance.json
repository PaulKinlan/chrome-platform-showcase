{
  "release": "v134",
  "featureSlug": "user-navigation-capturing-on-desktop",
  "chromestatusId": 5183927385587712,
  "specUrl": "https://w3c.github.io/manifest/",
  "generatedAt": "2026-06-01T08:30:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "manifest-link-rel",
      "description": "<link rel=manifest> parses — installed PWAs are the navigation-capture targets.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.rel='manifest';return l.rel==='manifest';})()"
    },
    {
      "id": "service-worker-supported",
      "description": "navigator.serviceWorker is exposed — installed PWAs are SW-backed.",
      "kind": "exists",
      "test": "navigator.serviceWorker"
    },
    {
      "id": "installedrelatedapps-fn",
      "description": "navigator.getInstalledRelatedApps is a function — the API to query installed PWAs from the page.",
      "kind": "typeof",
      "test": "navigator.getInstalledRelatedApps",
      "expect": "function"
    },
    {
      "id": "anchor-target-attribute",
      "description": "HTMLAnchorElement supports target='_blank' — the new capturing rule swaps a top-level nav into a PWA window when the URL is in scope.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('a');a.target='_blank';return a.target==='_blank';})()"
    },
    {
      "id": "anchor-href-supports-launch",
      "description": "The Launch Handler integration relies on URL parsing; anchor href reflects through.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('a');a.href='https://example.com/in-scope';return a.href.startsWith('https://example.com');})()"
    }
  ]
}
