{
  "release": "v134",
  "featureSlug": "customizable-select-element",
  "chromestatusId": 5737365999976448,
  "specUrl": "https://html.spec.whatwg.org/multipage/form-elements.html#the-select-element",
  "generatedAt": "2026-06-01T08:30:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "appearance-base-select",
      "description": "select supports appearance: base-select to opt into the customizable rendering model.",
      "kind": "css-supports",
      "test": "appearance: base-select"
    },
    {
      "id": "selectedcontent-element-defined",
      "description": "<selectedcontent> is a known HTML element (HTMLElement, not HTMLUnknownElement).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('selectedcontent');return e instanceof HTMLElement && !(e instanceof HTMLUnknownElement);})()"
    },
    {
      "id": "select-allows-rich-children",
      "description": "When appearance: base-select is set, a <select> can host arbitrary descendants (div, span) without the parser stripping them.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');s.innerHTML='<option><div><span>x</span></div></option>';return s.querySelector('option div span')!==null;})()"
    },
    {
      "id": "select-popover-attribute",
      "description": "A <select> in base appearance exposes a popover-like picker; the underlying picker uses the popover algorithm so showPicker is callable.",
      "kind": "typeof",
      "test": "HTMLSelectElement.prototype.showPicker",
      "expect": "function"
    },
    {
      "id": "option-base-appearance",
      "description": "appearance: base-select also flows through to <option> so descendant content can be styled.",
      "kind": "css-supports",
      "test": "appearance: base-select"
    },
    {
      "id": "select-still-form-associated",
      "description": "Custom-rendered select is still form-associated — form attribute and name continue to work.",
      "kind": "script",
      "test": "(()=>{const f=document.createElement('form');const s=document.createElement('select');s.name='x';const o=document.createElement('option');o.value='1';o.textContent='1';s.appendChild(o);f.appendChild(s);document.body.appendChild(f);const ok=new FormData(f).get('x')==='1';f.remove();return ok;})()"
    }
  ]
}
