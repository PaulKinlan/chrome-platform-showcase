      "description": "The attributionreporting content attribute on <a> and <img> no longer functions; navigator.attributionReporting is undefined.",
      "kind": "script",
      "test": "typeof navigator.attributionReporting === 'undefined'",
      "specSection": "https://wicg.github.io/attribution-reporting-api"
    },
    {
      "id": "attribution-reporting-fetch-option-rejected",
      "description": "fetch() with an attributionReporting option no longer triggers any registration; the option is silently ignored. Testable: the option name is not enumerated on Request prototype.",
      "kind": "script",
      "test": "!('attributionReporting' in Request.prototype)",
      "specSection": "https://wicg.github.io/attribution-reporting-api"
    },
    {
      "id": "permissions-policy-attribution-reporting-removed",
      "description": "The 'attribution-reporting' permissions-policy feature is no longer enumerated.",
      "kind": "script",
      "test": "(()=>{try{return !document.featurePolicy || !document.featurePolicy.features().includes('attribution-reporting');}catch(e){return true;}})()",
      "specSection": "https://wicg.github.io/attribution-reporting-api"
    },
    {
      "id": "no-window-fence-reporter",
      "description": "window.fence (where attribution events could be reported from a fenced frame) is undefined in normal documents.",
      "kind": "script",
      "test": "typeof window.fence === 'undefined'",
      "specSection": "https://wicg.github.io/attribution-reporting-api"
    }
