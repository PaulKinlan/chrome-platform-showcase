{
  "release": "v144",
  "featureSlug": "web-app-manifest-specify-update-eligibility-icon-urls-are-cache-control-immutabl",
  "chromestatusId": 5148463647686656,
  "specUrl": "https://www.w3.org/TR/appmanifest/#updating",
  "generatedAt": "2026-06-01T08:03:56Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "manifest-link-rel-still-supported",
      "description": "<link rel=\"manifest\"> remains the entry point; HTMLLinkElement reflects rel.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.rel='manifest';l.href='/manifest.webmanifest';return l.rel==='manifest';})()",
      "specSection": "https://www.w3.org/TR/appmanifest/#linking"
    },
    {
      "id": "manifest-content-type",
      "description": "The manifest type is application/manifest+json; <link> accepts the type attribute reflecting it.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.rel='manifest';l.type='application/manifest+json';return l.type==='application/manifest+json';})()",
      "specSection": "https://www.w3.org/TR/appmanifest/#processing-the-manifest"
    },
    {
      "id": "no-update-eligibility-script-api",
      "description": "The update eligibility behaviour is server-driven via Cache-Control: immutable on icon URLs — there is no JavaScript API change. Test: there is no document.installedAppUpdateEligibility hook.",
      "kind": "script",
      "test": "!('installedAppUpdateEligibility' in document) && !('manifestUpdateEligibility' in navigator)",
      "specSection": "https://www.w3.org/TR/appmanifest/#updating"
    },
    {
      "id": "manifest-link-href-readable",
      "description": "HTMLLinkElement href is reflected and resolvable.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.rel='manifest';l.href='/m.webmanifest';return l.href.endsWith('/m.webmanifest');})()",
      "specSection": "https://www.w3.org/TR/appmanifest/#linking"
    }
  ]
}
