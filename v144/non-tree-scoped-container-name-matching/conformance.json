      "id": "cross-tree-container-match",
      "description": "A container-name declared in one stylesheet's tree scope matches an @container query authored in a different scope (shadow vs. light). Container queries no longer require same-tree-scope name resolution.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');host.style.cssText='container-type:inline-size;container-name:hostc;width:300px';const shadow=host.attachShadow({mode:'open'});shadow.innerHTML='<style>@container hostc (min-width: 100px) { p { color: rgb(0,128,0) } }</style><p>x</p>';document.body.appendChild(host);const c=getComputedStyle(shadow.querySelector('p')).color;host.remove();return c==='rgb(0, 128, 0)';})()",
      "specSection": "https://drafts.csswg.org/css-conditional-5/#container-name"
