  "featureSlug": "mirroring-of-rtl-mathml-operators",
  "chromestatusId": 6317308531965952,
  "specUrl": "https://w3c.github.io/mathml-core/#layout-of-operators",
  "generatedAt": "2026-06-01T08:03:56Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "math-element-parses",
      "description": "<math> is recognised as MathML and produces a MathMLElement/HTMLElement node.",
      "kind": "script",
      "test": "(()=>{const w=document.createElement('div');w.innerHTML='<math><mo>(</mo></math>';const m=w.firstChild;return m && m.tagName.toLowerCase()==='math';})()",
      "specSection": "https://w3c.github.io/mathml-core/"
    },
    {
      "id": "math-rtl-direction-respected",
      "description": "Setting dir=\"rtl\" on the math element makes computed direction rtl, enabling operator mirroring.",
      "kind": "script",
      "test": "(()=>{const w=document.createElement('div');w.innerHTML='<math dir=\"rtl\"><mo>(</mo></math>';document.body.appendChild(w);const dir=getComputedStyle(w.firstChild).direction;w.remove();return dir==='rtl';})()",
      "specSection": "https://w3c.github.io/mathml-core/#layout-of-operators"
    },
    {
      "id": "math-default-ltr",
      "description": "Without dir, computed direction is ltr and operators are not mirrored.",
      "kind": "script",
      "test": "(()=>{const w=document.createElement('div');w.innerHTML='<math><mo>(</mo></math>';document.body.appendChild(w);const dir=getComputedStyle(w.firstChild).direction;w.remove();return dir==='ltr';})()",
      "specSection": "https://w3c.github.io/mathml-core/#layout-of-operators"
    },
    {
      "id": "mo-renders-as-mathml",
      "description": "<mo> inside <math> is a MathML element, not an HTMLUnknownElement.",
      "kind": "script",
      "test": "(()=>{const w=document.createElement('div');w.innerHTML='<math><mo>(</mo></math>';const mo=w.firstChild && w.firstChild.firstChild;return mo && mo.namespaceURI==='http://www.w3.org/1998/Math/MathML';})()",
      "specSection": "https://w3c.github.io/mathml-core/#layout-of-operators"
    }
  ]
}
