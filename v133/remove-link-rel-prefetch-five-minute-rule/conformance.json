{
  "release": "v133",
  "featureSlug": "remove-link-rel-prefetch-five-minute-rule",
  "chromestatusId": 5087526916718592,
  "specUrl": "https://github.com/whatwg/html/pull/8111",
  "generatedAt": "2026-06-01T08:12:59Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "htmllinkelement-exposed",
      "description": "HTMLLinkElement is exposed; rel=prefetch is processed through it.",
      "kind": "exists",
      "test": "HTMLLinkElement",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    },
    {
      "id": "link-rel-prefetch-accepted",
      "description": "rel='prefetch' is an accepted value on <link>.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.rel='prefetch';return l.rel==='prefetch';})()"
    },
    {
      "id": "link-rellist-supports-prefetch",
      "description": "DOMTokenList relList reports support for 'prefetch' on link elements.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');try{return l.relList.supports('prefetch')===true;}catch(e){return false;}})()"
    },
    {
      "id": "link-href-still-reflects",
      "description": "link.href IDL attribute remains exposed and reflects the resolved URL.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.href='/x';return typeof l.href==='string'&&l.href.endsWith('/x');})()"
    },
    {
      "id": "link-as-attribute-supported",
      "description": "The 'as' content attribute remains exposed via IDL.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');if(!('as' in l))return true;l.as='document';return typeof l.as==='string';})()"
    }
  ]
}
