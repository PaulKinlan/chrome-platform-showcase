      "id": "dialog-closedby-idl",
      "description": "HTMLDialogElement.prototype exposes a closedBy IDL attribute reflecting the closedby content attribute.",
      "kind": "script",
      "test": "'closedBy' in HTMLDialogElement.prototype",
      "specSection": "https://html.spec.whatwg.org/#dom-dialog-closedby"
    },
    {
      "id": "dialog-closedby-default-state",
      "description": "On a fresh <dialog>, closedBy reflects a string value (the default state derived from how the dialog was opened).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('dialog');document.body.appendChild(d);const v=typeof d.closedBy;d.remove();return v==='string';})()"
    },
    {
      "id": "dialog-closedby-any",
      "description": "Setting closedby='any' is reflected through the IDL attribute and remembered.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('dialog');d.setAttribute('closedby','any');document.body.appendChild(d);const v=d.closedBy;d.remove();return v==='any';})()",
      "specSection": "https://html.spec.whatwg.org/#attr-dialog-closedby"
    },
    {
      "id": "dialog-closedby-closerequest",
      "description": "closedby='closerequest' is accepted and surfaces through the IDL attribute.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('dialog');d.setAttribute('closedby','closerequest');document.body.appendChild(d);const v=d.closedBy;d.remove();return v==='closerequest';})()"
    },
    {
      "id": "dialog-closedby-none",
      "description": "closedby='none' is accepted and surfaces through the IDL attribute.",
      "kind": "script",
