      "id": "anchor-interestfor-idl",
      "description": "HTMLAnchorElement.prototype exposes the interestForElement IDL attribute reflecting the interestfor content attribute.",
      "kind": "script",
      "test": "'interestForElement' in HTMLAnchorElement.prototype",
      "specSection": "https://github.com/whatwg/html/pull/11006"
    },
    {
      "id": "button-interestfor-idl",
      "description": "HTMLButtonElement.prototype exposes the interestForElement IDL attribute.",
      "kind": "script",
      "test": "'interestForElement' in HTMLButtonElement.prototype"
    },
    {
      "id": "interestfor-attribute-reflects-element",
      "description": "Setting interestfor to an id resolves through interestForElement to that element.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('a');const t=document.createElement('div');t.id='target-x';document.body.appendChild(t);a.setAttribute('interestfor','target-x');document.body.appendChild(a);const ok=a.interestForElement===t;a.remove();t.remove();return ok;})()"
    },
    {
      "id": "interest-event-name-accepted",
      "description": "Elements accept 'interest' and 'loseinterest' as event names without throwing.",
      "kind": "script",
      "test": "(()=>{try{const a=document.createElement('a');const fn=()=>{};a.addEventListener('interest',fn);a.addEventListener('loseinterest',fn);a.removeEventListener('interest',fn);a.removeEventListener('loseinterest',fn);return true;}catch(e){return false;}})()"
    },
    {
      "id": "popover-still-supported",
      "description": "The Popover API (the primary surface interest invokers drive) remains exposed.",
      "kind": "script",
      "test": "'popover' in HTMLElement.prototype",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
