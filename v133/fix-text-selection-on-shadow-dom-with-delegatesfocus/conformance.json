{
  "release": "v133",
  "featureSlug": "fix-text-selection-on-shadow-dom-with-delegatesfocus",
  "chromestatusId": 5134341540413440,
  "specUrl": "https://dom.spec.whatwg.org/#shadowroot-delegates-focus",
  "generatedAt": "2026-06-01T08:12:59Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "shadowroot-delegatesfocus-attr",
      "description": "ShadowRoot.prototype exposes the delegatesFocus attribute.",
      "kind": "script",
      "test": "'delegatesFocus' in ShadowRoot.prototype",
      "specSection": "https://dom.spec.whatwg.org/#shadowroot-delegates-focus"
    },
    {
      "id": "attachshadow-delegatesfocus-true",
      "description": "attachShadow({ delegatesFocus: true }) produces a ShadowRoot whose delegatesFocus is true.",
      "kind": "script",
      "test": "(()=>{const h=document.createElement('div');const r=h.attachShadow({mode:'open',delegatesFocus:true});return r.delegatesFocus===true;})()"
    },
    {
      "id": "delegatesfocus-default-false",
      "description": "Without delegatesFocus in the init dict, ShadowRoot.delegatesFocus is false.",
      "kind": "script",
      "test": "(()=>{const h=document.createElement('div');const r=h.attachShadow({mode:'open'});return r.delegatesFocus===false;})()"
    },
    {
      "id": "selection-api-still-works-on-host",
      "description": "document.getSelection() still returns a Selection object on documents that contain shadow trees with delegatesFocus.",
      "kind": "script",
      "test": "(()=>{const h=document.createElement('div');h.attachShadow({mode:'open',delegatesFocus:true});document.body.appendChild(h);const s=document.getSelection();h.remove();return s instanceof Selection;})()"
    },
    {
      "id": "shadowroot-getselection-exposed",
      "description": "ShadowRoot.prototype exposes getSelection() (Chromium-specific) for retrieving selection within the shadow tree.",
      "kind": "script",
      "test": "typeof ShadowRoot.prototype.getSelection==='function'",
      "expectedBrowsers": ["chrome"]
    }
  ]
}
