  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "open-pseudo-supported-selector",
      "description": "CSS.supports recognises :open as a valid selector.",
      "kind": "script",
      "test": "CSS.supports('selector(:open)')",
      "specSection": "https://drafts.csswg.org/selectors-4/#open-state"
    },
    {
      "id": "open-on-details-element",
      "description": "An open <details> element matches :open.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('details');d.open=true;document.body.appendChild(d);const m=d.matches(':open');d.remove();return m;})()",
      "specSection": "https://drafts.csswg.org/selectors-4/#open-state"
    },
    {
      "id": "closed-details-does-not-match-open",
      "description": "A closed <details> does not match :open.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('details');document.body.appendChild(d);const m=d.matches(':open');d.remove();return !m;})()"
    },
    {
      "id": "open-on-dialog-element",
      "description": "A <dialog> opened via show() matches :open.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('dialog');document.body.appendChild(d);try{d.show();const m=d.matches(':open');d.close();d.remove();return m;}catch(e){d.remove();return false;}})()",
      "specSection": "https://drafts.csswg.org/selectors-4/#open-state"
    },
    {
      "id": "open-on-select-element-not-throwing",
      "description": "Calling .matches(':open') on a <select> does not throw — open select state is in scope for the pseudo-class.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');document.body.appendChild(s);try{s.matches(':open');s.remove();return true;}catch(e){s.remove();return false;}})()"
    }
  ]
}
