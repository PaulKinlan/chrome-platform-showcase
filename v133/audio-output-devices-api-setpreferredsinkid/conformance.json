    {
      "id": "setpreferredsinkid-on-mediadevices",
      "description": "MediaDevices.prototype exposes setPreferredSinkId for setting the preferred output device for the document.",
      "kind": "script",
      "test": "(()=>!window.MediaDevices||!navigator.mediaDevices||!('setPreferredSinkId' in MediaDevices.prototype)||typeof navigator.mediaDevices.setPreferredSinkId==='function')()"
    },
    {
      "id": "setpreferredsinkid-is-function",
      "description": "navigator.mediaDevices.setPreferredSinkId is callable.",
      "kind": "script",
      "test": "(()=>!navigator.mediaDevices||!('setPreferredSinkId' in navigator.mediaDevices)||typeof navigator.mediaDevices.setPreferredSinkId==='function')()"
    },
    {
      "id": "setpreferredsinkid-returns-promise",
      "description": "setPreferredSinkId returns a Promise.",
      "kind": "script",
      "test": "(()=>{if(!navigator.mediaDevices||!navigator.mediaDevices.setPreferredSinkId)return true;try{const p=navigator.mediaDevices.setPreferredSinkId('');if(p&&p.catch)p.catch(()=>{});return p instanceof Promise;}catch(e){return true;}})()"
    },
    {
      "id": "setpreferredsinkid-empty-string-default",
      "description": "Passing the empty string requests the system default audio output device; the call does not throw synchronously.",
      "kind": "script",
      "test": "(()=>{if(!navigator.mediaDevices||!navigator.mediaDevices.setPreferredSinkId)return true;try{navigator.mediaDevices.setPreferredSinkId('').catch(()=>{});return true;}catch(e){return false;}})()"
    },
