      "kind": "exists",
      "test": "HTMLScriptElement",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "script-importmap-type-supported",
      "description": "Creating a <script type='importmap'> element reflects the type attribute.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('script');s.type='importmap';return s.type==='importmap';})()"
    },
    {
      "id": "two-importmaps-can-be-appended",
      "description": "Two <script type='importmap'> elements can be inserted into the document without a synchronous throw (the maps are merged at module resolution time).",
      "kind": "script",
      "test": "(()=>{try{const a=document.createElement('script');a.type='importmap';a.textContent=JSON.stringify({imports:{a:'/a.js'}});const b=document.createElement('script');b.type='importmap';b.textContent=JSON.stringify({imports:{b:'/b.js'}});document.head.appendChild(a);document.head.appendChild(b);a.remove();b.remove();return true;}catch(e){return false;}})()",
      "specSection": "https://github.com/whatwg/html/pull/10528"
    },
    {
      "id": "importmap-error-event",
      "description": "Invalid import map content fires an 'error' event on the <script> element rather than throwing synchronously.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('script');s.type='importmap';return 'onerror' in s;})()"
    },
    {
      "id": "script-element-text-property",
      "description": "HTMLScriptElement.prototype exposes the text property; import map content is read from it.",
      "kind": "script",
      "test": "'text' in HTMLScriptElement.prototype"
    }
