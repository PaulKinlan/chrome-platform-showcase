  "assertions": [
    {
      "id": "animation-prototype-overallprogress",
      "description": "Animation.prototype exposes an overallProgress property.",
      "kind": "script",
      "test": "'overallProgress' in Animation.prototype",
      "specSection": "https://drafts.csswg.org/web-animations-2/#the-overall-progress-of-an-animation"
    },
    {
      "id": "overallprogress-null-before-active",
      "description": "overallProgress is null on a fresh Animation that has not yet entered the active phase.",
      "kind": "script",
      "test": "(()=>{const a=new Animation();return a.overallProgress===null;})()",
      "specSection": "https://drafts.csswg.org/web-animations-2/#the-overall-progress-of-an-animation"
    },
    {
      "id": "overallprogress-numeric-after-running",
      "description": "Once an Animation is running over a KeyframeEffect with a finite iteration count, overallProgress returns a number between 0 and 1.",
      "kind": "script",
      "test": "(()=>{const el=document.createElement('div');document.body.appendChild(el);const a=el.animate([{opacity:0},{opacity:1}],{duration:1000,iterations:2});a.currentTime=500;const v=a.overallProgress;el.remove();return typeof v==='number'&&v>=0&&v<=1;})()",
      "specSection": "https://drafts.csswg.org/web-animations-2/#the-overall-progress-of-an-animation"
    },
    {
      "id": "overallprogress-accounts-for-iterations",
      "description": "overallProgress factors in iteration count: halfway through iteration 1 of a 2-iteration animation reports 0.25.",
      "kind": "script",
      "test": "(()=>{const el=document.createElement('div');document.body.appendChild(el);const a=el.animate([{opacity:0},{opacity:1}],{duration:1000,iterations:2});a.pause();a.currentTime=500;const v=a.overallProgress;el.remove();return Math.abs(v-0.25)<0.01;})()",
      "specSection": "https://drafts.csswg.org/web-animations-2/#the-overall-progress-of-an-animation"
    },
    {
      "id": "overallprogress-readonly",
      "description": "overallProgress is a read-only attribute; assigning to it has no effect.",
      "kind": "script",
      "test": "(()=>{const el=document.createElement('div');document.body.appendChild(el);const a=el.animate([{opacity:0},{opacity:1}],{duration:1000});a.pause();a.currentTime=500;const before=a.overallProgress;try{a.overallProgress=0.99;}catch(e){}const after=a.overallProgress;el.remove();return before===after;})()",
      "specSection": "https://drafts.csswg.org/web-animations-2/#the-overall-progress-of-an-animation"
    },
    {
      "id": "animation-interface-exposed",
      "description": "The Animation constructor remains exposed on Window for the API surface.",
      "kind": "typeof",
      "test": "Animation",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
