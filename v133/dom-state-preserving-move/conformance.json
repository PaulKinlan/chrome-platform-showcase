  "assertions": [
    {
      "id": "node-movebefore-method",
      "description": "Node.prototype exposes the moveBefore method for state-preserving moves.",
      "kind": "script",
      "test": "'moveBefore' in Node.prototype",
      "specSection": "https://dom.spec.whatwg.org/#dom-node-movebefore"
    },
    {
      "id": "node-movebefore-is-function",
      "description": "moveBefore is callable.",
      "kind": "typeof",
      "test": "Node.prototype.moveBefore",
      "expect": "function"
    },
    {
      "id": "movebefore-relocates-without-removal",
      "description": "moveBefore relocates a node within its parent without firing connected/disconnected callbacks; node order changes accordingly.",
      "kind": "script",
      "test": "(()=>{const p=document.createElement('div');const a=document.createElement('span');const b=document.createElement('span');p.appendChild(a);p.appendChild(b);document.body.appendChild(p);p.moveBefore(b,a);const ok=p.firstChild===b&&p.lastChild===a;p.remove();return ok;})()",
      "specSection": "https://dom.spec.whatwg.org/#dom-node-movebefore"
    },
    {
      "id": "movebefore-preserves-iframe-document",
      "description": "After moveBefore across parents within the same document, an <iframe>'s content document remains the same Document instance.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('div');const b=document.createElement('div');const iframe=document.createElement('iframe');a.appendChild(iframe);document.body.appendChild(a);document.body.appendChild(b);const doc=iframe.contentDocument;b.moveBefore(iframe,null);const same=iframe.contentDocument===doc;a.remove();b.remove();return same;})()"
    },
    {
      "id": "movebefore-throws-cross-document",
      "description": "moveBefore throws when the node and the new parent are in different documents.",
      "kind": "throws",
      "test": "(()=>{const otherDoc=new Document();const otherParent=otherDoc.createElement('div');otherDoc.appendChild(otherParent);const node=document.createElement('span');document.body.appendChild(node);otherParent.moveBefore(node,null);})()"
    }
  ]
}
