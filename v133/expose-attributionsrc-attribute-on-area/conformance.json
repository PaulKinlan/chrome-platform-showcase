  "assertions": [
    {
      "id": "area-attributionsrc-idl",
      "description": "HTMLAreaElement.prototype exposes the attributionSrc IDL attribute reflecting the attributionsrc content attribute.",
      "kind": "script",
      "test": "'attributionSrc' in HTMLAreaElement.prototype",
      "specSection": "https://wicg.github.io/attribution-reporting-api/#html-monkeypatches"
    },
    {
      "id": "area-attributionsrc-setter",
      "description": "Setting HTMLAreaElement.attributionSrc reflects to the content attribute.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('area');a.attributionSrc='https://example.com/src';return a.getAttribute('attributionsrc')==='https://example.com/src';})()"
    },
    {
      "id": "area-attributionsrc-getter",
      "description": "Reading attributionSrc returns the value set via the content attribute.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('area');a.setAttribute('attributionsrc','https://example.com/x');return a.attributionSrc==='https://example.com/x';})()"
    },
    {
      "id": "anchor-attributionsrc-still-exists",
      "description": "The pre-existing attributionSrc IDL attribute on HTMLAnchorElement remains exposed; <area> is parity, not a replacement.",
      "kind": "script",
      "test": "'attributionSrc' in HTMLAnchorElement.prototype"
    },
    {
      "id": "area-attributionsrc-empty-string-trigger",
      "description": "Setting attributionsrc to the empty string (the implicit-request form) is accepted and reflected.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('area');a.setAttribute('attributionsrc','');return a.attributionSrc===''&&a.hasAttribute('attributionsrc');})()"
    }
