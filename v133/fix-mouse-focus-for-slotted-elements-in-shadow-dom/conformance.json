  "assertions": [
    {
      "id": "attachshadow-supported",
      "description": "Element.prototype.attachShadow exists; shadow DOM is the substrate for the slotting fix.",
      "kind": "typeof",
      "test": "Element.prototype.attachShadow",
      "expect": "function",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    },
    {
      "id": "slot-element-supported",
      "description": "HTMLSlotElement is exposed and hosts the slotting machinery.",
      "kind": "exists",
      "test": "HTMLSlotElement",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    },
    {
      "id": "slotted-element-receives-programmatic-focus",
      "description": "A focusable element distributed into a slot can receive programmatic focus (the focus delegates to the shadow host).",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');document.body.appendChild(host);const root=host.attachShadow({mode:'open'});root.innerHTML='<slot></slot>';const btn=document.createElement('button');host.appendChild(btn);btn.focus();const ok=document.activeElement===host||document.activeElement===btn;host.remove();return ok;})()",
      "specSection": "https://dom.spec.whatwg.org/#concept-event-dispatch"
    },
    {
      "id": "shadowroot-activeelement-reflects-focused",
      "description": "ShadowRoot.activeElement reports the focused element inside the shadow tree.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');document.body.appendChild(host);const root=host.attachShadow({mode:'open'});root.innerHTML='<button id=b></button>';root.getElementById('b').focus();const ok=root.activeElement&&root.activeElement.id==='b';host.remove();return ok;})()"
    },
    {
      "id": "click-event-on-slotted-still-fires",
      "description": "A synthetic click on a slotted element still fires the click event (regression-check for the focus-fix's side-effects).",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');document.body.appendChild(host);const root=host.attachShadow({mode:'open'});root.innerHTML='<slot></slot>';const btn=document.createElement('button');host.appendChild(btn);let fired=false;btn.addEventListener('click',()=>{fired=true;});btn.click();host.remove();return fired;})()"
    }
  ]
