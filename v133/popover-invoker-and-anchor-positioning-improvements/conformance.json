      "test": "(()=>{const t=document.createElement('div');t.id='pop1';t.popover='auto';document.body.appendChild(t);const b=document.createElement('button');b.setAttribute('popovertarget','pop1');document.body.appendChild(b);const ok=b.popoverTargetElement===t;b.remove();t.remove();return ok;})()"
