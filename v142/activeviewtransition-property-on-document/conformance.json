      "id": "active-view-transition-reflects-running-transition",
      "description": "Calling document.startViewTransition sets document.activeViewTransition to the returned transition for the duration of the transition.",
      "kind": "script",
      "test": "(()=>{if(typeof document.startViewTransition!=='function')return false;const t=document.startViewTransition(()=>{});const live=document.activeViewTransition===t;t.skipTransition&&t.skipTransition();return live;})()",
      "specSection": "https://drafts.csswg.org/css-view-transitions-2/#dom-document-activeviewtransition"
    },
    {
      "id": "active-view-transition-clears-after-finished",
      "description": "Once the transition's finished promise settles, document.activeViewTransition returns to null.",
      "kind": "script",
      "test": "(async()=>{if(typeof document.startViewTransition!=='function')return false;const t=document.startViewTransition(()=>{});t.skipTransition&&t.skipTransition();try{await t.finished;}catch(_){}return document.activeViewTransition===null;})()"
