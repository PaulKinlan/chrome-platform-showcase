      "kind": "css-supports",
      "test": "container: card / inline-size",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "container-query-rule-parses",
      "description": "Userland can author an @container rule referencing a named container; CSSContainerRule is exposed as the OM surface.",
      "kind": "exists",
      "test": "CSSContainerRule"
    },
    {
      "id": "attach-shadow-supported",
      "description": "attachShadow is available so the cross-tree-scope container-name matching can actually be exercised.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');return typeof d.attachShadow==='function';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "cross-shadow-named-container-match",
      "description": "A container declared inside a shadow tree, queried by name from a light-tree stylesheet, now matches and resolves the inline-size query.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');host.style.cssText='width:300px;container-name:card;container-type:inline-size';document.body.appendChild(host);const sr=host.attachShadow({mode:'open'});sr.innerHTML='<style>@container card (min-width: 100px){.inner{color:rgb(1,2,3)}}</style><span class=inner>x</span>';const c=getComputedStyle(sr.querySelector('.inner')).color;host.remove();return /rgb\\(\\s*1\\s*,\\s*2\\s*,\\s*3\\s*\\)/.test(c);})()",
      "specSection": "https://drafts.csswg.org/css-conditional-5/#container-name"
    }
  ]
