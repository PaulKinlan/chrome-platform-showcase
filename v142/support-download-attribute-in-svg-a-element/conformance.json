  "release": "v142",
  "featureSlug": "support-download-attribute-in-svg-a-element",
  "chromestatusId": 6265596395913216,
  "specUrl": "https://svgwg.org/svg2-draft/linking.html#InterfaceSVGAElement",
  "generatedAt": "2026-06-01T08:13:10Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "svganchor-interface-exists",
      "description": "SVGAElement is exposed; the download attribute reflects on this interface.",
      "kind": "exists",
      "test": "SVGAElement"
    },
    {
      "id": "svg-a-download-idl-attribute",
      "description": "SVGAElement.prototype reflects a download IDL attribute (a DOMString).",
      "kind": "script",
      "test": "(()=>{const a=document.createElementNS('http://www.w3.org/2000/svg','a');return 'download' in a;})()",
      "specSection": "https://svgwg.org/svg2-draft/linking.html#InterfaceSVGAElement"
    },
    {
      "id": "svg-a-download-roundtrips",
      "description": "Setting the download IDL attribute on an SVG <a> element round-trips to the content attribute.",
      "kind": "script",
      "test": "(()=>{const a=document.createElementNS('http://www.w3.org/2000/svg','a');a.setAttribute('download','file.svg');return a.getAttribute('download')==='file.svg';})()"
    },
    {
      "id": "svg-a-href-still-supported",
      "description": "SVGAElement's href surface remains; download is additive.",
      "kind": "script",
      "test": "(()=>{const a=document.createElementNS('http://www.w3.org/2000/svg','a');return 'href' in a;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "html-a-download-still-supported",
      "description": "HTMLAnchorElement's download attribute (the source of the parity) is still there.",
      "kind": "script",
      "test": "'download' in document.createElement('a')",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "svg-a-ping-and-rel-supported",
      "description": "The SVG2 parity also brings ping/rel onto SVGAElement; these IDL attributes are present.",
      "kind": "script",
      "test": "(()=>{const a=document.createElementNS('http://www.w3.org/2000/svg','a');return 'ping' in a && 'rel' in a;})()"
    }
  ]
}
