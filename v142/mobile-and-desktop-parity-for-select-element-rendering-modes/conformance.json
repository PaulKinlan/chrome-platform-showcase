{
  "release": "v142",
  "featureSlug": "mobile-and-desktop-parity-for-select-element-rendering-modes",
  "chromestatusId": 5412736871825408,
  "specUrl": "https://html.spec.whatwg.org/multipage/form-elements.html#the-select-element",
  "generatedAt": "2026-06-01T08:13:10Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "select-element-exists",
      "description": "HTMLSelectElement is exposed; the rendering parity change touches its rendering, not its IDL surface.",
      "kind": "exists",
      "test": "HTMLSelectElement",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "select-size-attribute-reflects",
      "description": "The size attribute reflects as a number; size > 1 is what triggers the in-page listbox rendering on every form factor now.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');s.size=3;return s.size===3;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "select-multiple-attribute-reflects",
      "description": "The multiple attribute reflects as a boolean; multiple (with no size) now also triggers in-page rendering uniformly.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');s.multiple=true;return s.multiple===true && s.hasAttribute('multiple');})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "select-multiple-size-1-still-allowed",
      "description": "multiple with size=1 is allowed; the new behaviour is to render this as a popup on every form factor.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');s.multiple=true;s.size=1;return s.multiple===true && s.size===1;})()"
    },
    {
      "id": "select-selectedoptions-collection",
      "description": "HTMLSelectElement exposes selectedOptions; this is the IDL surface a multi-select listbox surfaces user selection through.",
      "kind": "script",
      "test": "'selectedOptions' in HTMLSelectElement.prototype",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "option-element-still-exposed",
      "description": "HTMLOptionElement is exposed; the rendering change does not alter the option IDL.",
      "kind": "exists",
      "test": "HTMLOptionElement",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
}
