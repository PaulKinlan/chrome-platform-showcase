{
  "release": "v142",
  "featureSlug": "interest-invokers-the-interestfor-attribute",
  "chromestatusId": 4530756656562176,
  "specUrl": "https://github.com/whatwg/html/pull/11006",
  "generatedAt": "2026-06-01T08:13:10Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "interestfor-on-button",
      "description": "HTMLButtonElement reflects the interestfor IDL attribute.",
      "kind": "script",
      "test": "'interestForElement' in HTMLButtonElement.prototype || 'interestfor' in document.createElement('button')"
    },
    {
      "id": "interestfor-on-anchor",
      "description": "HTMLAnchorElement reflects the interestfor IDL attribute — `<a>` is one of the elements that can be an interest invoker.",
      "kind": "script",
      "test": "'interestForElement' in HTMLAnchorElement.prototype || 'interestfor' in document.createElement('a')"
    },
    {
      "id": "interest-event-constructor",
      "description": "InterestEvent is exposed; this is the event interface dispatched on the target when interest is shown or lost.",
      "kind": "exists",
      "test": "InterestEvent"
    },
    {
      "id": "interest-event-is-cancelable",
      "description": "InterestEvent is constructed cancelable; an authored interest event has cancelable === true by default per the spec text.",
      "kind": "script",
      "test": "(()=>{try{const e=new InterestEvent('interest',{cancelable:true});return e.cancelable===true && e.type==='interest';}catch(_){return false;}})()"
    },
    {
      "id": "interestfor-attribute-roundtrips",
      "description": "Setting button.interestForElement (or button.setAttribute('interestfor', id)) round-trips through the attribute.",
      "kind": "script",
      "test": "(()=>{const t=document.createElement('div');t.id='__c14e_target';document.body.appendChild(t);const b=document.createElement('button');b.setAttribute('interestfor','__c14e_target');const ok=b.getAttribute('interestfor')==='__c14e_target';t.remove();return ok;})()"
    },
    {
      "id": "popover-attribute-still-supported",
      "description": "interestfor commonly points at a popover; the popover attribute on the target is still parsed.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.setAttribute('popover','hint');return d.getAttribute('popover')==='hint';})()"
    }
  ]
}
