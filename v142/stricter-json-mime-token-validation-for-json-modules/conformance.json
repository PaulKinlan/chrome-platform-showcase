{
  "release": "v142",
  "featureSlug": "stricter-json-mime-token-validation-for-json-modules",
  "chromestatusId": 5182756304846848,
  "specUrl": "https://mimesniff.spec.whatwg.org/#parse-a-mime-type",
  "generatedAt": "2026-06-01T08:13:10Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "dynamic-import-exists",
      "description": "Dynamic import() is the entry point for JSON module loads; the syntax is parsed without throwing.",
      "kind": "script",
      "test": "typeof Function('return import(\"data:application/json,1\", {with:{type:\"json\"}})')==='function'",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "import-with-type-json-supported",
      "description": "The import attributes (`with { type: 'json' }`) syntax is supported as the way to mark a JSON module.",
      "kind": "script",
      "test": "(async()=>{try{const m=await import('data:application/json,{\"ok\":true}',{with:{type:'json'}});return m.default && m.default.ok===true;}catch(e){return false;}})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "json-with-plus-json-suffix-still-accepted",
      "description": "A response with a well-formed `*+json` MIME (no whitespace in type/subtype) still loads as a JSON module.",
      "kind": "script",
      "test": "(async()=>{try{const m=await import('data:application/vnd.x+json,{\"v\":1}',{with:{type:'json'}});return m.default && m.default.v===1;}catch(e){return false;}})()"
    },
    {
      "id": "json-mime-with-space-rejected",
      "description": "A JSON module load whose MIME type contains a non-token code point (e.g. a space inside the subtype) is now rejected — the import promise rejects.",
      "kind": "script",
      "test": "(async()=>{try{await import('data:application/foo bar+json,{}',{with:{type:'json'}});return false;}catch(e){return true;}})()",
      "specSection": "https://mimesniff.spec.whatwg.org/#parse-a-mime-type"
    },
    {
      "id": "json-mime-tab-in-type-rejected",
      "description": "Likewise a tab character in the MIME type is rejected by the stricter validator.",
      "kind": "script",
      "test": "(async()=>{try{await import('data:application/x\\tjson,{}',{with:{type:'json'}});return false;}catch(e){return true;}})()"
    },
    {
      "id": "fetch-still-tolerates-loose-mime",
      "description": "Fetch itself does not reject responses with loose MIME types — the strict check is module-loader-specific.",
      "kind": "typeof",
      "test": "fetch",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
}
