    {
      "id": "style-container-query-range-supported",
      "description": "An @container style() query with a range operator parses and evaluates against a custom property declared on the container.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('div');c.style.cssText='--inner-padding:2em;container-type:size';c.innerHTML='<style>@container style(--inner-padding > 1em){.t{color:rgb(2,3,4)}}</style><span class=t>x</span>';document.body.appendChild(c);const ok=/rgb\\(\\s*2\\s*,\\s*3\\s*,\\s*4\\s*\\)/.test(getComputedStyle(c.querySelector('.t')).color);c.remove();return ok;})()",
      "specSection": "https://drafts.csswg.org/css-conditional-5/#typedef-style-range"
    },
    {
      "id": "container-type-supported",
      "description": "container-type accepts size — the base surface style range queries hang off.",
      "kind": "css-supports",
      "test": "container-type: size",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "if-function-supported",
      "description": "The CSS if() function is supported; range syntax inside if() requires the function to be available.",
      "kind": "css-supports",
      "test": "color: if(style(--x: 1): red; else: blue)"
    },
    {
      "id": "style-exact-match-still-supported",
      "description": "Exact-match style queries continue to work; the range syntax is additive.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('div');c.style.cssText='--theme:dark;container-type:size';c.innerHTML='<style>@container style(--theme: dark){.t{color:rgb(5,6,7)}}</style><span class=t>x</span>';document.body.appendChild(c);const ok=/rgb\\(\\s*5\\s*,\\s*6\\s*,\\s*7\\s*\\)/.test(getComputedStyle(c.querySelector('.t')).color);c.remove();return ok;})()"
    },
    {
      "id": "container-query-om-rule-exists",
      "description": "CSSContainerRule is exposed; the style-range query lives inside the same OM rule type.",
      "kind": "exists",
      "test": "CSSContainerRule"
    },
    {
      "id": "attr-with-type-supported",
      "description": "attr() with a type<number> hint is used in range examples; CSS.supports recognises the typed-attr form.",
      "kind": "css-supports",
      "test": "width: attr(data-columns type(<number>), 0px)"
