  "assertions": [
    {
      "id": "webgpu-on-navigator",
      "description": "navigator.gpu is exposed; the tier1/tier2 format extensions are properties of GPUAdapter.features.",
      "kind": "exists",
      "test": "navigator.gpu"
    },
    {
      "id": "adapter-features-set",
      "description": "GPUAdapter exposes a `features` GPUSupportedFeatures set whose `has()` returns a boolean for any feature name including 'texture-formats-tier1' and 'texture-formats-tier2'.",
      "kind": "script",
      "test": "(async()=>{if(!navigator.gpu)return false;const a=await navigator.gpu.requestAdapter();return !!(a && a.features && typeof a.features.has==='function');})()"
    },
    {
      "id": "texture-formats-tier1-introspectable",
      "description": "features.has('texture-formats-tier1') returns a boolean.",
      "kind": "script",
      "test": "(async()=>{if(!navigator.gpu)return false;const a=await navigator.gpu.requestAdapter();if(!a||!a.features)return false;return typeof a.features.has('texture-formats-tier1')==='boolean';})()",
      "specSection": "https://gpuweb.github.io/gpuweb/#gpufeaturename"
    },
    {
      "id": "texture-formats-tier2-introspectable",
      "description": "features.has('texture-formats-tier2') returns a boolean.",
      "kind": "script",
      "test": "(async()=>{if(!navigator.gpu)return false;const a=await navigator.gpu.requestAdapter();if(!a||!a.features)return false;return typeof a.features.has('texture-formats-tier2')==='boolean';})()",
      "specSection": "https://gpuweb.github.io/gpuweb/#gpufeaturename"
    },
    {
      "id": "request-device-rejects-when-tier-unsupported",
      "description": "Requesting a device with a tier feature on an adapter that does not list it rejects.",
      "kind": "script",
      "test": "(async()=>{if(!navigator.gpu)return true;const a=await navigator.gpu.requestAdapter();if(!a)return true;if(a.features&&a.features.has('texture-formats-tier1'))return true;try{await a.requestDevice({requiredFeatures:['texture-formats-tier1']});return false;}catch(_){return true;}})()"
    },
    {
      "id": "create-texture-base-formats-still-supported",
      "description": "Base format like 'rgba8unorm' must still be creatable as a texture; the tier extensions are additive.",
      "kind": "script",
      "test": "(async()=>{if(!navigator.gpu)return false;const a=await navigator.gpu.requestAdapter();if(!a)return false;const d=await a.requestDevice();const t=d.createTexture({size:[1,1,1],format:'rgba8unorm',usage:GPUTextureUsage.TEXTURE_BINDING});return !!t;})()"
    }
  ]
