      "kind": "script",
      "test": "(()=>{const f=document.createElement('iframe');f.srcdoc='<div id=h><template shadowrootmode=open shadowrootadoptedstylesheets=\"data:text/css,:host%7Bdisplay:block%7D\"><span>ok</span></template></div>';document.body.append(f);return new Promise(r=>f.onload=()=>setTimeout(()=>{const root=f.contentDocument.getElementById('h').shadowRoot;const ok=(root?.adoptedStyleSheets?.length||0)>0;f.remove();r(ok)},50))})()",
