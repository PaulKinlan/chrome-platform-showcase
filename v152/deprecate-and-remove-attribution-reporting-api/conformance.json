  "assertions": [
    {
      "id": "attribution-reporting-removed",
      "description": "Document.featurePolicy or document.permissionsPolicy no longer lists 'attribution-reporting' as an allowed feature \u2014 the API is removed in Chrome 150.",
      "kind": "script",
      "test": "(()=>{const p=document.permissionsPolicy||document.featurePolicy;if(!p||typeof p.features!=='function')return false;return !p.features().includes('attribution-reporting');})()"
    },
    {
      "id": "attributionreporting-attribute-removed",
      "description": "The 'attributionsrc' content attribute is no longer reflected on <a> elements as an IDL property.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('a');return !('attributionSrc' in a);})()"
    },
    {
      "id": "registerattributionsource-removed",
      "description": "navigator.registerAttributionSource is no longer present on Navigator (where it was historically considered).",
      "kind": "script",
      "test": "!('registerAttributionSource' in navigator)"
    },
    {
      "id": "fetch-still-works",
      "description": "fetch() still works \u2014 only the attributionreporting-specific surfaces are removed, not the underlying network APIs.",
      "kind": "typeof",
      "test": "fetch",
      "expect": "function",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    },
    {
      "id": "iframe-attributionsrc-not-reflected",
      "description": "HTMLIFrameElement no longer reflects an attributionSrc IDL attribute.",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('iframe');return !('attributionSrc' in i);})()"
    },
    {
      "id": "attribution-reporting-eligible-not-special",
      "description": "Setting an 'Attribution-Reporting-Eligible' header via Request is allowed (header is no longer special-cased) \u2014 fetch construction succeeds.",
      "kind": "script",
      "test": "(()=>{try{new Request('/x',{headers:{'Attribution-Reporting-Eligible':'event-source'}});return true;}catch(_){return false;}})()"
    }
  ]
}
