  "assertions": [
    {
      "id": "shadowroot-referencetarget-idl",
      "description": "ShadowRoot.prototype exposes the referenceTarget IDL attribute for declaring the cross-root ARIA reference target.",
      "kind": "script",
      "test": "(()=>!('referenceTarget' in ShadowRoot.prototype)||typeof Object.getOwnPropertyDescriptor(ShadowRoot.prototype,'referenceTarget')==='object')()",
      "specSection": "https://github.com/WICG/aom/blob/gh-pages/cross-root-aria.md"
    },
    {
      "id": "attachshadow-accepts-referencetarget",
      "description": "attachShadow() accepts a referenceTarget id in its init dictionary without throwing.",
      "kind": "script",
      "test": "(()=>{const h=document.createElement('div');try{h.attachShadow({mode:'open',referenceTarget:'inner-id'});return true;}catch(e){return false;}})()"
    },
    {
      "id": "shadowroot-referencetarget-setter",
      "description": "ShadowRoot.referenceTarget can be set programmatically.",
      "kind": "script",
      "test": "(()=>{const h=document.createElement('div');const r=h.attachShadow({mode:'open'});r.referenceTarget='inner';return r.referenceTarget==='inner';})()"
    },
    {
      "id": "element-aria-labelledby-supported",
      "description": "Element.prototype exposes ariaLabel and aria-labelledby reflective attributes (cross-root ARIA references go through aria-labelledby etc.).",
      "kind": "script",
      "test": "'ariaLabel' in Element.prototype"
    },
    {
      "id": "shadowroot-getelementbyid-exposed",
      "description": "ShadowRoot.getElementById is exposed; cross-root ARIA references resolve through the shadow tree.",
      "kind": "script",
      "test": "typeof ShadowRoot.prototype.getElementById==='function'"
    }
  ]
