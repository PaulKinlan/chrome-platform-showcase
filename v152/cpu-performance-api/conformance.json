    {
      "id": "navigator-cpuperformance-exists",
      "description": "Navigator exposes a cpuPerformance attribute \u2014 the partial Navigator interface defined by the CPU Performance API.",
      "kind": "exists",
      "test": "navigator.cpuPerformance",
      "specSection": "https://wicg.github.io/cpu-performance/#dom-navigator-cpuperformance"
    },
    {
      "id": "cpuperformance-is-number",
      "description": "navigator.cpuPerformance is an unsigned short \u2014 typeof must be 'number' (not a function, not an object).",
      "kind": "typeof",
      "test": "navigator.cpuPerformance",
      "expect": "number",
      "specSection": "https://wicg.github.io/cpu-performance/#dom-navigator-cpuperformance"
    },
    {
      "id": "cpuperformance-tier-in-defined-range",
      "description": "The reported tier is an integer in 0..4 in the initial deployment; specs note future tiers 5+ may appear. Allow 0..16 as a forward-compatible upper bound.",
      "kind": "script",
      "test": "(()=>{const v=navigator.cpuPerformance;return Number.isInteger(v) && v>=0 && v<=16;})()",
      "specSection": "https://wicg.github.io/cpu-performance/#dom-navigator-cpuperformance"
    },
    {
      "id": "cpuperformance-readonly",
      "description": "cpuPerformance is a readonly attribute \u2014 assigning a new value must not change the observable reading.",
      "kind": "script",
      "test": "(()=>{const before=navigator.cpuPerformance;try{navigator.cpuPerformance=999;}catch(e){}return navigator.cpuPerformance===before;})()",
      "specSection": "https://wicg.github.io/cpu-performance/#dom-navigator-cpuperformance"
    },
    {
      "id": "cpuperformance-requires-secure-context",
      "description": "The IDL is marked [SecureContext]; this check confirms the page running the assertion is in a secure context, otherwise the attribute is not expected to be exposed.",
      "kind": "script",
      "test": "window.isSecureContext === true",
      "specSection": "https://wicg.github.io/cpu-performance/"
    },
    {
      "id": "hardwareconcurrency-companion-signal",
      "description": "navigator.hardwareConcurrency remains exposed alongside cpuPerformance \u2014 the spec positions cpuPerformance as a coarser companion, not a replacement.",
      "kind": "typeof",
      "test": "navigator.hardwareConcurrency",
      "expect": "number",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    },
    {
      "id": "capability-echo-sends-critical-client-hints",
      "description": "The adaptive echo route opts in with Accept-CH, marks the same hints as Critical-CH, varies on them, and echoes the received Sec-CH-* request headers for server-side adaptation diagnostics.",
      "kind": "script",
      "test": "fetch('/v152/cpu-performance-api/capability-echo?scenario=conformance&tier=2&delay=0',{cache:'no-store',headers:{'x-app-profile':'balanced'}}).then(async(res)=>{const body=await res.json();const acceptCH=res.headers.get('accept-ch')||'';const criticalCH=res.headers.get('critical-ch')||'';const vary=res.headers.get('vary')||'';return acceptCH.includes('Sec-CH-UA-Platform')&&criticalCH.includes('Sec-CH-UA-Platform')&&vary.includes('Sec-CH-UA-Platform')&&body.negotiation?.sentCriticalCH===true&&typeof body.negotiation?.receivedClientHints==='object'&&body.request?.appProfile==='balanced';})",
      "specSection": "https://wicg.github.io/cpu-performance/"
    }
  ]
