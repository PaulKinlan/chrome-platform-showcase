{
  "release": "v152",
  "featureSlug": "expose-the-autocorrect-global-html-attribute",
  "chromestatusId": 6264645053710336,
  "specUrl": "https://html.spec.whatwg.org/multipage/interaction.html#autocorrection",
  "generatedAt": "2026-07-15T10:00:00Z",
  "author": "manual-openai-v152-coverage",
  "assertions": [
    {
      "id": "autocorrect-idl-on-htmlelement",
      "description": "The autocorrect IDL attribute is defined as a global attribute on HTMLElement.prototype, so 'autocorrect' must be present on the prototype.",
      "kind": "script",
      "test": "'autocorrect' in HTMLElement.prototype",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#autocorrection"
    },
    {
      "id": "autocorrect-is-boolean",
      "description": "Per spec, the IDL attribute reflects as a boolean (limited to known values, default 'on'). Reading it on a fresh input returns a boolean.",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('input');return typeof i.autocorrect==='boolean';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#autocorrection"
    },
    {
      "id": "autocorrect-defaults-to-on",
      "description": "The default state when the attribute is absent or invalid is 'on' \u2014 so a freshly-created input reports autocorrect===true.",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('input');return i.autocorrect===true;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#autocorrection"
    },
    {
      "id": "autocorrect-off-reflects-content-attribute",
      "description": "Setting the content attribute to 'off' must make the IDL getter return false.",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('input');i.setAttribute('autocorrect','off');return i.autocorrect===false;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#autocorrection"
    },
    {
      "id": "autocorrect-setter-writes-content-attribute",
      "description": "Setting the IDL attribute to false must write the content attribute as 'off' (per HTML reflection rules for enumerated boolean attributes).",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('input');i.autocorrect=false;return i.getAttribute('autocorrect')==='off';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#autocorrection"
    },
    {
      "id": "autocorrect-on-textarea",
      "description": "Because autocorrect is a global attribute, it is also exposed on textarea and contenteditable hosts \u2014 not just <input>.",
      "kind": "script",
      "test": "(()=>{const t=document.createElement('textarea');return 'autocorrect' in t && typeof t.autocorrect==='boolean';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#autocorrection"
    },
    {
      "id": "autocorrect-on-contenteditable-div",
      "description": "Global attribute means HTMLDivElement instances also reflect autocorrect; this verifies the attribute really lives on HTMLElement, not on form-control subclasses only.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.contentEditable='true';return 'autocorrect' in d && typeof d.autocorrect==='boolean';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#autocorrection"
    }
  ]
}
