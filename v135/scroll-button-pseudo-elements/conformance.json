  "assertions": [
    {
      "id": "scroll-button-pseudo-parses",
      "description": "::scroll-button(*) parses as a pseudo-element selector.",
      "kind": "script",
      "test": "(()=>{try{const s=new CSSStyleSheet();s.replaceSync('.s::scroll-button(*) { color: red }');return s.cssRules[0].selectorText.includes('::scroll-button');}catch(e){return false;}})()",
      "specSection": "https://drafts.csswg.org/css-overflow-5/#scroll-buttons"
    },
    {
      "id": "scroll-button-direction-left",
      "description": "::scroll-button(left) parses with a directional argument.",
      "kind": "script",
      "test": "(()=>{try{const s=new CSSStyleSheet();s.replaceSync('.s::scroll-button(left) { color: red }');return !!s.cssRules[0];}catch(e){return false;}})()",
      "specSection": "https://drafts.csswg.org/css-overflow-5/#scroll-buttons"
    },
    {
      "id": "scroll-button-content-supported",
      "description": "content property is supported — required to make ::scroll-button generate its glyph.",
      "kind": "css-supports",
      "test": "content: 'a'",
      "specSection": "https://www.w3.org/TR/css-content-3/#content-property"
    },
    {
      "id": "scroll-button-direction-up",
      "description": "::scroll-button(up) parses for block-direction scrollers.",
      "kind": "script",
      "test": "(()=>{try{const s=new CSSStyleSheet();s.replaceSync('div::scroll-button(up) { content: \"\" }');return !!s.cssRules[0];}catch(e){return false;}})()",
      "specSection": "https://drafts.csswg.org/css-overflow-5/#scroll-buttons"
    },
    {
      "id": "scroll-snap-type-supported",
