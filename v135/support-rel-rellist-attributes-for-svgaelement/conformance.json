{
  "release": "v135",
  "featureSlug": "support-rel-rellist-attributes-for-svgaelement",
  "chromestatusId": 5066982694846464,
  "specUrl": "https://svgwg.org/svg2-draft/linking.html#__svg__SVGAElement__rel",
  "generatedAt": "2026-06-02T08:08:51Z",
  "author": "conformance-author-codex",
  "assertions": [
    {
      "id": "svgaelement-interface-exposed",
      "description": "SVGAElement is exposed as the DOM interface for SVG anchor elements.",
      "kind": "exists",
      "test": "SVGAElement",
      "specSection": "https://svgwg.org/svg2-draft/linking.html#InterfaceSVGAElement"
    },
    {
      "id": "svg-anchor-rel-reflects-attribute",
      "description": "SVGAElement.rel reflects the SVG anchor rel content attribute.",
      "kind": "script",
      "test": "(()=>{const a=document.createElementNS('http://www.w3.org/2000/svg','a');a.setAttribute('rel','noopener noreferrer');return 'rel' in a && a.rel==='noopener noreferrer';})()",
      "specSection": "https://svgwg.org/svg2-draft/linking.html#__svg__SVGAElement__rel"
    },
    {
      "id": "svg-anchor-rellist-is-domtokenlist",
      "description": "SVGAElement.relList exposes a DOMTokenList, matching HTMLAnchorElement.",
      "kind": "script",
      "test": "(()=>{const a=document.createElementNS('http://www.w3.org/2000/svg','a');return a.relList instanceof DOMTokenList;})()",
      "specSection": "https://svgwg.org/svg2-draft/linking.html#__svg__SVGAElement__relList"
    },
    {
      "id": "rellist-add-updates-rel",
      "description": "Calling relList.add() on an SVG anchor updates the reflected rel value.",
      "kind": "script",
      "test": "(()=>{const a=document.createElementNS('http://www.w3.org/2000/svg','a');a.relList.add('noopener','noreferrer');return a.rel.includes('noopener')&&a.rel.includes('noreferrer');})()",
      "specSection": "https://svgwg.org/svg2-draft/linking.html#__svg__SVGAElement__relList"
    },
    {
      "id": "rellist-remove-updates-rel",
      "description": "Calling relList.remove() on an SVG anchor removes the token from rel.",
      "kind": "script",
      "test": "(()=>{const a=document.createElementNS('http://www.w3.org/2000/svg','a');a.rel='noopener noreferrer';a.relList.remove('noopener');return !a.relList.contains('noopener')&&a.relList.contains('noreferrer');})()",
      "specSection": "https://svgwg.org/svg2-draft/linking.html#__svg__SVGAElement__relList"
    },
    {
      "id": "svg-and-html-anchor-rellist-parity",
      "description": "SVG and HTML anchors expose relList with the same DOMTokenList operations.",
      "kind": "script",
      "test": "(()=>{const svg=document.createElementNS('http://www.w3.org/2000/svg','a');const html=document.createElement('a');svg.relList.add('external');html.relList.add('external');return svg.relList.contains('external')&&html.relList.contains('external')&&typeof svg.relList.toggle==='function';})()",
      "specSection": "https://svgwg.org/svg2-draft/linking.html#__svg__SVGAElement__relList"
    }
  ]
}
