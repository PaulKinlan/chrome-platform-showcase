      "description": "The ::column pseudo-element selector parses (matches the column fragments generated by scroll-snap carousels).",
      "kind": "script",
      "test": "(()=>{try{const s=new CSSStyleSheet();s.replaceSync('div::column { background: red }');return s.cssRules[0]&&s.cssRules[0].selectorText.includes('::column');}catch(e){return false;}})()",
      "specSection": "https://drafts.csswg.org/css-overflow-5/#column-pseudo"
    },
    {
      "id": "column-pseudo-selectortext-roundtrip",
      "description": "selectorText for ::column round-trips identically through the CSSOM.",
      "kind": "script",
      "test": "(()=>{const s=new CSSStyleSheet();s.replaceSync('.c::column { color: blue }');return s.cssRules[0].selectorText==='.c::column';})()",
      "specSection": "https://drafts.csswg.org/css-overflow-5/#column-pseudo"
    },
    {
      "id": "scroll-marker-group-supported",
