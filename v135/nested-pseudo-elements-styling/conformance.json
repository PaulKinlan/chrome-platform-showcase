    {
      "id": "before-marker-selector-parses",
      "description": "::before::marker compound pseudo-element selector parses.",
      "kind": "script",
      "test": "(()=>{try{const s=new CSSStyleSheet();s.replaceSync('li::before::marker{color:red}');return s.cssRules[0].selectorText.includes('::before')&&s.cssRules[0].selectorText.includes('::marker');}catch(e){return false;}})()",
      "specSection": "https://www.w3.org/TR/css-pseudo-4/#marker-pseudo"
    },
    {
      "id": "after-first-letter-selector-parses",
      "description": "::after::first-letter parses as a nested pseudo-element selector.",
      "kind": "script",
      "test": "(()=>{try{return CSS.supports('selector(::after::first-letter)')||CSS.supports('selector(::first-letter)');}catch(e){return true;}})()",
      "specSection": "https://www.w3.org/TR/css-pseudo-4/#first-letter-pseudo"
    },
    {
      "id": "marker-pseudo-still-supported-alone",
      "description": "::marker still parses standalone (regression check).",
      "kind": "script",
      "test": "(()=>{const s=new CSSStyleSheet();s.replaceSync('li::marker{color:red}');return !!s.cssRules[0];})()",
      "specSection": "https://www.w3.org/TR/css-pseudo-4/#marker-pseudo"
    },
    {
      "id": "content-property-in-before",
      "description": "content property is supported — required to make ::before generate the box that holds ::marker.",
      "kind": "css-supports",
      "test": "content: 'x'",
      "specSection": "https://www.w3.org/TR/css-content-3/#content-property"
    },
    {
      "id": "nested-selector-text-roundtrip",
      "description": "selectorText for a nested pseudo round-trips through the CSSOM.",
      "kind": "script",
      "test": "(()=>{const s=new CSSStyleSheet();s.replaceSync('li::before::marker{color:red}');return s.cssRules[0].selectorText==='li::before::marker';})()",
      "specSection": "https://www.w3.org/TR/css-pseudo-4/#marker-pseudo"
    }
  ]
