      "id": "script-type-speculationrules-accepted",
      "description": "script[type=speculationrules] is accepted as a script type.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('script');s.type='speculationrules';return s.type==='speculationrules';})()",
      "specSection": "https://wicg.github.io/nav-speculation/speculation-rules.html#parsing"
    },
    {
      "id": "speculation-rules-json-with-target-hint-parses",
      "description": "A speculationrules script with a target_hint field parses without throwing.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('script');s.type='speculationrules';s.textContent=JSON.stringify({prerender:[{source:'list',urls:['/x'],target_hint:'_blank'}]});document.head.appendChild(s);const ok=document.head.contains(s);s.remove();return ok;})()",
      "specSection": "https://wicg.github.io/nav-speculation/speculation-rules.html#target_hint"
    },
    {
      "id": "anchor-target-attribute-reflects",
      "description": "HTMLAnchorElement.prototype.target reflects target — the attribute target_hint mirrors.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('a');a.target='_blank';return a.target==='_blank';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/links.html#attr-hyperlink-target"
    },
    {
      "id": "no-vary-search-accepted-alongside",
      "description": "Speculation rules accept an expects_no_vary_search field alongside target_hint.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('script');s.type='speculationrules';try{s.textContent=JSON.stringify({prerender:[{source:'list',urls:['/x'],target_hint:'_self',expects_no_vary_search:'params'}]});return true;}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/nav-speculation/speculation-rules.html"
    },
    {
      "id": "prerender-rule-shape-accepted",
      "description": "Prerender rule with source=list and urls array is accepted shape — target_hint sits inside it.",
      "kind": "script",
      "test": "(()=>{try{JSON.parse(JSON.stringify({prerender:[{source:'list',urls:['/a'],target_hint:'_blank'}]}));return true;}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/nav-speculation/speculation-rules.html#prerender"
    }
  ]
