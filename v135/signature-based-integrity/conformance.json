      "description": "HTMLScriptElement.prototype.integrity reflects the integrity content attribute (string).",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('script');s.integrity='ed25519-AAAA';return s.integrity==='ed25519-AAAA';})()",
      "specSection": "https://wicg.github.io/signature-based-sri/#the-integrity-attribute"
    },
    {
      "id": "link-integrity-attribute-reflects",
      "description": "HTMLLinkElement.prototype.integrity reflects integrity (preload links also accept signatures).",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.integrity='ed25519-XYZ';return l.integrity==='ed25519-XYZ';})()",
      "specSection": "https://wicg.github.io/signature-based-sri/#the-integrity-attribute"
    },
    {
      "id": "ed25519-prefix-parses-as-string",
      "description": "The ed25519-* prefix is accepted as an integrity token (parsed lazily by the loader).",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('script');s.integrity='ed25519-AAAA sha384-BBBB';return s.integrity.includes('ed25519-');})()",
      "specSection": "https://wicg.github.io/signature-based-sri/#parsing-integrity-metadata"
    },
    {
      "id": "subtlecrypto-ed25519-feature-detectable",
      "description": "crypto.subtle is exposed — Ed25519 verification is performed via WebCrypto under the hood.",
      "kind": "exists",
      "test": "crypto.subtle",
      "specSection": "https://w3c.github.io/webcrypto/#dfn-Ed25519"
    },
    {
      "id": "fetch-integrity-option",
      "description": "fetch() accepts an integrity option in RequestInit — the dynamic-load path.",
      "kind": "script",
      "test": "(()=>{try{const r=new Request('/x',{integrity:'ed25519-AAAA'});return r.integrity==='ed25519-AAAA';}catch(e){return false;}})()",
      "specSection": "https://fetch.spec.whatwg.org/#concept-request-integrity-metadata"
