  "assertions": [
    {
      "id": "request-referrerpolicy-exposed",
      "description": "Request.prototype.referrerPolicy is exposed so redirect processing can re-evaluate the active policy.",
      "kind": "script",
      "test": "'referrerPolicy' in Request.prototype",
      "specSection": "https://fetch.spec.whatwg.org/#dom-request-referrerpolicy"
    },
    {
      "id": "request-redirect-mode-exposed",
      "description": "Request.prototype.redirect exposes the redirect mode used by the HTTP redirect fetch algorithm.",
      "kind": "script",
      "test": "'redirect' in Request.prototype",
      "specSection": "https://fetch.spec.whatwg.org/#dom-request-redirect"
    },
    {
      "id": "request-referrerpolicy-roundtrips",
      "description": "The Request constructor preserves a supplied referrerPolicy value.",
      "kind": "script",
      "test": "(()=>{const r=new Request('/probe',{referrerPolicy:'strict-origin-when-cross-origin'});return r.referrerPolicy==='strict-origin-when-cross-origin';})()",
      "specSection": "https://fetch.spec.whatwg.org/#concept-request-referrer-policy"
    },
    {
      "id": "post-request-keeps-body-before-redirect",
      "description": "A POST Request with a body exposes the body before redirect processing rewrites it.",
      "kind": "script",
      "test": "(()=>{const r=new Request('/probe',{method:'POST',body:'payload',headers:{'Content-Type':'text/plain'}});return r.method==='POST'&&r.headers.get('content-type').includes('text/plain')&&!!r.body;})()",
      "specSection": "https://fetch.spec.whatwg.org/#concept-request-body"
    },
    {
      "id": "response-redirect-creates-303",
      "description": "Response.redirect() can construct the 303 response shape that forces a redirected POST to become GET.",
      "kind": "script",
      "test": "(()=>{const r=Response.redirect('/after',303);return r.status===303&&r.headers.get('location').endsWith('/after');})()",
      "specSection": "https://fetch.spec.whatwg.org/#dom-response-redirect"
    },
    {
      "id": "response-redirect-creates-307",
      "description": "Response.redirect() can construct a 307 response, the redirect status that preserves method and body.",
      "kind": "script",
      "test": "(()=>{const r=Response.redirect('/after',307);return r.status===307&&r.headers.get('location').endsWith('/after');})()",
      "specSection": "https://fetch.spec.whatwg.org/#dom-response-redirect"
    }
  ]
