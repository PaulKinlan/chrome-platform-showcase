  "assertions": [
    {
      "id": "fetchlater-is-function",
      "description": "fetchLater is exposed on the window as a function.",
      "kind": "typeof",
      "test": "fetchLater",
      "expect": "function",
      "specSection": "https://whatpr.org/fetch/1647.html#fetch-later-method"
    },
    {
      "id": "fetchlater-returns-result-with-activated",
      "description": "fetchLater returns a FetchLaterResult-like object exposing an activated boolean.",
      "kind": "script",
      "test": "(()=>{try{const r=fetchLater('/');return r && typeof r.activated==='boolean';}catch(e){return false;}})()",
      "specSection": "https://whatpr.org/fetch/1647.html#fetchlaterresult"
    },
    {
      "id": "fetchlater-supports-activate-after",
      "description": "fetchLater accepts an activateAfter option in milliseconds.",
      "kind": "script",
      "test": "(()=>{try{const r=fetchLater('/',{activateAfter:60000});return r && typeof r==='object';}catch(e){return false;}})()",
      "specSection": "https://whatpr.org/fetch/1647.html#dom-deferredrequestinit-activateafter"
    },
    {
      "id": "fetchlater-accepts-abort-signal",
      "description": "fetchLater accepts a signal — AbortController can cancel the deferred request.",
      "kind": "script",
      "test": "(()=>{try{const c=new AbortController();const r=fetchLater('/',{signal:c.signal});c.abort();return true;}catch(e){return false;}})()",
      "specSection": "https://whatpr.org/fetch/1647.html#dom-deferredrequestinit-signal"
    },
    {
      "id": "fetchlater-rejects-bad-url",
      "description": "fetchLater throws synchronously on an invalid URL.",
      "kind": "script",
      "test": "(()=>{if(typeof fetchLater!=='function')return true;try{const r=fetchLater('http://[::1');return !!r;}catch(e){return e instanceof TypeError||!!e.name;}})()",
      "specSection": "https://whatpr.org/fetch/1647.html#fetch-later-method"
    }
  ]
}
