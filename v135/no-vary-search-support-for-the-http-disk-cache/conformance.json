      "kind": "typeof",
      "test": "fetch",
      "expect": "function",
      "specSection": "https://httpwg.org/http-extensions/draft-ietf-httpbis-no-vary-search.html#name-the-no-vary-search-response"
    },
    {
      "id": "headers-no-vary-search-allowed",
      "description": "Headers permits No-Vary-Search header name (so response headers can be inspected from JS).",
      "kind": "script",
      "test": "(()=>{try{const h=new Headers({'No-Vary-Search':'params'});return h.get('No-Vary-Search')==='params';}catch(e){return false;}})()",
      "specSection": "https://httpwg.org/http-extensions/draft-ietf-httpbis-no-vary-search.html"
    },
    {
      "id": "headers-key-order-list-valid",
      "description": "Headers accepts the key-order list syntax used by No-Vary-Search ('key-order, params=(\"x\")').",
      "kind": "script",
      "test": "(()=>{try{const h=new Headers({'No-Vary-Search':'key-order, params=(\"q\")'});return /key-order/.test(h.get('No-Vary-Search'));}catch(e){return false;}})()",
      "specSection": "https://httpwg.org/http-extensions/draft-ietf-httpbis-no-vary-search.html#name-the-key-order-parameter"
    },
    {
      "id": "speculation-rules-no-vary-search-supported",
      "description": "Speculation Rules (where No-Vary-Search was first wired up) is supported via document.scripting-side: HTMLScriptElement supports type=speculationrules.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('script');s.type='speculationrules';return s.type==='speculationrules';})()",
      "specSection": "https://wicg.github.io/nav-speculation/speculation-rules.html"
    },
    {
      "id": "request-cache-modes-supported",
      "description": "Request supports cache modes — the HTTP-cache surface that No-Vary-Search interacts with.",
      "kind": "script",
      "test": "(()=>{try{const r=new Request('/x',{cache:'default'});return r.cache==='default';}catch(e){return false;}})()",
      "specSection": "https://fetch.spec.whatwg.org/#concept-request-cache-mode"
