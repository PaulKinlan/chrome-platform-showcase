  "assertions": [
    {
      "id": "notification-exists",
      "description": "Notification is exposed — the API extended with incoming-call ergonomics.",
      "kind": "exists",
      "test": "Notification",
      "specSection": "https://notifications.spec.whatwg.org/#api"
    },
    {
      "id": "notification-permission-property",
      "description": "Notification.permission is a static property that returns the current permission string.",
      "kind": "script",
      "test": "['default','granted','denied'].includes(Notification.permission)",
      "specSection": "https://notifications.spec.whatwg.org/#dom-notification-permission"
    },
    {
      "id": "service-worker-registration-show-notification",
      "description": "ServiceWorkerRegistration.prototype.showNotification is the entry point used to display incoming-call notifications.",
      "kind": "script",
      "test": "typeof ServiceWorkerRegistration.prototype.showNotification==='function'",
      "specSection": "https://notifications.spec.whatwg.org/#dom-serviceworkerregistration-shownotification"
    },
    {
      "id": "notification-max-actions-non-negative",
      "description": "Notification.maxActions is a non-negative number — required for accept/decline call buttons.",
      "kind": "script",
      "test": "typeof Notification.maxActions==='number' && Notification.maxActions>=0",
      "specSection": "https://notifications.spec.whatwg.org/#dom-notification-maxactions"
    },
    {
      "id": "notification-requireinteraction-supported",
      "description": "requireInteraction option is supported — keeps the call notification visible until user acts.",
      "kind": "script",
      "test": "'requireInteraction' in Notification.prototype",
      "specSection": "https://notifications.spec.whatwg.org/#dom-notification-requireinteraction"
    }
