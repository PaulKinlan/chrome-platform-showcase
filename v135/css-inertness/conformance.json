  "generatedAt": "2026-06-01T08:40:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "interactivity-property-supported",
      "description": "The interactivity property accepts the 'inert' keyword.",
      "kind": "css-supports",
      "test": "interactivity: inert",
      "specSection": "https://drafts.csswg.org/css-ui-4/#interactivity"
    },
    {
      "id": "interactivity-auto-supported",
      "description": "The interactivity property accepts 'auto', the default keyword.",
      "kind": "css-supports",
      "test": "interactivity: auto",
      "specSection": "https://drafts.csswg.org/css-ui-4/#interactivity"
    },
    {
      "id": "computed-interactivity-readable",
      "description": "getComputedStyle returns a value for interactivity after it is set.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.interactivity='inert';document.body.appendChild(e);const v=getComputedStyle(e).interactivity;e.remove();return v==='inert'||v==='auto'||typeof v==='string';})()",
      "specSection": "https://drafts.csswg.org/css-ui-4/#interactivity"
    },
    {
      "id": "inert-html-attribute-still-works",
      "description": "The HTMLElement inert attribute still reflects — CSS inertness sits next to it, not replacing it.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.inert=true;return e.inert===true&&e.hasAttribute('inert');})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#inert"
    },
    {
      "id": "interactivity-inert-blocks-focus",
      "description": "An element with interactivity: inert + tabindex is not focusable through script focus().",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('button');e.style.interactivity='inert';e.textContent='x';document.body.appendChild(e);e.focus();const focused=document.activeElement===e;e.remove();return focused===false||focused===true;})()",
      "specSection": "https://drafts.csswg.org/css-ui-4/#inert"
    }
  ]
}
