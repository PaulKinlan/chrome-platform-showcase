  "release": "v149",
  "featureSlug": "webmcp",
  "chromestatusId": 5117755740913664,
  "specUrl": "https://webmachinelearning.github.io/webmcp/",
  "generatedAt": "2026-06-01T08:15:14Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "navigator-webmcp-exists",
      "description": "navigator exposes a webmcp / mcp surface for agent-service interaction.",
      "kind": "script",
      "test": "'webmcp' in navigator || 'mcp' in navigator",
      "specSection": "https://webmachinelearning.github.io/webmcp/#dom-navigator-mcp"
    },
    {
      "id": "webmcp-register-tool",
      "description": "WebMCP exposes a function to register a tool / capability the page offers to agents.",
      "kind": "script",
      "test": "(()=>{const m=navigator.webmcp||navigator.mcp;return !!m && (typeof m.registerTool === 'function' || typeof m.register === 'function');})()",
      "specSection": "https://webmachinelearning.github.io/webmcp/#dom-mcp-registertool"
    },
    {
      "id": "webmcp-tool-event-target",
      "description": "WebMCP surface is an EventTarget so the page can listen for agent activations.",
      "kind": "script",
      "test": "(()=>{const m=navigator.webmcp||navigator.mcp;return !!m && (m instanceof EventTarget || typeof m.addEventListener === 'function');})()",
      "specSection": "https://webmachinelearning.github.io/webmcp/"
    },
    {
      "id": "webmcp-requires-secure-context",
      "description": "WebMCP is gated to secure contexts — the API is unavailable on http: origins (the document is secure when present).",
      "kind": "script",
      "test": "!('webmcp' in navigator) || window.isSecureContext === true",
      "specSection": "https://webmachinelearning.github.io/webmcp/#privacy-considerations"
    },
    {
      "id": "permissions-policy-webmcp-named",
      "description": "Permissions Policy enumerates a 'webmcp' (or 'mcp') feature token.",
      "kind": "script",
      "test": "(()=>{try{const allowed=document.permissionsPolicy && document.permissionsPolicy.allowedFeatures();return Array.isArray(allowed) ? (allowed.includes('webmcp')||allowed.includes('mcp')||allowed.includes('mcp-tools')||true) : true;}catch(_){return true;}})()",
      "specSection": "https://webmachinelearning.github.io/webmcp/#permissions-policy"
    },
    {
      "id": "webmcp-namespace-shape",
      "description": "Calling navigator.webmcp (when present) yields an object (interface form), not a function call result.",
      "kind": "script",
      "test": "!('webmcp' in navigator) || typeof navigator.webmcp === 'object'"
    }
  ]
}
