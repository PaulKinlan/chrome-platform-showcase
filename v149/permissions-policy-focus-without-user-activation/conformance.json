      "description": "HTMLIFrameElement exposes an `allow` attribute, the surface that carries permissions-policy directives like focus-without-user-activation.",
      "kind": "script",
      "test": "'allow' in document.createElement('iframe')",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "permissions-policy-header-via-document-policy",
      "description": "Document exposes a featurePolicy or permissionsPolicy object so frames can introspect declared policies.",
      "kind": "script",
      "test": "('featurePolicy' in document) || ('permissionsPolicy' in document)"
    },
    {
      "id": "focus-method-is-function",
      "description": "HTMLElement.prototype.focus exists; the policy gates programmatic focus calls, so the API surface itself remains in place.",
      "kind": "typeof",
      "test": "HTMLElement.prototype.focus",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "autofocus-attribute-reflects",
      "description": "The autofocus attribute is reflected on HTMLElement and is one of the surfaces this policy governs in subframes.",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('input');i.autofocus=true;return i.hasAttribute('autofocus');})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "permissions-policy-supports-introspection",
      "description": "If a Permissions Policy interface is present, allowsFeature exists and is callable for policy introspection.",
      "kind": "script",
      "test": "(()=>{const p=document.permissionsPolicy||document.featurePolicy;return !!p && typeof p.allowsFeature==='function';})()"
