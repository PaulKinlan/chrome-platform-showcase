  "assertions": [
    {
      "id": "hover-pseudo-class-supported",
      "description": ":hover is supported in selectors (the user-action pseudo whose ancestor walk now stops at the top layer).",
      "kind": "script",
      "test": "CSS.supports('selector(:hover)')",
      "specSection": "https://www.w3.org/TR/selectors-4/#the-hover-pseudo"
    },
    {
      "id": "active-pseudo-class-supported",
      "description": ":active is supported.",
      "kind": "script",
      "test": "CSS.supports('selector(:active)')",
      "specSection": "https://www.w3.org/TR/selectors-4/#the-active-pseudo"
    },
    {
      "id": "focus-within-pseudo-class-supported",
      "description": ":focus-within is supported (the bubble-up pseudo with the new boundary).",
      "kind": "script",
      "test": "CSS.supports('selector(:focus-within)')",
      "specSection": "https://www.w3.org/TR/selectors-4/#the-focus-within-pseudo"
    },
    {
      "id": "dialog-show-modal-puts-in-top-layer",
      "description": "<dialog>.showModal places the element in the top layer (the boundary the spec stops :hover at).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('dialog');document.body.appendChild(d);try{d.showModal();const open=d.matches(':modal');d.close();d.remove();return open===true;}catch(_){d.remove();return false;}})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interactive-elements.html#dom-dialog-showmodal"
    },
    {
      "id": "popover-attribute-puts-in-top-layer",
      "description": "Elements with popover attribute also reach the top layer — equivalent boundary for :hover.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.popover='auto';document.body.appendChild(e);try{e.showPopover();const open=e.matches(':popover-open');e.hidePopover();e.remove();return open===true;}catch(_){e.remove();return false;}})()",
      "specSection": "https://html.spec.whatwg.org/multipage/popover.html#dom-htmlelement-showpopover"
    },
    {
      "id": "modal-pseudo-class-supported",
      "description": ":modal pseudo-class is supported (used to identify the top-layer boundary in selectors).",
      "kind": "script",
      "test": "CSS.supports('selector(:modal)')",
      "specSection": "https://html.spec.whatwg.org/multipage/semantics-other.html#selector-modal"
    }
  ]
