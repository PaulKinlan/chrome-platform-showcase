      "description": "path-length must reject <length> values like 100px — it is a unitless <number>.",
      "kind": "script",
      "test": "!CSS.supports('path-length', '100px')",
      "specSection": "https://svgwg.org/svg2-draft/paths.html#PathLengthAttribute"
    },
    {
      "id": "path-length-applies-to-svg-path",
      "description": "Setting style.pathLength on an SVG <path> round-trips via getComputedStyle.",
      "kind": "script",
      "test": "(()=>{const s='http://www.w3.org/2000/svg';const svg=document.createElementNS(s,'svg');const p=document.createElementNS(s,'path');p.setAttribute('d','M0 0 L100 0');svg.appendChild(p);document.body.appendChild(svg);p.style.setProperty('path-length','100');const v=getComputedStyle(p).getPropertyValue('path-length').trim();svg.remove();return v==='100';})()",
      "specSection": "https://svgwg.org/svg2-draft/paths.html#PathLengthAttribute"
    },
