  "assertions": [
    {
      "id": "table-element-supported",
      "description": "HTMLTableElement is exposed (the element whose UA border rule changed).",
      "kind": "exists",
      "test": "window.HTMLTableElement",
      "specSection": "https://html.spec.whatwg.org/multipage/tables.html#htmltableelement"
    },
    {
      "id": "table-default-border-color-is-not-gray",
      "description": "Default border-color on an unstyled <table> with border=1 is not the legacy 'gray' literal.",
      "kind": "script",
      "test": "(()=>{const t=document.createElement('table');t.setAttribute('border','1');document.body.appendChild(t);const v=getComputedStyle(t).borderTopColor;t.remove();return v !== 'rgb(128, 128, 128)';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/rendering.html#tables-2"
    },
    {
      "id": "table-border-resolves-against-current-color",
      "description": "A <table> with currentColor on a parent reflects through into border colour (legacy gray no longer wins).",
      "kind": "script",
      "test": "(()=>{const w=document.createElement('div');w.style.color='rgb(11, 22, 33)';const t=document.createElement('table');t.setAttribute('border','1');w.appendChild(t);document.body.appendChild(w);const v=getComputedStyle(t).borderTopColor;w.remove();return v==='rgb(11, 22, 33)';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/rendering.html#tables-2"
    },
    {
      "id": "border-style-property-supported",
      "description": "border-style is supported (UA stylesheet still drives style, only colour was wrong).",
      "kind": "css-supports",
      "test": "border-style: outset",
      "specSection": "https://www.w3.org/TR/CSS2/box.html#border-style-properties"
    },
    {
      "id": "border-color-currentcolor-supported",
      "description": "border-color: currentColor is supported — the value the UA stylesheet now defaults to.",
      "kind": "css-supports",
      "test": "border-color: currentColor",
      "specSection": "https://drafts.csswg.org/css-backgrounds-3/#border-color"
    },
    {
      "id": "td-default-border-currentcolor",
      "description": "Default <td> border colour also resolves to currentColor (parity with <table>).",
      "kind": "script",
      "test": "(()=>{const w=document.createElement('div');w.style.color='rgb(40, 60, 80)';const t=document.createElement('table');t.setAttribute('border','1');const tr=document.createElement('tr');const td=document.createElement('td');td.textContent='x';tr.appendChild(td);t.appendChild(tr);w.appendChild(t);document.body.appendChild(w);const v=getComputedStyle(td).borderTopColor;w.remove();return v==='rgb(40, 60, 80)' || v!=='rgb(128, 128, 128)';})()",
      "specSection": "https://html.spec.whatwg.org/multipage/rendering.html#tables-2"
    }
  ]
