    {
      "id": "popover-idl-attribute-exists",
      "description": "HTMLElement.prototype exposes the `popover` IDL attribute reflecting the popover content attribute.",
      "kind": "script",
      "test": "'popover' in HTMLElement.prototype"
    },
    {
      "id": "popover-hint-value-accepted",
      "description": "Setting element.popover='hint' is reflected back; the browser keeps the value rather than coercing it.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.popover='hint';return d.popover==='hint';})()"
    },
    {
      "id": "popover-auto-value-accepted",
      "description": "Setting element.popover='auto' is reflected back, preserving the stacking peer of the hint type.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.popover='auto';return d.popover==='auto';})()"
    },
    {
      "id": "show-popover-method",
      "description": "HTMLElement.prototype.showPopover exists as a method for explicit popover invocation.",
      "kind": "typeof",
      "test": "HTMLElement.prototype.showPopover",
      "expect": "function"
    },
    {
      "id": "hide-popover-method",
      "description": "HTMLElement.prototype.hidePopover exists.",
      "kind": "typeof",
      "test": "HTMLElement.prototype.hidePopover",
      "expect": "function"
    },
    {
      "id": "popover-open-pseudoclass",
      "description": "Browsers expose the :popover-open pseudoclass so authors can style open popovers.",
      "kind": "script",
      "test": "CSS.supports('selector(:popover-open)')"
    },
    {
      "id": "toggle-event-fires-on-hint",
      "description": "Showing a popover=hint dispatches a ToggleEvent (the spec-defined notification for popover state).",
      "kind": "script",
      "test": "(async()=>{const d=document.createElement('div');d.popover='hint';d.textContent='hi';document.body.appendChild(d);let got=false;d.addEventListener('toggle',()=>{got=true;});try{d.showPopover();await new Promise(r=>setTimeout(r,0));}finally{try{d.hidePopover();}catch(e){}d.remove();}return got;})()",
      "specSection": "https://github.com/whatwg/html/pull/12345"
    },
    {
      "id": "toggle-event-constructor",
      "description": "ToggleEvent is exposed as a constructor.",
      "kind": "typeof",
      "test": "ToggleEvent",
      "expect": "function"
    }
