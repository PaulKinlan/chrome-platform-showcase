    },
    {
      "id": "path-length-rejects-negative",
      "description": "path-length should not accept negative numbers per spec.",
      "kind": "script",
      "test": "!CSS.supports('path-length', '-50')",
      "specSection": "https://svgwg.org/svg2-draft/paths.html#PathLengthAttribute"
    },
    {
      "id": "path-length-overrides-presentation-attribute",
      "description": "When set via CSS on an SVG <path>, computed path-length reflects the CSS value, not the attribute.",
      "kind": "script",
      "test": "(()=>{const s='http://www.w3.org/2000/svg';const svg=document.createElementNS(s,'svg');const p=document.createElementNS(s,'path');p.setAttribute('d','M0 0 L100 0');p.setAttribute('pathLength','50');svg.appendChild(p);document.body.appendChild(svg);p.style.setProperty('path-length','200');const v=getComputedStyle(p).getPropertyValue('path-length').trim();svg.remove();return v==='200';})()",
      "specSection": "https://svgwg.org/svg2-draft/paths.html#PathLengthAttribute"
    },
    {
      "id": "path-length-animatable",
      "description": "path-length is animatable via the Web Animations API on SVG geometry.",
      "kind": "script",
      "test": "(()=>{const s='http://www.w3.org/2000/svg';const svg=document.createElementNS(s,'svg');const p=document.createElementNS(s,'path');p.setAttribute('d','M0 0 L100 0');svg.appendChild(p);document.body.appendChild(svg);try{const a=p.animate([{pathLength:'100'},{pathLength:'200'}],{duration:50});a.cancel();svg.remove();return true;}catch(_){svg.remove();return false;}})()",
      "specSection": "https://svgwg.org/svg2-draft/paths.html#PathLengthAttribute"
    }
  ]
