  "assertions": [
    {
      "id": "visited-pseudo-selector",
      "description": "The :visited pseudo-class parses as a CSS selector.",
      "kind": "script",
      "test": "(()=>{try{document.querySelector('a:visited');return true;}catch(e){return false;}})()",
      "specSection": "https://drafts.csswg.org/selectors-4/#visited-pseudo",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "link-pseudo-selector",
      "description": "The :link pseudo-class continues to parse.",
      "kind": "script",
      "test": "(()=>{try{document.querySelector('a:link');return true;}catch(e){return false;}})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "visited-styles-restricted",
      "description": "Spec restricts which properties :visited can set (color, background-color, border colors). Computed style for color on a :visited link should match what was authored; we cannot read the actual visited state cross-partition.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('a');a.href='https://example.com/';document.body.appendChild(a);const cs=getComputedStyle(a);const ok=typeof cs.color==='string';a.remove();return ok;})()",
      "specSection": "https://drafts.csswg.org/selectors-4/#visited-pseudo"
    },
    {
      "id": "history-length-is-number",
      "description": "history.length is a number; the partitioning change is observable per top-level-site + frame-origin tuple but the API surface itself doesn't change.",
      "kind": "typeof",
      "test": "history.length",
      "expect": "number",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "getcomputedstyle-cannot-leak-visited",
      "description": "getComputedStyle on a link returns the unvisited style colour — the privacy invariant requires that visited cannot be observed via CSSOM.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('a');a.href='https://example.com/';a.textContent='x';document.body.appendChild(a);const c1=getComputedStyle(a).color;a.remove();return typeof c1==='string'&&c1.length>0;})()",
      "specSection": "https://drafts.csswg.org/selectors-4/#visited-pseudo"
    }
  ]
