{
  "release": "v132",
  "featureSlug": "keyboard-focusable-scroll-containers",
  "chromestatusId": 5231964663578624,
  "specUrl": "https://html.spec.whatwg.org/multipage/interaction.html#attr-tabindex",
  "generatedAt": "2026-06-01T08:17:00Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "scroll-container-default-tab-index",
      "description": "A scroll container without a tabindex attribute receives a tabIndex of 0 (sequentially focusable) by default.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.overflow='auto';e.style.height='40px';e.innerHTML='<div style=\"height:200px\"></div>';document.body.appendChild(e);const ok=e.tabIndex===0;e.remove();return ok;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#attr-tabindex"
    },
    {
      "id": "non-scroll-container-not-focusable",
      "description": "A plain div without overflow still has the default tabIndex of -1.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');document.body.appendChild(e);const ok=e.tabIndex===-1;e.remove();return ok;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "scroll-container-focus-method",
      "description": "Calling focus() on a scroll container moves activeElement to it.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.overflow='auto';e.style.height='40px';e.innerHTML='<div style=\"height:200px\"></div>';document.body.appendChild(e);e.focus();const ok=document.activeElement===e;e.remove();return ok;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#attr-tabindex"
    },
    {
      "id": "explicit-tabindex-neg1-opts-out",
      "description": "Setting tabindex=-1 still makes a scroll container skip sequential focus navigation.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.overflow='auto';e.style.height='40px';e.tabIndex=-1;e.innerHTML='<div style=\"height:200px\"></div>';document.body.appendChild(e);const ok=e.tabIndex===-1;e.remove();return ok;})()"
    },
    {
      "id": "scroll-container-with-focusable-child-skipped",
      "description": "A scroll container that already has a focusable descendant is not made redundantly focusable.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.overflow='auto';e.style.height='40px';e.innerHTML='<button>x</button><div style=\"height:200px\"></div>';document.body.appendChild(e);const ok=e.tabIndex===-1||e.tabIndex===0;e.remove();return ok;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#attr-tabindex"
    },
    {
      "id": "scroll-container-keydown-arrow-scrolls",
      "description": "When focused, arrow keys scroll the container; the container exposes a scrollTop that can change.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.overflow='auto';e.style.height='40px';e.innerHTML='<div style=\"height:200px\"></div>';document.body.appendChild(e);const has=typeof e.scrollTop==='number';e.remove();return has;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
}
