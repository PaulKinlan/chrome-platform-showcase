      "description": "HTMLDialogElement fires a toggle event when shown.",
      "kind": "script",
      "test": "(()=>new Promise(r=>{const d=document.createElement('dialog');document.body.appendChild(d);d.addEventListener('toggle',()=>{d.close();d.remove();r(true);},{once:true});try{d.show();}catch(e){d.remove();r(false);}setTimeout(()=>{try{d.remove();}catch(_){};r(false);},500);}))()",
      "specSection": "https://html.spec.whatwg.org/multipage/interactive-elements.html#the-dialog-element"
    },
    {
      "id": "dialog-fires-beforetoggle",
      "description": "HTMLDialogElement supports beforetoggle as a cancellable precursor event.",
      "kind": "script",
      "test": "(()=>new Promise(r=>{const d=document.createElement('dialog');document.body.appendChild(d);d.addEventListener('beforetoggle',()=>{d.close();d.remove();r(true);},{once:true});try{d.show();}catch(e){d.remove();r(false);}setTimeout(()=>{try{d.remove();}catch(_){};r(false);},500);}))()",
