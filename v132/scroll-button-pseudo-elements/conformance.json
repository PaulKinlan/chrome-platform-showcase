    {
      "id": "scroll-button-supports-content",
      "description": "::scroll-button() pseudo elements accept generated content, just like ::before / ::after.",
      "kind": "script",
      "test": "(()=>{try{const s=new CSSStyleSheet();s.replaceSync('div::scroll-button(up){content:\"^\"}');return s.cssRules.length===1;}catch(e){return false;}})()",
      "specSection": "https://drafts.csswg.org/css-overflow-5/#scroll-buttons"
    },
    {
      "id": "scroll-button-disabled-pseudo-class",
      "description": "::scroll-button() participates in :disabled state when no further scrolling is possible in that direction.",
      "kind": "script",
      "test": "(()=>{try{const s=new CSSStyleSheet();s.replaceSync('div::scroll-button(up):disabled{opacity:0.5}');return s.cssRules.length===1;}catch(e){return false;}})()",
