    {
      "id": "interactivity-applies-inert-flag",
      "description": "Setting interactivity:inert in CSS makes a focusable child non-focusable via sequential focus.",
      "kind": "script",
      "test": "(()=>{const w=document.createElement('div');w.style.interactivity='inert';const b=document.createElement('button');b.textContent='x';w.appendChild(b);document.body.appendChild(w);b.focus();const ok=document.activeElement!==b;w.remove();return ok;})()",
      "specSection": "https://drafts.csswg.org/css-ui-4/#interactivity"
    },
