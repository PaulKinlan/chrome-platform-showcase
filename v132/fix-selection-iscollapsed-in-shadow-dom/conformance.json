    {
      "id": "iscollapsed-false-when-anchor-focus-differ",
      "description": "isCollapsed returns false when the selection spans distinct anchor and focus nodes.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('span');a.textContent='hello';const b=document.createElement('span');b.textContent='world';const w=document.createElement('div');w.appendChild(a);w.appendChild(b);document.body.appendChild(w);const r=document.createRange();r.setStart(a.firstChild,0);r.setEnd(b.firstChild,5);const s=window.getSelection();s.removeAllRanges();s.addRange(r);const ok=s.isCollapsed===false;s.removeAllRanges();w.remove();return ok;})()",
