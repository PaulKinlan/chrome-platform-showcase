  "assertions": [
    {
      "id": "clipboard-item-exists",
      "description": "ClipboardItem is exposed.",
      "kind": "exists",
      "test": "ClipboardItem",
      "specSection": "https://www.w3.org/TR/clipboard-apis/#clipboard-item-interface"
    },
    {
      "id": "clipboard-item-constructor-accepts-string",
      "description": "ClipboardItem constructor accepts a plain string value (not just a Blob), per the type alias change.",
      "kind": "script",
      "test": "(()=>{try{const c=new ClipboardItem({'text/plain':'hello'});return c instanceof ClipboardItem;}catch(e){return false;}})()",
      "specSection": "https://www.w3.org/TR/clipboard-apis/#typedefdef-clipboarditemdata"
    },
    {
      "id": "clipboard-item-constructor-accepts-promise-string",
      "description": "ClipboardItem constructor accepts a Promise<DOMString>.",
      "kind": "script",
      "test": "(()=>{try{const c=new ClipboardItem({'text/plain':Promise.resolve('hi')});return c instanceof ClipboardItem;}catch(e){return false;}})()",
      "specSection": "https://www.w3.org/TR/clipboard-apis/#typedefdef-clipboarditemdata"
    },
    {
      "id": "clipboard-item-constructor-accepts-blob",
      "description": "ClipboardItem constructor still accepts a Blob (the original surface is preserved).",
      "kind": "script",
      "test": "(()=>{try{const c=new ClipboardItem({'text/plain':new Blob(['x'],{type:'text/plain'})});return c instanceof ClipboardItem;}catch(e){return false;}})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "clipboard-item-types-property",
      "description": "A ClipboardItem exposes a types getter listing the MIME types it carries.",
      "kind": "script",
      "test": "(()=>{const c=new ClipboardItem({'text/plain':'x'});return Array.isArray(c.types)&&c.types[0]==='text/plain';})()",
      "specSection": "https://www.w3.org/TR/clipboard-apis/#dom-clipboarditem-types"
    },
    {
      "id": "clipboard-item-get-type-returns-blob",
      "description": "ClipboardItem.prototype.getType returns a Promise resolving to a Blob, even when constructed with a string.",
      "kind": "script",
      "test": "(async()=>{const c=new ClipboardItem({'text/plain':'hi'});const b=await c.getType('text/plain');return b instanceof Blob;})()",
      "specSection": "https://www.w3.org/TR/clipboard-apis/#dom-clipboarditem-gettype"
    }
  ]
}
