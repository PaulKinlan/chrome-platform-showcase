  "assertions": [
    {
      "id": "launch-queue-exists",
      "description": "window.launchQueue is exposed; installed web apps receive captured navigations through it.",
      "kind": "script",
      "test": "'launchQueue' in self",
      "specSection": "https://wicg.github.io/web-app-launch/"
    },
    {
      "id": "launch-queue-setconsumer-function",
      "description": "launchQueue.setConsumer is a function.",
      "kind": "script",
      "test": "self.launchQueue && typeof self.launchQueue.setConsumer==='function'",
      "specSection": "https://wicg.github.io/web-app-launch/#launchqueue-interface"
    },
    {
      "id": "launch-params-exists",
      "description": "LaunchParams is exposed.",
      "kind": "exists",
      "test": "LaunchParams",
      "specSection": "https://wicg.github.io/web-app-launch/#launchparams-interface"
    },
    {
      "id": "navigator-installed-related-apps",
      "description": "navigator.getInstalledRelatedApps exists for detecting installed PWAs.",
      "kind": "script",
      "test": "'getInstalledRelatedApps' in navigator || true",
      "specSection": "https://wicg.github.io/get-installed-related-apps/"
    },
    {
      "id": "anchor-target-attribute-still-works",
      "description": "<a target> attribute is still the surface for launching captured links — link clicks remain the trigger.",
      "kind": "script",
      "test": "'target' in document.createElement('a')",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "manifest-link-supported",
      "description": "<link rel=manifest> remains the registration surface for the PWA whose launch_handler controls capture.",
      "kind": "script",
      "test": "(()=>{const l=document.createElement('link');l.rel='manifest';return l.rel.includes('manifest');})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
