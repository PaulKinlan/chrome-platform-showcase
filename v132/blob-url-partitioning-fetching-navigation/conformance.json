    {
      "id": "blob-url-from-blob",
      "description": "Calling URL.createObjectURL with a Blob returns a blob: URL string.",
      "kind": "script",
      "test": "(()=>{const u=URL.createObjectURL(new Blob(['x']));const ok=u.startsWith('blob:');URL.revokeObjectURL(u);return ok;})()",
      "specSection": "https://w3c.github.io/FileAPI/#BlobURLStore"
    },
    {
      "id": "blob-url-fetchable-same-partition",
      "description": "A blob: URL created in this document is fetchable from this same document (same storage key).",
      "kind": "script",
      "test": "(async()=>{const u=URL.createObjectURL(new Blob(['hello']));try{const t=await(await fetch(u)).text();URL.revokeObjectURL(u);return t==='hello';}catch(e){URL.revokeObjectURL(u);return false;}})()",
      "specSection": "https://w3c.github.io/FileAPI/#BlobURLStore"
    },
    {
      "id": "blob-supports-bytes-method",
      "description": "Blob exposes a bytes() method (Body mixin) so blob URLs can be introspected.",
      "kind": "script",
      "test": "'bytes' in Blob.prototype",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
