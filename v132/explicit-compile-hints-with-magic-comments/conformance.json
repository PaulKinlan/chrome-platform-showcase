      "test": "(()=>{try{new Function('//# allFunctionsCalledOnLoad\\nreturn 1;')();return true;}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/explicit-javascript-compile-hints-file-based/"
    },
    {
      "id": "script-execution-unchanged-by-hint",
      "description": "Adding the magic comment does not change the function's observable behaviour — it's a compile hint only.",
      "kind": "script",
      "test": "(()=>{const f=new Function('//# allFunctionsCalledOnLoad\\nreturn 42;');return f()===42;})()",
      "specSection": "https://wicg.github.io/explicit-javascript-compile-hints-file-based/"
    },
    {
      "id": "magic-comment-is-comment",
      "description": "The magic comment is a JS comment so it is ignored by older engines that don't recognise it.",
      "kind": "script",
