  "assertions": [
    {
      "id": "showpopover-on-detached-throws",
      "description": "Calling showPopover() on an element whose document is not fully active throws.",
      "kind": "throws",
      "test": "(()=>{const i=document.createElement('iframe');document.body.appendChild(i);const d=i.contentDocument;const el=d.createElement('div');el.popover='auto';d.body.appendChild(el);i.remove();el.showPopover();})()",
      "specSection": "https://html.spec.whatwg.org/multipage/popover.html#dom-showpopover"
    },
    {
      "id": "showmodal-on-detached-throws",
      "description": "HTMLDialogElement.showModal() throws when the document is not fully active.",
      "kind": "throws",
      "test": "(()=>{const i=document.createElement('iframe');document.body.appendChild(i);const d=i.contentDocument;const dl=d.createElement('dialog');d.body.appendChild(dl);i.remove();dl.showModal();})()",
      "specSection": "https://html.spec.whatwg.org/multipage/interactive-elements.html#dom-dialog-showmodal"
    },
    {
      "id": "show-on-detached-throws",
      "description": "HTMLDialogElement.show() throws when the document is not fully active.",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('iframe');document.body.appendChild(i);const d=i.contentDocument;const dl=d.createElement('dialog');d.body.appendChild(dl);i.remove();try{dl.show();return true;}catch(e){return e&&!!e.name;}})()"
    },
    {
      "id": "showpopover-on-active-doc-still-works",
      "description": "showPopover() in the current, active document continues to work — only inactive docs throw.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.popover='auto';document.body.appendChild(e);try{e.showPopover();const ok=e.matches(':popover-open');e.hidePopover();e.remove();return ok;}catch(_){e.remove();return false;}})()",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    },
    {
      "id": "popover-api-exists",
      "description": "The popover API surface is present — without it the new error contract would be moot.",
      "kind": "script",
      "test": "'showPopover' in document.createElement('div') && 'hidePopover' in document.createElement('div')",
      "expectedBrowsers": [
        "chrome",
        "firefox",
        "safari"
      ]
    }
  ]
