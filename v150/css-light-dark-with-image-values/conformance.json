      "test": "color: light-dark(black, white)",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "light-dark-with-urls",
      "description": "background-image accepts light-dark() with url() values per the extended spec.",
      "kind": "css-supports",
      "test": "background-image: light-dark(url(light.png), url(dark.png))",
      "specSection": "https://drafts.csswg.org/css-color-5/#light-dark"
    },
    {
      "id": "light-dark-with-image-set",
      "description": "light-dark() accepts image-set() arguments.",
      "kind": "css-supports",
      "test": "background-image: light-dark(image-set(url(a.png) 1x), image-set(url(b.png) 1x))"
    },
    {
      "id": "light-dark-with-none",
      "description": "light-dark() accepts the 'none' keyword as an image-valued branch (to suppress the image in one scheme).",
      "kind": "css-supports",
      "test": "background-image: light-dark(url(only-light.png), none)"
    },
    {
      "id": "light-dark-on-cursor",
      "description": "cursor accepts a light-dark() image value (image-typed properties beyond background-image are covered).",
      "kind": "css-supports",
      "test": "cursor: light-dark(url(a.png), url(b.png)), auto"
    },
    {
      "id": "light-dark-image-roundtrip",
      "description": "background-image: light-dark(url, url) round-trips via getComputedStyle (computed value contains 'light-dark' or the resolved url).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.backgroundImage='light-dark(url(a.png), url(b.png))';document.body.appendChild(e);const v=getComputedStyle(e).backgroundImage;e.remove();return v.includes('url') || v.includes('light-dark');})()"
    }
  ]
