    },
    {
      "id": "flex-wrap-balance-roundtrip",
      "description": "flex-wrap: balance round-trips via getComputedStyle.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.display='flex';e.style.flexWrap='balance';document.body.appendChild(e);const v=getComputedStyle(e).flexWrap;e.remove();return v==='balance';})()"
    },
    {
      "id": "flex-wrap-balance-distributes-items",
      "description": "10 fixed-width children inside a flex container with flex-wrap: balance produce >=2 wrap lines (observable via line offsetTop differences).",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('div');c.style.cssText='display:flex;flex-wrap:balance;width:240px;';for(let i=0;i<10;i++){const x=document.createElement('span');x.style.cssText='display:inline-block;width:60px;height:20px;';c.appendChild(x);}document.body.appendChild(c);const tops=new Set([...c.children].map(e=>e.offsetTop));c.remove();return tops.size>=2;})()"
    }
