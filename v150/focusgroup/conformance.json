  "assertions": [
    {
      "id": "focusgroup-attribute-reflected",
      "description": "HTMLElement reflects a focusgroup IDL attribute mirroring the focusgroup content attribute.",
      "kind": "script",
      "test": "'focusgroup' in document.createElement('div')",
      "specSection": "https://github.com/whatwg/html/pull/11723"
    },
    {
      "id": "focusgroup-empty-string",
      "description": "Setting the focusgroup content attribute (no value) is accepted — it enables a default focusgroup.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.setAttribute('focusgroup','');return d.hasAttribute('focusgroup');})()"
    },
    {
      "id": "focusgroup-wrap-token",
      "description": "focusgroup accepts the 'wrap' token (arrow navigation wraps at the ends).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.setAttribute('focusgroup','wrap');return d.getAttribute('focusgroup')==='wrap';})()"
    },
    {
      "id": "focusgroup-grid-token",
      "description": "focusgroup accepts 'grid' as a token (two-dimensional arrow navigation).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.setAttribute('focusgroup','grid');return d.getAttribute('focusgroup')==='grid';})()"
    },
    {
      "id": "tabindex-still-honored",
      "description": "tabindex IDL attribute remains exposed on HTMLElement — focusgroup composes with, not replaces, tabindex semantics.",
      "kind": "script",
      "test": "'tabIndex' in document.createElement('button')",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "arrow-navigation-via-keydown",
      "description": "Synthetically dispatching an ArrowRight keydown to the first child of a focusgroup does not throw — listeners can observe and the default action is gated by focusgroup.",
      "kind": "script",
      "test": "(()=>{try{const fg=document.createElement('div');fg.setAttribute('focusgroup','');const a=document.createElement('button');a.textContent='A';const b=document.createElement('button');b.textContent='B';fg.appendChild(a);fg.appendChild(b);document.body.appendChild(fg);a.focus();a.dispatchEvent(new KeyboardEvent('keydown',{key:'ArrowRight',bubbles:true}));fg.remove();return true;}catch(_){return false;}})()"
    }
  ]
}
