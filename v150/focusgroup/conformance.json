    {
      "id": "focusgroup-idl-attribute",
      "description": "HTMLElement exposes the focusgroup IDL attribute used for feature detection.",
      "kind": "script",
      "test": "'focusgroup' in HTMLElement.prototype",
      "specSection": "https://developer.chrome.com/blog/focusgroup-rfc#feature_detection",
      "expectedBrowsers": ["chrome"]
    },
    {
      "id": "focusgroup-current-toolbar-syntax-reflects",
      "description": "The current toolbar syntax reflects through the IDL and content attributes.",
      "kind": "script",
      "test": "(()=>{const el=document.createElement('div');el.focusgroup='toolbar wrap';return el.focusgroup==='toolbar wrap'&&el.getAttribute('focusgroup')==='toolbar wrap';})()",
      "specSection": "https://open-ui.org/components/scoped-focusgroup.explainer/#index-of-focusgroup-values",
      "expectedBrowsers": ["chrome"]
    },
    {
      "id": "focusgroup-behavior-token-examples-reflect",
      "description": "Scoped behavior-token examples for toolbar, tablist, radiogroup, listbox, menu, menubar, and none are representable as focusgroup values.",
      "kind": "script",
      "test": "(()=>['toolbar wrap','tablist nomemory','radiogroup block nomemory','listbox wrap nomemory','menu','menubar','none'].every(value=>{const el=document.createElement('div');el.focusgroup=value;return el.focusgroup===value&&el.getAttribute('focusgroup')===value;}))()",
      "specSection": "https://developer.chrome.com/blog/focusgroup-rfc#behavior_tokens",
      "expectedBrowsers": ["chrome"]
    },
    {
      "id": "focusgroupstart-entry-marker",
      "description": "The focusgroupstart marker can be represented on a focusable item to declare the entry point.",
      "kind": "script",
      "test": "(()=>{const button=document.createElement('button');button.setAttribute('focusgroupstart','');return button.hasAttribute('focusgroupstart');})()",
      "specSection": "https://developer.chrome.com/blog/focusgroup-rfc#the_focusgroupstart_attribute",
      "expectedBrowsers": ["chrome"]
    },
    {
      "id": "tabindex-composes-with-focusgroup",
      "description": "Custom focusgroup items can still opt into focusability with tabindex, which focusgroup then composes with.",
      "kind": "script",
      "test": "(()=>{const item=document.createElement('div');item.tabIndex=0;return item.tabIndex===0&&item.getAttribute('tabindex')==='0';})()",
      "specSection": "https://developer.chrome.com/blog/focusgroup-rfc#deep_descendant_discovery",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
