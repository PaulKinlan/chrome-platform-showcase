    {
      "id": "focusgroup-content-attribute-values",
      "description": "The behavior-token strings used by the demos are represented as focusgroup content attributes.",
      "kind": "script",
      "test": "(()=>['toolbar wrap','tablist nomemory','radiogroup block nomemory','listbox wrap nomemory','menu','menubar','none'].every(value=>{const el=document.createElement('div');el.setAttribute('focusgroup',value);return el.getAttribute('focusgroup')===value&&el.matches('[focusgroup]');}))()",
      "specSection": "https://open-ui.org/components/scoped-focusgroup.explainer/#index-of-focusgroup-values",
      "expectedBrowsers": [
        "chrome"
      ]
    },
    {
      "id": "focusgroupstart-entry-marker",
      "description": "The focusgroupstart marker is represented as a content attribute on the item that should receive deterministic entry focus.",
      "kind": "script",
      "test": "(()=>{const button=document.createElement('button');button.setAttribute('focusgroupstart','');return button.hasAttribute('focusgroupstart')&&button.matches('[focusgroupstart]');})()",
      "specSection": "https://developer.chrome.com/blog/focusgroup-rfc#the_focusgroupstart_attribute",
      "expectedBrowsers": [
        "chrome"
      ]
    },
    {
      "id": "toolbar-demo-declares-toolbar-wrap",
      "description": "The toolbar concept declares the toolbar behavior token and wrap modifier on the toolbar container.",
      "kind": "script",
      "test": "(async()=>{const html=await fetch('/v150/focusgroup/toolbar-demo/').then(r=>r.text());const doc=new DOMParser().parseFromString(html,'text/html');const toolbar=doc.querySelector('[role=\"toolbar\"]');return toolbar?.getAttribute('focusgroup')==='toolbar wrap'&&toolbar.querySelectorAll('button').length>=3&&doc.querySelectorAll('[onkeydown]').length===0&&![...doc.scripts].some(script=>script.textContent.includes('keydown'));})()",
      "specSection": "https://open-ui.org/components/scoped-focusgroup.explainer/#index-of-focusgroup-values",
      "expectedBrowsers": [
        "chrome"
      ]
    },
    {
      "id": "radiogroup-demo-declares-block-nomemory",
      "description": "The radio group concept declares radiogroup, block, and nomemory tokens and marks the initial radio with focusgroupstart.",
      "kind": "script",
      "test": "(async()=>{const html=await fetch('/v150/focusgroup/radio-group/').then(r=>r.text());const doc=new DOMParser().parseFromString(html,'text/html');const group=doc.querySelector('[role=\"radiogroup\"][focusgroup]');return group?.getAttribute('focusgroup')==='radiogroup block nomemory'&&group.querySelectorAll('[role=\"radio\"]').length===4&&!!group.querySelector('[role=\"radio\"][focusgroupstart]');})()",
      "specSection": "https://open-ui.org/components/scoped-focusgroup.explainer/#index-of-focusgroup-values",
      "expectedBrowsers": [
        "chrome"
      ]
    },
    {
      "id": "custom-radio-items-compose-with-tabindex",
      "description": "The roving-tabindex comparison uses custom role=radio elements that opt into focusability with tabindex inside a focusgroup.",
      "kind": "script",
      "test": "(async()=>{const html=await fetch('/v150/focusgroup/roving-tabindex-compare/').then(r=>r.text());const doc=new DOMParser().parseFromString(html,'text/html');const group=doc.querySelector('[role=\"radiogroup\"][focusgroup]');return group?.getAttribute('focusgroup')==='radiogroup block nomemory'&&[...group.querySelectorAll('[role=\"radio\"]')].every(item=>item.getAttribute('tabindex')==='0');})()",
      "specSection": "https://developer.chrome.com/blog/focusgroup-rfc#deep_descendant_discovery",
      "expectedBrowsers": [
        "chrome"
      ]
    },
    {
      "id": "menu-bar-declares-menubar-and-menu-focusgroups",
      "description": "The menu bar concept declares a menubar focusgroup for top-level items and menu focusgroups for submenus.",
      "kind": "script",
      "test": "(async()=>{const html=await fetch('/v150/focusgroup/menu-bar/').then(r=>r.text());const doc=new DOMParser().parseFromString(html,'text/html');const menubar=doc.querySelector('#menuBar[role=\"menubar\"][focusgroup=\"menubar\"]');const menus=[...doc.querySelectorAll('#menuBar [role=\"menu\"][focusgroup=\"menu\"]')];const comparison=doc.querySelector('[aria-label=\"Comparison focusgroup menubar\"][focusgroup=\"menubar\"]');return !!menubar&&menus.length===4&&!!comparison;})()",
      "specSection": "https://open-ui.org/components/scoped-focusgroup.explainer/#index-of-focusgroup-values",
      "expectedBrowsers": [
        "chrome"
      ]
    },
    {
      "id": "grid-navigation-declares-listbox-focusgroups",
      "description": "The visual grid concept declares listbox focusgroups and option children for both picker widgets.",
      "kind": "script",
      "test": "(async()=>{const html=await fetch('/v150/focusgroup/grid-navigation/').then(r=>r.text());const doc=new DOMParser().parseFromString(html,'text/html');const grids=[doc.querySelector('#color-grid[role=\"listbox\"][focusgroup=\"listbox wrap nomemory\"]'),doc.querySelector('#emoji-grid[role=\"listbox\"][focusgroup=\"listbox wrap nomemory\"]')];return grids.every(Boolean)&&html.includes(\"setAttribute('role', 'option')\")&&html.includes('focusgroupstart');})()",
      "specSection": "https://open-ui.org/components/scoped-focusgroup.explainer/#index-of-focusgroup-values",
