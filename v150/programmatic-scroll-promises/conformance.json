      "description": "Element.scrollTo returns a Promise when called on an attached scrollable element.",
      "kind": "script",
      "test": "(()=>{const scroller=document.createElement('div');scroller.style.cssText='position:fixed;left:-9999px;top:0;width:100px;height:40px;overflow:auto';const child=document.createElement('div');child.style.height='180px';scroller.appendChild(child);document.body.appendChild(scroller);try{return scroller.scrollTo({top:20,behavior:'instant'}) instanceof Promise;}finally{scroller.remove();}})()",
      "specSection": "https://drafts.csswg.org/cssom-view/#dom-element-scrollto"
    },
    {
      "id": "element-scroll-to-promise-resolves-at-position",
      "description": "Awaiting Element.scrollTo resolves after the element reaches the requested position.",
      "kind": "script",
      "test": "(async()=>{const scroller=document.createElement('div');scroller.style.cssText='position:fixed;left:-9999px;top:0;width:100px;height:40px;overflow:auto';const child=document.createElement('div');child.style.height='220px';scroller.appendChild(child);document.body.appendChild(scroller);try{const result=scroller.scrollTo({top:80,behavior:'instant'});if(!(result instanceof Promise))return false;return await Promise.race([result.then(()=>Math.round(scroller.scrollTop)===80,()=>false),new Promise(resolve=>setTimeout(()=>resolve(false),1000))]);}finally{scroller.remove();}})()",
      "specSection": "https://drafts.csswg.org/cssom-view/#dom-element-scrollto"
