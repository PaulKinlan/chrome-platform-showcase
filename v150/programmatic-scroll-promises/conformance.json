      "kind": "script",
      "test": "(async()=>{const scroller=document.createElement('div');scroller.style.cssText='height:40px;overflow:auto';const child=document.createElement('div');child.style.height='180px';scroller.appendChild(child);document.body.appendChild(scroller);try{const result=scroller.scrollBy({top:60,behavior:'instant'});if(!(result instanceof Promise))return false;await result;return Math.round(scroller.scrollTop)===60;}finally{scroller.remove();}})()",
