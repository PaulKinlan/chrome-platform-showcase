    {
      "id": "element-scroll-to-returns-promise",
      "description": "Element.scrollTo returns a Promise when called on a scrollable element.",
      "kind": "script",
      "test": "(()=>{const scroller=document.createElement('div');scroller.style.cssText='height:40px;overflow:auto';const child=document.createElement('div');child.style.height='160px';scroller.appendChild(child);document.body.appendChild(scroller);try{const result=scroller.scrollTo({top:20,behavior:'instant'});return result instanceof Promise;}finally{scroller.remove();}})()",
      "specSection": "https://drafts.csswg.org/cssom-view/#dom-element-scrollto"
    },
    {
      "id": "element-scroll-to-promise-resolves-at-position",
      "description": "Awaiting Element.scrollTo resolves after the element reaches the requested position.",
      "kind": "script",
      "test": "(async()=>{const scroller=document.createElement('div');scroller.style.cssText='height:40px;overflow:auto';const child=document.createElement('div');child.style.height='180px';scroller.appendChild(child);document.body.appendChild(scroller);try{const result=scroller.scrollTo({top:80,behavior:'instant'});if(!(result instanceof Promise))return false;await result;return Math.round(scroller.scrollTop)===80;}finally{scroller.remove();}})()",
      "specSection": "https://drafts.csswg.org/cssom-view/#dom-element-scrollto"
    },
