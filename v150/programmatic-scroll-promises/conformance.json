      "kind": "script",
      "test": "(()=>{const scroller=document.createElement('div');scroller.style.cssText='height:40px;overflow:auto';const spacer=document.createElement('div');spacer.style.height='120px';const target=document.createElement('div');target.textContent='target';scroller.append(spacer,target);document.body.appendChild(scroller);try{const result=target.scrollIntoView({behavior:'instant',block:'nearest'});return result instanceof Promise;}finally{scroller.remove();}})()",
