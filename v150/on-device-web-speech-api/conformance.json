  "assertions": [
    {
      "id": "speech-recognition-exposed",
      "description": "SpeechRecognition (or webkitSpeechRecognition) is exposed.",
      "kind": "script",
      "test": "'SpeechRecognition' in window || 'webkitSpeechRecognition' in window"
    },
    {
      "id": "process-locally-property",
      "description": "SpeechRecognition.prototype exposes a processLocally accessor used to request on-device processing.",
      "kind": "script",
      "test": "(()=>{const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR)return false;return 'processLocally' in SR.prototype;})()",
      "specSection": "https://webaudio.github.io/web-speech-api"
    },
    {
      "id": "available-static-method",
      "description": "SpeechRecognition.available({langs:['en-US']}) is a static method returning a Promise.",
      "kind": "script",
      "test": "(()=>{const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR)return false;return typeof SR.available==='function';})()"
    },
    {
      "id": "install-static-method",
      "description": "SpeechRecognition.install() is a static method (for downloading the on-device language model).",
      "kind": "script",
      "test": "(()=>{const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR)return false;return typeof SR.install==='function';})()"
    },
    {
      "id": "continuous-recognition-still-supported",
      "description": "The continuous accessor is still present (on-device mode still respects baseline knobs).",
      "kind": "script",
      "test": "(()=>{const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR)return false;return 'continuous' in SR.prototype;})()"
    },
    {
      "id": "process-locally-default-false",
      "description": "A freshly constructed SpeechRecognition has processLocally set to a boolean (default false).",
      "kind": "script",
      "test": "(()=>{const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR)return false;try{const r=new SR();return typeof r.processLocally==='boolean';}catch(_){return false;}})()"
    }
  ]
