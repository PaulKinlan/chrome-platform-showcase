  "specUrl": "https://drafts.csswg.org/css-viewport/#zoom-property",
  "generatedAt": "2026-06-01T08:14:34Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "zoom-property-supported",
      "description": "The CSS zoom property is recognised; zoom: 1 parses via CSS.supports.",
      "kind": "css-supports",
      "test": "zoom: 1"
    },
    {
      "id": "zoom-accepts-number",
      "description": "zoom accepts a unitless <number> value in the new standard syntax.",
      "kind": "css-supports",
      "test": "zoom: 1.5"
    },
    {
      "id": "zoom-accepts-percentage",
      "description": "zoom accepts <percentage> values per the standardised spec.",
      "kind": "css-supports",
      "test": "zoom: 150%"
    },
    {
      "id": "zoom-computed-to-number",
      "description": "Computed value of zoom is a number string (e.g. '1.5'), not the literal '150%' — the spec normalises percentages to numbers.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.style.zoom='200%';document.body.appendChild(e);const v=getComputedStyle(e).zoom;e.remove();return v==='2'||v==='2.0'||parseFloat(v)===2;})()"
    },
    {
      "id": "zoom-animates-via-waapi",
      "description": "zoom is now animatable: Element.animate accepts zoom keyframes without throwing.",
      "kind": "script",
      "test": "(()=>{try{const e=document.createElement('div');document.body.appendChild(e);const a=e.animate([{zoom:1},{zoom:2}],{duration:50});a.cancel();e.remove();return true;}catch(_){return false;}})()",
      "specSection": "https://drafts.csswg.org/css-viewport/#zoom-property"
    },
    {
      "id": "zoom-inherits-into-length-resolution",
      "description": "zoom affects resolved length properties on descendants (e.g. computed width scales with zoom).",
      "kind": "script",
      "test": "(()=>{const p=document.createElement('div');p.style.zoom='2';const c=document.createElement('div');c.style.width='50px';p.appendChild(c);document.body.appendChild(p);const w=parseFloat(getComputedStyle(c).width);p.remove();return w>=80;})()"
    }
  ]
