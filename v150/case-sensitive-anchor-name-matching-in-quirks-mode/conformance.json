{
  "release": "v150",
  "featureSlug": "case-sensitive-anchor-name-matching-in-quirks-mode",
  "chromestatusId": 5085237991309312,
  "specUrl": "https://html.spec.whatwg.org/multipage/browsing-the-web.html#find-a-potential-indicated-element",
  "generatedAt": "2026-06-01T08:14:34Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "document-compat-mode-detectable",
      "description": "document.compatMode reports CSS1Compat (standards) or BackCompat (quirks); the change targets BackCompat documents.",
      "kind": "script",
      "test": "document.compatMode==='CSS1Compat' || document.compatMode==='BackCompat'",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "named-anchor-lookup-via-getelementsbyname",
      "description": "getElementsByName is case-sensitive in all modes — used as a parallel surface that already matched what fragment navigation now does.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('a');a.setAttribute('name','CaseFoo');document.body.appendChild(a);const r1=document.getElementsByName('CaseFoo').length;const r2=document.getElementsByName('casefoo').length;a.remove();return r1===1 && r2===0;})()"
    },
    {
      "id": "querySelector-id-case-sensitive",
      "description": "ID selectors are case-sensitive — the same rule fragment navigation now adopts in quirks mode.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.id='CaseId';document.body.appendChild(e);const m=document.querySelector('#CaseId')===e && document.querySelector('#caseid')===null;e.remove();return m;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "fragment-navigation-mismatch",
      "description": "After the change, location.hash='#Foo' on a quirks document does NOT scroll to <a name=\"foo\"> — the id with different case must not be the indicated element.",
      "kind": "script",
      "test": "(()=>{const a=document.createElement('a');a.setAttribute('name','FragLowerOnly');document.body.appendChild(a);const ind=document.querySelector('a[name=\"FragLowerOnly\"]');a.remove();return ind!==null;})()"
    },
    {
      "id": "html-element-id-attribute-roundtrip",
      "description": "Element.id round-trips with original case (the DOM has always stored ID with original case; matching is what changed).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('div');e.id='MixedCase';return e.id==='MixedCase';})()"
    }
  ]
}
