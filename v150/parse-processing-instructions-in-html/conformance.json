{
  "release": "v150",
  "featureSlug": "parse-processing-instructions-in-html",
  "chromestatusId": 6534495085920256,
  "specUrl": "https://github.com/whatwg/html/pull/12118",
  "generatedAt": "2026-06-01T08:14:34Z",
  "author": "conformance-author-v1-subagent",
  "assertions": [
    {
      "id": "processing-instruction-node-type",
      "description": "Node.PROCESSING_INSTRUCTION_NODE is exposed (existing constant, used by HTML parser output).",
      "kind": "script",
      "test": "Node.PROCESSING_INSTRUCTION_NODE===7",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "html-parser-creates-pi-nodes",
      "description": "Parsing HTML containing <?target data?> via innerHTML produces a ProcessingInstruction node in the DOM (previously the HTML parser dropped these into comments).",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.innerHTML='<?range-start id=\"x\"?>text';const child=d.firstChild;return child && child.nodeType===Node.PROCESSING_INSTRUCTION_NODE;})()",
      "specSection": "https://github.com/whatwg/html/pull/12118"
    },
    {
      "id": "pi-target-roundtrip",
      "description": "The PI's target is preserved through HTML parsing.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.innerHTML='<?range-start id=\"x\"?>';const pi=d.firstChild;return pi && pi.target==='range-start';})()"
    },
    {
      "id": "pi-data-roundtrip",
      "description": "PI data is preserved through HTML parsing.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.innerHTML='<?range-start id=\"x\"?>';const pi=d.firstChild;return pi && /id=\"x\"/.test(pi.data);})()"
    },
    {
      "id": "create-processing-instruction-still-works",
      "description": "document.createProcessingInstruction continues to work in HTML documents (was already permitted for XML; explicitly now also useful for HTML use cases).",
      "kind": "script",
      "test": "(()=>{try{const pi=document.createProcessingInstruction('range-end','id=\"x\"');return pi.target==='range-end';}catch(_){return false;}})()"
    },
    {
      "id": "pi-survives-cloning",
      "description": "A PI node survives cloneNode(true) of its parent.",
      "kind": "script",
      "test": "(()=>{const d=document.createElement('div');d.innerHTML='<?range-start?>';const c=d.cloneNode(true);return c.firstChild && c.firstChild.nodeType===Node.PROCESSING_INSTRUCTION_NODE;})()"
    }
  ]
}
