  "author": "codex-pi-streaming-repair",
  "assertions": [
    {
      "id": "innerhtml-creates-processing-instruction",
      "description": "The HTML fragment parser creates a ProcessingInstruction node for allowed <?target data?> syntax.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');host.innerHTML='<?range-start id=\"x\"?>text';const node=host.firstChild;return !!node&&node.nodeType===Node.PROCESSING_INSTRUCTION_NODE&&node.constructor.name==='ProcessingInstruction';})()",
      "specSection": "https://github.com/whatwg/html/pull/12118"
    },
    {
      "id": "target-and-data-roundtrip",
      "description": "The PI target and data are preserved when HTML markup is parsed.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');host.innerHTML='<?stream-start name=\"recommendations\" phase=\"placeholder\"?>';const node=host.firstChild;return !!node&&node.target==='stream-start'&&node.data.includes('name=\"recommendations\"')&&node.data.includes('phase=\"placeholder\"');})()",
      "specSection": "https://github.com/whatwg/html/pull/12118"
    },
    {
      "id": "target-is-ascii-lowercased",
      "description": "HTML PI targets are ASCII-lowercased by the parser.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');host.innerHTML='<?Stream-Start name=\"Hero\"?>';const node=host.firstChild;return !!node&&node.nodeType===Node.PROCESSING_INSTRUCTION_NODE&&node.target==='stream-start';})()",
      "specSection": "https://github.com/whatwg/html/pull/12118"
    },
    {
      "id": "domparser-text-html-creates-pi",
      "description": "DOMParser with text/html also exposes allowed processing instructions as PI nodes.",
      "kind": "script",
      "test": "(()=>{const doc=new DOMParser().parseFromString('<!doctype html><body><?pi-probe value=\"domparser\"?><p>after</p></body>','text/html');const walker=doc.createTreeWalker(doc,NodeFilter.SHOW_PROCESSING_INSTRUCTION);const node=walker.nextNode();return !!node&&node.target==='pi-probe'&&node.data.includes('domparser');})()",
      "specSection": "https://github.com/whatwg/html/pull/12118"
    },
    {
      "id": "xml-target-remains-comment",
      "description": "The block-listed <?xml ...?> target is not converted into a ProcessingInstruction node by the HTML parser.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');host.innerHTML='<?xml version=\"1.0\"?>';const node=host.firstChild;return !!node&&node.nodeType===Node.COMMENT_NODE;})()",
      "specSection": "https://github.com/whatwg/html/pull/12118"
    },
    {
      "id": "xml-stylesheet-target-remains-comment",
      "description": "The block-listed <?xml-stylesheet ...?> target remains a comment in HTML parsing.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');host.innerHTML='<?xml-stylesheet href=\"theme.css\"?>';const node=host.firstChild;return !!node&&node.nodeType===Node.COMMENT_NODE;})()",
      "specSection": "https://github.com/whatwg/html/pull/12118"
    },
    {
      "id": "invalid-target-remains-comment",
      "description": "Invalid PI targets such as those starting with a digit are not exposed as ProcessingInstruction nodes.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');host.innerHTML='<?1st-place value=\"bad\"?>';const node=host.firstChild;return !!node&&node.nodeType===Node.COMMENT_NODE;})()",
      "specSection": "https://github.com/whatwg/html/pull/12118"
    },
    {
      "id": "streaming-use-case-route-serves-pis",
      "description": "The streaming-use-case live route serves text/html containing literal processing-instruction syntax across the response.",
      "kind": "script",
      "test": "(async()=>{const res=await fetch('/v150/parse-processing-instructions-in-html/streaming-use-case/live?delay=300&run=conformance',{cache:'no-store'});const text=await res.text();return res.ok&&(res.headers.get('content-type')||'').startsWith('text/html')&&(res.headers.get('cache-control')||'').includes('no-store')&&text.includes('<?stream-start name=\"recommendations\"')&&text.includes('<?stream-end name=\"recommendations\"')&&text.includes('<?server-data source=\"recommendations-db\"');})()",
      "specSection": "https://github.com/WICG/declarative-partial-updates/blob/main/patching-explainer.md#proposed-markup"
    },
    {
      "id": "live-streamed-document-preserves-pis",
      "description": "A same-origin streamed document exposes its parsed processing instructions through TreeWalker.",
      "kind": "script",
      "test": "(async()=>{const iframe=document.createElement('iframe');iframe.hidden=true;iframe.src='/v150/parse-processing-instructions-in-html/streaming-use-case/live?delay=250&run=conformance-frame';document.body.appendChild(iframe);try{await new Promise((resolve,reject)=>{const timer=setTimeout(()=>reject(new Error('iframe timed out')),5000);iframe.addEventListener('load',()=>{clearTimeout(timer);resolve();},{once:true});});const doc=iframe.contentDocument;if(!doc)return false;const walker=doc.createTreeWalker(doc,NodeFilter.SHOW_PROCESSING_INSTRUCTION);const targets=[];let node;while((node=walker.nextNode()))targets.push(node.target);return targets.includes('stream-start')&&targets.includes('stream-end')&&targets.includes('server-data');}catch(_){return false;}finally{iframe.remove();}})()",
      "specSection": "https://github.com/whatwg/html/pull/12118",
      "expectedBrowsers": ["chrome"]
    }
  ]
}
