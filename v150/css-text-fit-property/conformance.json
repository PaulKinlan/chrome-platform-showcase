      "id": "text-fit-shrinks-to-container",
      "description": "Wide text inside a narrow container with text-fit: width fits within the container width.",
      "kind": "script",
      "test": "(()=>{const wrap=document.createElement('div');wrap.style.cssText='width:100px;overflow:hidden;';const h=document.createElement('h1');h.style.cssText='text-fit:width;font-size:160px;margin:0;white-space:nowrap;';h.textContent='TextFit';wrap.appendChild(h);document.body.appendChild(wrap);const r=h.getBoundingClientRect().width;wrap.remove();return r<=101;})()"
