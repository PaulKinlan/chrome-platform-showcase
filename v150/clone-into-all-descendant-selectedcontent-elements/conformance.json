{
  "release": "v150",
  "featureSlug": "clone-into-all-descendant-selectedcontent-elements",
  "chromestatusId": 5863985044914176,
  "specUrl": "https://html.spec.whatwg.org/multipage/form-elements.html#the-selectedcontent-element",
  "generatedAt": "2026-06-02T13:54:51Z",
  "author": "manual-goal-setting",
  "assertions": [
    {
      "id": "html-selectedcontent-interface",
      "description": "HTMLSelectedContentElement is exposed for native customizable select selectedcontent elements.",
      "kind": "exists",
      "test": "HTMLSelectedContentElement"
    },
    {
      "id": "selectedcontent-uses-native-interface",
      "description": "document.createElement('selectedcontent') creates an HTMLSelectedContentElement instance rather than an unknown element.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('selectedcontent');return typeof HTMLSelectedContentElement==='function'&&e instanceof HTMLSelectedContentElement&&!(e instanceof HTMLUnknownElement);})()"
    },
    {
      "id": "base-select-appearance-support",
      "description": "Customizable select styling uses the base-select appearance keyword.",
      "kind": "css-supports",
      "test": "appearance: base-select"
    },
    {
      "id": "parser-preserves-multiple-descendant-selectedcontent",
      "description": "The parser preserves multiple selectedcontent descendants inside the select button subtree.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');s.innerHTML='<button><span><selectedcontent></selectedcontent></span><span><selectedcontent></selectedcontent></span><span><selectedcontent></selectedcontent></span></button><option>One</option>';return s.querySelectorAll('selectedcontent').length===3&&[...s.querySelectorAll('selectedcontent')].every(sc=>sc.closest('button')&&sc.closest('select')===s);})()"
    },
    {
      "id": "all-descendant-selectedcontent-receive-selected-option-clone",
      "description": "Chrome 150 clones the selected option into every descendant selectedcontent element, not only the first one in DOM order.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');s.style.appearance='base-select';s.innerHTML='<button><span><selectedcontent></selectedcontent></span><span><selectedcontent></selectedcontent></span><span><selectedcontent></selectedcontent></span></button><option value=\"a\"><span>Alpha label</span></option><option value=\"b\"><span>Beta label</span></option>';document.body.appendChild(s);const mirrors=[...s.querySelectorAll('selectedcontent')];const ok=mirrors.length===3&&mirrors.every(sc=>sc.textContent.includes('Alpha label'));s.remove();return ok;})()"
    },
    {
      "id": "selectedcontent-clone-updates-after-selection-change",
      "description": "After the selected value changes, every descendant selectedcontent element reflects the newly selected option.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');s.style.appearance='base-select';s.innerHTML='<button><span><selectedcontent></selectedcontent></span><span><selectedcontent></selectedcontent></span><span><selectedcontent></selectedcontent></span></button><option value=\"a\"><span>Alpha label</span></option><option value=\"b\"><span>Beta label</span></option>';document.body.appendChild(s);s.value='b';const mirrors=[...s.querySelectorAll('selectedcontent')];const ok=mirrors.length===3&&mirrors.every(sc=>sc.textContent.includes('Beta label'));s.remove();return ok;})()"
    },
    {
      "id": "select-options-collection-remains-live",
      "description": "HTMLSelectElement.options remains a live HTMLOptionsCollection; the selectedcontent clone behavior does not change legacy select APIs.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');const first=document.createElement('option');s.append(first);const before=s.options.length;const second=document.createElement('option');s.append(second);return before===1&&s.options.length===2&&typeof s.options.item==='function';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
}
