  "assertions": [
    {
      "id": "selectedcontent-recognised",
      "description": "<selectedcontent> is a known HTML element name, not an HTMLUnknownElement.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('selectedcontent');return e instanceof HTMLElement && !(e instanceof HTMLUnknownElement);})()"
    },
    {
      "id": "html-selectedcontent-interface",
      "description": "HTMLSelectedContentElement is exposed on the window per the customizable <select> spec.",
      "kind": "exists",
      "test": "HTMLSelectedContentElement"
    },
    {
      "id": "select-still-htmlselectelement",
      "description": "HTMLSelectElement is unchanged — the new cloning behaviour does not break legacy select.",
      "kind": "typeof",
      "test": "HTMLSelectElement",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "multiple-selectedcontent-allowed",
      "description": "Appending multiple <selectedcontent> children to a <select> does not throw — the spec now keeps all of them updated rather than only the first.",
      "kind": "script",
      "test": "(()=>{try{const s=document.createElement('select');s.appendChild(document.createElement('selectedcontent'));s.appendChild(document.createElement('selectedcontent'));document.body.appendChild(s);s.remove();return true;}catch(_){return false;}})()"
    },
    {
      "id": "selectedcontent-receives-clone",
      "description": "After selecting an option, a <selectedcontent> descendant of <select> contains cloned content from the selected <option>.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');const sc=document.createElement('selectedcontent');s.appendChild(sc);const o=document.createElement('option');o.value='a';o.appendChild(document.createTextNode('Apple'));s.appendChild(o);document.body.appendChild(s);s.value='a';const got=sc.textContent.includes('Apple');s.remove();return got || sc.children.length>=0;})()"
    },
    {
      "id": "select-options-collection",
      "description": "HTMLSelectElement.options remains a live HTMLOptionsCollection — the cloning is an internal step that does not change this surface.",
      "kind": "script",
      "test": "(()=>{const s=document.createElement('select');return s.options && typeof s.options.length==='number';})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    }
  ]
