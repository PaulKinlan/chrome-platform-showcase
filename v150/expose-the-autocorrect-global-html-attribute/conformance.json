      "description": "HTMLInputElement reflects an autocorrect IDL attribute.",
      "kind": "script",
      "test": "'autocorrect' in document.createElement('input')",
      "specSection": "https://html.spec.whatwg.org/multipage/interaction.html#autocorrection"
    },
    {
      "id": "autocorrect-on-textarea",
      "description": "HTMLTextAreaElement reflects autocorrect.",
      "kind": "script",
      "test": "'autocorrect' in document.createElement('textarea')"
    },
    {
      "id": "autocorrect-on-htmlelement-global",
      "description": "Per spec, autocorrect is a global HTML attribute — it is reflected on the HTMLElement prototype.",
      "kind": "script",
      "test": "'autocorrect' in document.createElement('div')"
    },
    {
      "id": "autocorrect-attribute-on-roundtrip",
      "description": "Setting input.autocorrect=true sets the content attribute to 'on' per the boolean-attribute reflection rules.",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('input');i.autocorrect=true;return i.getAttribute('autocorrect')==='on' || i.getAttribute('autocorrect')==='';})()"
    },
    {
      "id": "autocorrect-attribute-off",
      "description": "Setting autocorrect=false sets the content attribute to 'off'.",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('input');i.autocorrect=false;return i.getAttribute('autocorrect')==='off' || i.autocorrect===false;})()"
    },
    {
      "id": "autocorrect-default-state",
      "description": "Default value of autocorrect on a fresh input is truthy (browser default is autocorrect on).",
      "kind": "script",
      "test": "(()=>{const i=document.createElement('input');return i.autocorrect!==false;})()"
    }
