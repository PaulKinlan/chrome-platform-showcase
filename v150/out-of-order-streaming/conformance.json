  "assertions": [
    {
      "id": "template-element-supported",
      "description": "HTMLTemplateElement is exposed (baseline) — the carrier for out-of-order streaming.",
      "kind": "exists",
      "test": "HTMLTemplateElement",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "template-for-attribute-reflected",
      "description": "<template> reflects a 'for' attribute used to target an existing DOM range.",
      "kind": "script",
      "test": "(()=>{const t=document.createElement('template');t.setAttribute('for','range-1');return t.getAttribute('for')==='range-1';})()",
      "specSection": "https://github.com/whatwg/html/pull/11818"
    },
    {
      "id": "processing-instruction-node-type",
      "description": "Document.PROCESSING_INSTRUCTION_NODE constant is exposed; PIs are part of the DOM that out-of-order streaming uses for range markers.",
      "kind": "script",
      "test": "Node.PROCESSING_INSTRUCTION_NODE===7"
    },
    {
      "id": "create-processing-instruction-still-works",
      "description": "document.createProcessingInstruction returns a ProcessingInstruction node.",
      "kind": "script",
      "test": "(()=>{try{const pi=document.createProcessingInstruction('start','x');return pi.nodeType===7;}catch(_){return false;}})()"
    },
    {
      "id": "template-fragment-content",
      "description": "<template>.content is a DocumentFragment (the buffer the out-of-order chunk renders into).",
      "kind": "script",
      "test": "(()=>{const t=document.createElement('template');return t.content instanceof DocumentFragment;})()",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "html-parsing-streaming-via-textcontent",
      "description": "Assigning innerHTML containing <template for=\"x\">...</template> retains the for attribute through parse.",
      "kind": "script",
      "test": "(()=>{const c=document.createElement('div');c.innerHTML='<template for=\"x\"><p>hi</p></template>';const t=c.querySelector('template');return !!t && t.getAttribute('for')==='x';})()"
    }
  ]
