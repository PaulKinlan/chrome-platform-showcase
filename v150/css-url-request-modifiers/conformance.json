  "assertions": [
    {
      "id": "url-baseline",
      "description": "Baseline url() in background-image still parses (regression check).",
      "kind": "css-supports",
      "test": "background-image: url(\"x.png\")",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "url-with-cross-origin-modifier",
      "description": "url() accepts the cross-origin() modifier per the spec.",
      "kind": "css-supports",
      "test": "background-image: url(\"x.png\" cross-origin(anonymous))",
      "specSection": "https://drafts.csswg.org/css-values-5/#request-url-modifiers"
    },
    {
      "id": "url-with-integrity-modifier",
      "description": "url() accepts the integrity() modifier carrying a Subresource-Integrity hash.",
      "kind": "css-supports",
      "test": "background-image: url(\"x.png\" integrity(\"sha384-AAAA\"))"
    },
    {
      "id": "url-with-referrer-policy-modifier",
      "description": "url() accepts the referrer-policy() modifier with a known referrer-policy token.",
      "kind": "css-supports",
      "test": "background-image: url(\"x.png\" referrer-policy(no-referrer))"
    },
    {
      "id": "url-with-multiple-modifiers",
      "description": "Multiple modifiers compose inside one url().",
      "kind": "css-supports",
      "test": "background-image: url(\"x.png\" cross-origin(use-credentials) referrer-policy(origin))"
    },
    {
      "id": "url-bogus-modifier-rejected",
      "description": "An unrecognised modifier name is rejected so the parser remains strict.",
      "kind": "script",
      "test": "!CSS.supports('background-image','url(\"x.png\" definitely-not-a-modifier(foo))')"
    },
    {
      "id": "server-meta-provides-sri-hashes",
      "description": "The crossorigin and integrity demo exposes server-computed SHA-384 SRI hashes for clean and tampered resources.",
      "kind": "script",
      "test": "fetch('/v150/css-url-request-modifiers/crossorigin-integrity-demo/asset-meta', { cache: 'no-store' }).then((r) => r.ok && r.json()).then((m) => /^sha384-[A-Za-z0-9+/]+=*$/.test(m.cleanSha384) && /^sha384-[A-Za-z0-9+/]+=*$/.test(m.tamperedSha384) && m.cleanSha384 !== m.tamperedSha384)"
    },
    {
      "id": "server-public-cors-header",
      "description": "The demo resource can return a public CORS response for anonymous CSS resource requests.",
      "kind": "script",
      "test": "fetch('/v150/css-url-request-modifiers/crossorigin-integrity-demo/resource.svg?cors=public&variant=clean', { cache: 'no-store' }).then((r) => r.headers.get('access-control-allow-origin') === '*' && r.headers.get('x-demo-variant') === 'clean' && !!r.headers.get('x-demo-sha384'))"
    },
    {
      "id": "server-credentialed-cors-headers",
      "description": "The demo resource can return credentialed CORS headers by echoing the request origin and sending Access-Control-Allow-Credentials.",
      "kind": "script",
      "test": "fetch('/v150/css-url-request-modifiers/crossorigin-integrity-demo/resource.svg?cors=credentialed&variant=clean', { cache: 'no-store' }).then((r) => r.headers.get('access-control-allow-origin') === location.origin && r.headers.get('access-control-allow-credentials') === 'true')"
    },
    {
      "id": "server-blocked-cors-omits-acao",
      "description": "The demo resource can deliberately omit Access-Control-Allow-Origin for the CORS failure path.",
      "kind": "script",
      "test": "fetch('/v150/css-url-request-modifiers/crossorigin-integrity-demo/resource.svg?cors=blocked&variant=clean', { cache: 'no-store' }).then((r) => r.headers.get('access-control-allow-origin') === null)"
    }
  ]
}
