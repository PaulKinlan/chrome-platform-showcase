  "author": "codex-goal-setting",
  "assertions": [
    {
      "id": "destination-manifest-id-required",
      "description": "The destination manifest declares a stable id before naming any predecessor app.",
      "kind": "script",
      "test": "(()=>{const m={id:'https://app.example.com/app/',start_url:'/app/',scope:'/app/',migrate_from:[{id:'https://www.example.com/app/'}]};return typeof m.id==='string'&&m.id.startsWith('https://app.example.com/')&&Array.isArray(m.migrate_from);})()",
      "specSection": "https://developer.chrome.com/blog/seamless-pwa-origin-migration#how-to-migrate-a-pwa"
    },
    {
      "id": "migrate-from-names-old-app-id",
      "description": "The destination manifest's migrate_from entry names the installed app id from the old origin.",
      "kind": "script",
      "test": "(()=>{const m={id:'https://app.example.com/app/',migrate_from:[{id:'https://www.example.com/app/',behavior:'suggest'}]};return m.migrate_from.some((entry)=>entry&&entry.id==='https://www.example.com/app/');})()",
      "specSection": "https://developer.chrome.com/blog/seamless-pwa-origin-migration#step-1-the-new-app-declares-the-predecessor-required"
    },
    {
      "id": "allow-migration-authorizes-destination-id",
      "description": "The old origin's web-app-origin-association object authorizes the destination app id with allow_migration: true.",
      "kind": "script",
      "test": "(()=>{const destination='https://app.example.com/app/';const association={};association[destination]={allow_migration:true};return association[destination]?.allow_migration===true;})()",
      "specSection": "https://developer.chrome.com/blog/seamless-pwa-origin-migration#step-2-the-old-origin-confirms-the-migration-required"
    },
    {
      "id": "migration-behavior-values",
      "description": "The migration behavior is either suggest or force, with suggest used for a passive rollout.",
      "kind": "script",
      "test": "(()=>['suggest','force'].includes({behavior:'suggest'}.behavior)&&!['suggest','force'].includes('silent'))()",
      "specSection": "https://developer.chrome.com/blog/seamless-pwa-origin-migration#control-the-user-experience"
    },
    {
      "id": "old-manifest-migrate-to-hint",
      "description": "The old manifest can proactively point to the destination app id with migrate_to.",
      "kind": "script",
      "test": "(()=>{const oldManifest={migrate_to:{id:'https://app.example.com/app/',install_url:'https://app.example.com/app/'}};return oldManifest.migrate_to.id==='https://app.example.com/app/'&&oldManifest.migrate_to.install_url.startsWith('https://app.example.com/');})()",
      "specSection": "https://developer.chrome.com/blog/seamless-pwa-origin-migration#step-3-proactive-signaling-optional"
    },
    {
      "id": "same-site-limitation",
      "description": "The migration stays within the same site boundary rather than moving between unrelated registrable domains.",
      "kind": "script",
      "test": "(()=>{const site=(url)=>new URL(url).hostname.split('.').slice(-2).join('.');return site('https://www.example.com/app/')===site('https://app.example.com/app/')&&site('https://oldcompany.com/app/')!==site('https://newcompany.com/app/');})()",
      "specSection": "https://developer.chrome.com/blog/seamless-pwa-origin-migration#the-two-way-handshake-how-it-works"
    }
  ]
}
