      "test": "(()=>{const wrap=document.createElement('div');wrap.style.cssText='width:120px;overflow:hidden;';const h=document.createElement('h1');h.style.cssText='text-fit:width;font-size:200px;margin:0;white-space:nowrap;';h.textContent='Headline';wrap.appendChild(h);document.body.appendChild(wrap);const r=h.getBoundingClientRect().width;wrap.remove();return r<=121;})()"
