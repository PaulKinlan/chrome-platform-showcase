      "kind": "script",
      "test": "(()=>{const e=document.createElement('span');e.style.setProperty('text-fit','width');document.body.appendChild(e);const v=getComputedStyle(e).getPropertyValue('text-fit').trim();e.remove();return v.includes('width');})()"
