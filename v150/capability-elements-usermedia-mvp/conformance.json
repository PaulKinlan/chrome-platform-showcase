      "id": "usermedia-element-constructible",
      "description": "<usermedia> parses as a known HTML element name (createElement returns an HTMLElement, not HTMLUnknownElement).",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('usermedia');return e instanceof HTMLElement && !(e instanceof HTMLUnknownElement);})()"
    },
    {
      "id": "html-user-media-element-exposed",
      "description": "The HTMLUserMediaElement interface is exposed on window for the declarative capability element.",
      "kind": "exists",
      "test": "HTMLUserMediaElement"
    },
    {
      "id": "getusermedia-still-available",
      "description": "navigator.mediaDevices.getUserMedia remains available — capability elements supplement, not replace, the imperative API.",
      "kind": "typeof",
      "test": "navigator.mediaDevices.getUserMedia",
      "expect": "function",
      "expectedBrowsers": ["chrome", "firefox", "safari"]
    },
    {
      "id": "usermedia-kind-attribute",
      "description": "The <usermedia> element reflects a kind attribute used to scope between audio, video, or both.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('usermedia');e.setAttribute('kind','video');return e.getAttribute('kind')==='video';})()"
    },
    {
      "id": "usermedia-track-event",
      "description": "Adding a 'track' event listener to a <usermedia> element does not throw — the spec defines this event for stream lifecycle.",
      "kind": "script",
      "test": "(()=>{try{const e=document.createElement('usermedia');const fn=()=>{};e.addEventListener('track',fn);e.removeEventListener('track',fn);return true;}catch(_){return false;}})()"
    },
    {
      "id": "permissions-policy-camera-still-defined",
      "description": "The 'camera' Permissions Policy feature continues to gate access — capability elements still respect Permissions Policy.",
      "kind": "script",
      "test": "(()=>{const p=document.permissionsPolicy||document.featurePolicy;return !!p && typeof p.allowsFeature==='function' && p.allowsFeature('camera')!==undefined;})()"
    }
