      "id": "root-computed-value-roundtrips",
      "description": "The root element's overscroll-behavior-y declaration round-trips through computed style.",
      "kind": "script",
      "test": "(()=>{const root=document.documentElement;const prev=root.style.overscrollBehaviorY;root.style.overscrollBehaviorY='none';const v=getComputedStyle(root).overscrollBehaviorY;root.style.overscrollBehaviorY=prev;return v==='none';})()",
      "specSection": "https://drafts.csswg.org/css-overscroll-behavior-1/#overscroll-behavior-properties"
    },
    {
      "id": "standards-scrolling-element-is-root",
      "description": "In standards mode the documentElement is the scrolling element whose root overscroll value propagates to the viewport.",
      "kind": "script",
      "test": "document.compatMode==='CSS1Compat'&&document.scrollingElement===document.documentElement",
      "specSection": "https://drafts.csswg.org/css-overscroll-behavior-1/#overscroll-behavior-properties"
    },
    {
      "id": "overscroll-behavior-not-inherited",
      "description": "overscroll-behavior is not inherited by nested scroll containers.",
      "kind": "script",
      "test": "(()=>{const p=document.createElement('div');const c=document.createElement('div');p.style.overscrollBehavior='contain';p.append(c);document.body.append(p);const v=getComputedStyle(c).overscrollBehavior;document.body.removeChild(p);return v==='auto';})()",
      "specSection": "https://drafts.csswg.org/css-overscroll-behavior-1/#overscroll-behavior-properties"
