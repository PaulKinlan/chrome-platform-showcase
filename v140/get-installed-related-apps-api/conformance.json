  "assertions": [
    {
      "id": "navigator-method-exists",
      "description": "navigator.getInstalledRelatedApps is exposed as the entry point for querying installed related applications.",
      "kind": "typeof",
      "test": "navigator.getInstalledRelatedApps",
      "expect": "function",
      "specSection": "https://wicg.github.io/get-installed-related-apps/spec/#api"
    },
    {
      "id": "navigator-prototype-method-exists",
      "description": "Navigator.prototype includes getInstalledRelatedApps so every Navigator instance shares the API.",
      "kind": "script",
      "test": "(()=>{try{return typeof Navigator.prototype.getInstalledRelatedApps==='function';}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/get-installed-related-apps/spec/#api"
    },
    {
      "id": "method-has-zero-required-arguments",
      "description": "getInstalledRelatedApps takes no required arguments.",
      "kind": "script",
      "test": "(()=>{try{return navigator.getInstalledRelatedApps.length===0;}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/get-installed-related-apps/spec/#api"
    },
    {
      "id": "call-returns-promise",
      "description": "Calling getInstalledRelatedApps returns a Promise.",
      "kind": "script",
      "test": "(()=>{try{const p=navigator.getInstalledRelatedApps();if(p&&typeof p.catch==='function')p.catch(()=>{});return p instanceof Promise;}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/get-installed-related-apps/spec/#api"
    },
    {
      "id": "call-resolves-array",
      "description": "The API resolves to an array; a generic origin without verified related apps should resolve to an empty array.",
      "kind": "script",
      "test": "(async()=>{try{const apps=await navigator.getInstalledRelatedApps();return Array.isArray(apps);}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/get-installed-related-apps/spec/#api"
    },
    {
      "id": "result-entries-have-platform",
      "description": "Any returned related application records include a string platform identifier.",
      "kind": "script",
      "test": "(async()=>{try{const apps=await navigator.getInstalledRelatedApps();return apps.every(app=>app&&typeof app.platform==='string');}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/get-installed-related-apps/spec/#dictdef-relatedapplication"
    },
    {
      "id": "result-entry-optional-fields-are-strings",
      "description": "When a related application record includes id, url, or version, those fields are strings.",
      "kind": "script",
      "test": "(async()=>{try{const apps=await navigator.getInstalledRelatedApps();return apps.every(app=>(app.id===undefined||typeof app.id==='string')&&(app.url===undefined||typeof app.url==='string')&&(app.version===undefined||typeof app.version==='string'));}catch(e){return false;}})()",
      "specSection": "https://wicg.github.io/get-installed-related-apps/spec/#dictdef-relatedapplication"
    }
  ]
}
