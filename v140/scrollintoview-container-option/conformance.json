    {
      "id": "container-nearest-scrolls-only-nearest-ancestor",
      "description": "container: 'nearest' scrolls the nearest scroll container and leaves outer scroll containers at their current position.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');host.style.cssText='position:fixed;left:0;top:0;width:300px;height:300px;overflow:hidden;opacity:0;pointer-events:none;';const outer=document.createElement('div');outer.style.cssText='width:120px;height:120px;overflow:auto;scroll-behavior:auto;';const outerPad=document.createElement('div');outerPad.style.cssText='height:160px;';const inner=document.createElement('div');inner.style.cssText='width:100px;height:100px;overflow:auto;scroll-behavior:auto;';const innerPad=document.createElement('div');innerPad.style.cssText='height:160px;';const target=document.createElement('div');target.style.cssText='height:20px;';inner.append(innerPad,target);outer.append(outerPad,inner);host.append(outer);document.body.append(host);outer.scrollTop=40;try{target.scrollIntoView({container:'nearest',block:'start',inline:'nearest',behavior:'auto'});return inner.scrollTop>0&&outer.scrollTop===40;}catch(e){return false;}finally{host.remove();}})()",
      "specSection": "https://drafts.csswg.org/cssom-view/#dom-element-scrollintoview"
    },
    {
      "id": "container-all-scrolls-ancestor-chain",
      "description": "container: 'all' scrolls each scrollable ancestor needed to bring the target into view.",
      "kind": "script",
      "test": "(()=>{const host=document.createElement('div');host.style.cssText='position:fixed;left:0;top:0;width:300px;height:300px;overflow:hidden;opacity:0;pointer-events:none;';const outer=document.createElement('div');outer.style.cssText='width:120px;height:120px;overflow:auto;scroll-behavior:auto;';const outerPad=document.createElement('div');outerPad.style.cssText='height:160px;';const inner=document.createElement('div');inner.style.cssText='width:100px;height:100px;overflow:auto;scroll-behavior:auto;';const innerPad=document.createElement('div');innerPad.style.cssText='height:160px;';const target=document.createElement('div');target.style.cssText='height:20px;';inner.append(innerPad,target);outer.append(outerPad,inner);host.append(outer);document.body.append(host);try{target.scrollIntoView({container:'all',block:'start',inline:'nearest',behavior:'auto'});return inner.scrollTop>0&&outer.scrollTop>0;}catch(e){return false;}finally{host.remove();}})()",
      "specSection": "https://drafts.csswg.org/cssom-view/#dom-scrollintoviewoptions-container"
    },
