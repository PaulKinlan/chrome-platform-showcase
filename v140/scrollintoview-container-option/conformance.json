      "test": "(()=>{const host=document.createElement('div');host.style.cssText='position:fixed;left:0;top:0;width:300px;height:300px;overflow:hidden;opacity:0;pointer-events:none;';const outer=document.createElement('div');outer.style.cssText='width:120px;height:120px;overflow:auto;white-space:nowrap;scroll-behavior:auto;direction:ltr;';const outerPad=document.createElement('span');outerPad.style.cssText='display:inline-block;width:160px;height:1px;';const inner=document.createElement('div');inner.style.cssText='display:inline-block;width:100px;height:100px;overflow:auto;white-space:nowrap;scroll-behavior:auto;vertical-align:top;direction:ltr;';const innerPad=document.createElement('span');innerPad.style.cssText='display:inline-block;width:160px;height:20px;';const target=document.createElement('span');target.style.cssText='display:inline-block;width:20px;height:20px;';inner.append(innerPad,target);outer.append(outerPad,inner);host.append(outer);document.body.append(host);try{target.scrollIntoView({container:'nearest',block:'nearest',inline:'start',behavior:'auto'});return inner.scrollLeft>0&&outer.scrollLeft===0;}catch(e){return false;}finally{host.remove();}})()",
