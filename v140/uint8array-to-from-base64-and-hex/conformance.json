    {
      "id": "base64-roundtrip-standard-alphabet",
      "description": "Bytes round-trip through standard base64 with the default alphabet and padding behavior.",
      "kind": "script",
      "test": "(()=>{try{const bytes=new Uint8Array([104,101,108,108,111]);const encoded=bytes.toBase64();const decoded=Uint8Array.fromBase64(encoded);return encoded==='aGVsbG8='&&decoded.length===5&&decoded.every((b,i)=>b===bytes[i]);}catch(e){return false;}})()",
      "specSection": "https://tc39.es/proposal-arraybuffer-base64/spec/#sec-uint8array.prototype.tobase64"
    },
    {
      "id": "base64url-alphabet-option",
      "description": "The alphabet option supports URL-safe base64 encoding and decoding.",
      "kind": "script",
      "test": "(()=>{try{const bytes=new Uint8Array([255,238,221]);const encoded=bytes.toBase64({alphabet:'base64url',omitPadding:true});const decoded=Uint8Array.fromBase64(encoded,{alphabet:'base64url'});return encoded==='_-7d'&&decoded.length===3&&decoded[0]===255&&decoded[1]===238&&decoded[2]===221;}catch(e){return false;}})()",
      "specSection": "https://tc39.es/proposal-arraybuffer-base64/spec/#sec-to-uint8array-encode-set"
    },
    {
      "id": "hex-roundtrip-lowercase",
      "description": "Bytes round-trip through lowercase hexadecimal strings.",
      "kind": "script",
      "test": "(()=>{try{const bytes=new Uint8Array([0,15,16,255]);const hex=bytes.toHex();const decoded=Uint8Array.fromHex(hex);return hex==='000f10ff'&&decoded.length===4&&decoded.every((b,i)=>b===bytes[i]);}catch(e){return false;}})()",
      "specSection": "https://tc39.es/proposal-arraybuffer-base64/spec/#sec-uint8array.prototype.tohex"
    },
    {
      "id": "setfrombase64-read-written-counts",
      "description": "Uint8Array.prototype.setFromBase64 decodes into an existing buffer and reports read/written counters.",
      "kind": "script",
      "test": "(()=>{try{const out=new Uint8Array(8);const result=out.setFromBase64('aGk=');return result.read===4&&result.written===2&&out[0]===104&&out[1]===105;}catch(e){return false;}})()",
      "specSection": "https://tc39.es/proposal-arraybuffer-base64/spec/#sec-uint8array.prototype.setfrombase64"
    }
