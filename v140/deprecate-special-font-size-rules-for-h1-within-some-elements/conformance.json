    {
      "id": "bare-h1-default-font-size",
      "description": "A bare top-level h1 still renders at a positive user-agent default font size.",
      "kind": "script",
      "test": "(()=>{const h=document.createElement('h1');h.textContent='x';document.body.appendChild(h);const s=parseFloat(getComputedStyle(h).fontSize);h.remove();return s>0;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/rendering.html#sections-and-headings"
    },
    {
      "id": "h1-in-section-uses-base-h1-size",
      "description": "An h1 nested in section no longer gets a downsized user-agent style.",
      "kind": "script",
      "test": "(()=>{const wrap=document.createElement('div');wrap.innerHTML='<h1 id=\"bare\">x</h1><section><h1 id=\"nested\">x</h1></section>';document.body.appendChild(wrap);const b=parseFloat(getComputedStyle(wrap.querySelector('#bare')).fontSize);const n=parseFloat(getComputedStyle(wrap.querySelector('#nested')).fontSize);wrap.remove();return Math.abs(b-n)<0.5;})()",
      "specSection": "https://html.spec.whatwg.org/multipage/rendering.html#sections-and-headings"
    },
