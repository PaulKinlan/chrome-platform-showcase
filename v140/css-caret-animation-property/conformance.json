{
  "release": "v140",
  "featureSlug": "css-caret-animation-property",
  "chromestatusId": 5082469066604544,
  "specUrl": "https://drafts.csswg.org/css-ui/#caret-animation",
  "generatedAt": "2026-06-01T23:47:03Z",
  "author": "codex",
  "assertions": [
    {
      "id": "caret-animation-auto-supported",
      "description": "caret-animation accepts the auto keyword, preserving the user agent's default caret animation behavior.",
      "kind": "css-supports",
      "test": "caret-animation: auto",
      "specSection": "https://drafts.csswg.org/css-ui/#caret-animation"
    },
    {
      "id": "caret-animation-manual-supported",
      "description": "caret-animation accepts the manual keyword, allowing authors to suppress user-agent-driven caret animation.",
      "kind": "css-supports",
      "test": "caret-animation: manual",
      "specSection": "https://drafts.csswg.org/css-ui/#caret-animation"
    },
    {
      "id": "caret-animation-rejects-unknown-keywords",
      "description": "caret-animation rejects identifiers outside the defined auto and manual keywords.",
      "kind": "script",
      "test": "CSS.supports('caret-animation: auto')&&CSS.supports('caret-animation: manual')&&!CSS.supports('caret-animation: blink')&&!CSS.supports('caret-animation: none')&&!CSS.supports('caret-animation: 1s')",
      "specSection": "https://drafts.csswg.org/css-ui/#caret-animation"
    },
    {
      "id": "caret-animation-initial-auto",
      "description": "The initial computed value of caret-animation is auto.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('input');document.body.appendChild(e);const v=getComputedStyle(e).getPropertyValue('caret-animation');e.remove();return v==='auto';})()",
      "specSection": "https://drafts.csswg.org/css-ui/#caret-animation"
    },
    {
      "id": "caret-animation-computes-specified-keyword",
      "description": "caret-animation computes to the specified keyword for manual and auto declarations.",
      "kind": "script",
      "test": "(()=>{const e=document.createElement('textarea');document.body.appendChild(e);e.style.setProperty('caret-animation','manual');const manual=getComputedStyle(e).getPropertyValue('caret-animation');e.style.setProperty('caret-animation','auto');const auto=getComputedStyle(e).getPropertyValue('caret-animation');e.remove();return manual==='manual'&&auto==='auto';})()",
      "specSection": "https://drafts.csswg.org/css-ui/#caret-animation"
    },
    {
      "id": "caret-animation-is-inherited",
      "description": "caret-animation is inherited, so a text input child can inherit manual from an ancestor.",
      "kind": "script",
      "test": "(()=>{const wrapper=document.createElement('div');const input=document.createElement('input');wrapper.contentEditable='true';wrapper.style.setProperty('caret-animation','manual');wrapper.appendChild(input);document.body.appendChild(wrapper);const v=getComputedStyle(input).getPropertyValue('caret-animation');wrapper.remove();return v==='manual';})()",
      "specSection": "https://drafts.csswg.org/css-ui/#caret-animation"
    },
    {
      "id": "caret-color-animation-remains-valid-with-manual",
      "description": "CSS animations can still target caret-color while caret-animation is manual.",
      "kind": "script",
      "test": "(()=>{const style=document.createElement('style');style.textContent='@keyframes caretConformanceColor{from{caret-color:rgb(1, 2, 3)}to{caret-color:rgb(1, 2, 3)}}';const target=document.createElement('input');const ref=document.createElement('input');target.style.setProperty('caret-animation','manual');target.style.animationName='caretConformanceColor';target.style.animationDuration='1s';target.style.animationPlayState='paused';target.style.animationFillMode='both';ref.style.setProperty('caret-color','rgb(1, 2, 3)');document.head.appendChild(style);document.body.append(target,ref);const actual=getComputedStyle(target).getPropertyValue('caret-color');const expected=getComputedStyle(ref).getPropertyValue('caret-color');const ok=getComputedStyle(target).getPropertyValue('caret-animation')==='manual'&&actual===expected;target.remove();ref.remove();style.remove();return ok;})()",
      "specSection": "https://drafts.csswg.org/css-ui/#caret-animation"
    }
  ]
}
