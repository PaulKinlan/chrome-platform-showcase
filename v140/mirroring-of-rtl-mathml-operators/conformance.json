      "test": "(()=>{const w=document.createElement('div');w.innerHTML='<math><mo>(</mo></math>';const m=w.firstChild;return m&&m.tagName.toLowerCase()==='math'&&m.namespaceURI==='http://www.w3.org/1998/Math/MathML';})()",
      "specSection": "https://w3c.github.io/mathml-core/"
    },
    {
      "id": "mo-renders-as-mathml",
      "description": "mo inside math is a MathML operator element, not an HTMLUnknownElement.",
      "kind": "script",
      "test": "(()=>{const w=document.createElement('div');w.innerHTML='<math><mo>(</mo></math>';const mo=w.firstChild&&w.firstChild.firstChild;return mo&&mo.localName==='mo'&&mo.namespaceURI==='http://www.w3.org/1998/Math/MathML';})()",
      "specSection": "https://w3c.github.io/mathml-core/#the-mo-element"
    },
    {
      "id": "math-rtl-direction-respected",
      "description": "Setting dir=rtl on math yields a computed rtl direction for operator layout.",
      "kind": "script",
      "test": "(()=>{const w=document.createElement('div');w.innerHTML='<math dir=\"rtl\"><mo>(</mo></math>';document.body.appendChild(w);const dir=getComputedStyle(w.firstChild).direction;w.remove();return dir==='rtl';})()",
      "specSection": "https://w3c.github.io/mathml-core/#layout-of-operators"
    },
    {
